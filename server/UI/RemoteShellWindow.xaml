<Window x:Class="SeroServer.UI.RemoteShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Remote Shell"
        Width="720" Height="500" MinWidth="480" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border x:Name="RootBorder" CornerRadius="8" BorderThickness="1" ClipToBounds="True">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">

            <!-- ── Accent bar ───────────────────────────────────────── -->
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4A85F5" Offset="0"/>
                        <GradientStop Color="#7C5CE8" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- ── Title bar ────────────────────────────────────────── -->
            <Border DockPanel.Dock="Top" Height="40" Background="#111222"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                            <TextBlock FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#7AAEFF" Offset="0"/>
                                        <GradientStop Color="#B090FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                                <Run Text="Remote Shell"/>
                            </TextBlock>
                            <TextBlock x:Name="TxtTitle" Text=""
                                       FontSize="11" FontFamily="Segoe UI Mono">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#C0CCD8" Offset="0"/>
                                        <GradientStop Color="#6A8099" Offset="0.5"/>
                                        <GradientStop Color="#B0C0D0" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right" Width="28" Height="26"
                            Style="{StaticResource SRedBtn}" Click="Close_Click"
                            Padding="0" FontSize="10"/>
                </Grid>
            </Border>

            <!-- ── Status bar ───────────────────────────────────────── -->
            <Border DockPanel.Dock="Bottom" Height="28" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,0">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="›" Foreground="#4A85F5" FontFamily="Consolas"
                                   FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="TxtCommand" Style="{StaticResource STxt}"
                                 FontFamily="Consolas" FontSize="12"
                                 MinWidth="380" VerticalAlignment="Center"
                                 KeyDown="TxtCommand_KeyDown"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="SEND" Width="64" Height="22" Margin="0,0,8,0"
                                Style="{StaticResource SGreenBtn}" Click="Send_Click"
                                FontSize="10" FontWeight="SemiBold"/>
                        <Thumb Width="14" Height="14" VerticalAlignment="Center"
                               Cursor="SizeNWSE" DragDelta="ResizeGrip_DragDelta">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Path Data="M2,12 L12,2 M5,12 L12,5 M9,12 L12,9"
                                          Stroke="#4A85F5" StrokeThickness="1.2" Opacity="0.6"/>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Output (selectable TextBox) ─────────────────────── -->
            <Border Background="#111222" Margin="0" BorderBrush="#1A1C2E" BorderThickness="0,1,0,0">
                <ScrollViewer x:Name="OutputScroller" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Padding="4,4,4,4">
                    <TextBox x:Name="TxtOutput"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             FontFamily="Consolas" FontSize="12"
                             Foreground="#DDE0F0"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="10,8"
                             Text="Type a command and press Enter..."
                             SelectionBrush="#3A85F540"
                             CaretBrush="Transparent"
                             IsTabStop="False"
                             FocusVisualStyle="{x:Null}">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          VerticalScrollBarVisibility="Disabled"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </ScrollViewer>
            </Border>

        </DockPanel>
    </Border>
</Window>
