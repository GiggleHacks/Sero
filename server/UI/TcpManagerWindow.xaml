<Window x:Class="SeroServer.UI.TcpManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TCP Manager"
        Width="820" Height="500" MinWidth="640" MinHeight="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="8" BorderThickness="1" ClipToBounds="True">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">

            <!-- Accent bar -->
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4A85F5" Offset="0"/>
                        <GradientStop Color="#7C5CE8" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="40" Background="#111222"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⇄" FontSize="16" Foreground="#4A85F5" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="TCP Manager" FontSize="12" FontWeight="SemiBold" Foreground="#C0CCDD"
                                   VerticalAlignment="Center" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="TxtTitle" FontSize="11" Foreground="#404868"
                                   VerticalAlignment="Center" FontFamily="Segoe UI Mono" Margin="10,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="⟳ Refresh" Width="76" Height="26" Margin="0,0,6,0"
                                Style="{StaticResource SBtn}" FontSize="10" Click="Refresh_Click"/>
                        <Button x:Name="BtnMaxTcp" Content="☐" Width="28" Height="26" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="13" Padding="0" Click="BtnMax_Click"/>
                        <Button Content="✕" Width="28" Height="26" FontSize="10"
                                Style="{StaticResource SRedBtn}" Click="Close_Click" Padding="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Legend -->
            <Border DockPanel.Dock="Top" Background="#0A0B14" BorderBrush="#1A1C2E"
                    BorderThickness="0,0,0,1" Padding="14,5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="■" Foreground="#22C55E" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="ESTABLISHED" Foreground="#506880" FontSize="9" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <TextBlock Text="■" Foreground="#4A85F5" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="LISTEN" Foreground="#506880" FontSize="9" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <TextBlock Text="■" Foreground="#F59E0B" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="TIME_WAIT / CLOSE_WAIT" Foreground="#506880" FontSize="9" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <TextBlock Text="■" Foreground="#EF4444" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="SYN_SENT" Foreground="#506880" FontSize="9" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Height="28" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,0">
                                <Grid>
<TextBlock x:Name="TxtStatus" Text="Ready" Foreground="#404868"
                           FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Margin="14,0"/>
                    <Thumb Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,4,0" Cursor="SizeNWSE" DragDelta="ResizeGrip_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Path Data="M2,12 L12,2 M5,12 L12,5 M9,12 L12,9"
                                      Stroke="#4A85F5" StrokeThickness="1.2" Opacity="0.6"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>
            </Border>

            <!-- TCP Table -->
            <DataGrid x:Name="GridTcp"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Background="#0C0D18" Foreground="#DDE0F0"
                      BorderThickness="0" RowBackground="Transparent"
                      AlternatingRowBackground="Transparent"
                      GridLinesVisibility="None" HeadersVisibility="Column"
                      FontFamily="Consolas" FontSize="13" SelectionMode="Single"
                      CanUserAddRows="False" CanUserResizeRows="False"
                      ColumnHeaderHeight="32"
                      ColumnHeaderStyle="{StaticResource SColHeader}">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding State}" Value="ESTABLISHED">
                                <Setter Property="Background" Value="#081808"/>
                                <Setter Property="Foreground" Value="#B0D8B0"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding State}" Value="LISTEN">
                                <Setter Property="Background" Value="#080A1A"/>
                                <Setter Property="Foreground" Value="#A0B8E0"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding State}" Value="TIME_WAIT">
                                <Setter Property="Background" Value="#181208"/>
                                <Setter Property="Foreground" Value="#C8A050"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding State}" Value="CLOSE_WAIT">
                                <Setter Property="Background" Value="#180808"/>
                                <Setter Property="Foreground" Value="#C87878"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding State}" Value="SYN_SENT">
                                <Setter Property="Background" Value="#181008"/>
                                <Setter Property="Foreground" Value="#C8B060"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding State}" Value="SYN_RCVD">
                                <Setter Property="Background" Value="#181008"/>
                                <Setter Property="Foreground" Value="#C8B060"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding State}" Value="FIN_WAIT1">
                                <Setter Property="Background" Value="#100808"/>
                                <Setter Property="Foreground" Value="#C87878"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding State}" Value="FIN_WAIT2">
                                <Setter Property="Background" Value="#100808"/>
                                <Setter Property="Foreground" Value="#C87878"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="⬛ Close Connection" Click="CloseConn_Click"/>
                        <MenuItem Header="☠ Kill Process"     Click="KillProc_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="PID"            Binding="{Binding Pid}"         Width="60"/>
                    <DataGridTextColumn Header="PROCESS"        Binding="{Binding ProcessName}" Width="150"/>
                    <DataGridTextColumn Header="LOCAL ADDRESS"  Binding="{Binding LocalAddr}"   Width="*"/>
                    <DataGridTextColumn Header="REMOTE ADDRESS" Binding="{Binding RemoteAddr}"  Width="*"/>
                    <DataGridTemplateColumn Header="STATE" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8,0">
                                    <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,6,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#404868"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding State}" Value="ESTABLISHED"><Setter Property="Fill" Value="#22C55E"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="LISTEN">     <Setter Property="Fill" Value="#4A85F5"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="TIME_WAIT">  <Setter Property="Fill" Value="#F59E0B"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="CLOSE_WAIT"> <Setter Property="Fill" Value="#EF4444"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="SYN_SENT">   <Setter Property="Fill" Value="#F59E0B"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="SYN_RCVD">   <Setter Property="Fill" Value="#F59E0B"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="FIN_WAIT1">  <Setter Property="Fill" Value="#EF4444"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="FIN_WAIT2">  <Setter Property="Fill" Value="#EF4444"/></DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding State}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</Window>
