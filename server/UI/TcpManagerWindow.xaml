<Window x:Class="SeroServer.UI.TcpManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TCP Connections"
        Width="920" Height="540" MinWidth="680" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <Style TargetType="DataGridRow">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#B8C0D8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0D1020"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background"      Value="#101C3A"/>
                    <Setter Property="Foreground"      Value="#FFFFFF"/>
                    <Setter Property="BorderBrush"     Value="#4A85F5"/>
                    <Setter Property="BorderThickness" Value="2,0,0,0"/>
                </Trigger>
                <DataTrigger Binding="{Binding State}" Value="ESTABLISHED">
                    <Setter Property="Foreground" Value="#7DD8A0"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="LISTEN">
                    <Setter Property="Foreground" Value="#80A8E8"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="TIME_WAIT">
                    <Setter Property="Foreground" Value="#C8A060"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="CLOSE_WAIT">
                    <Setter Property="Foreground" Value="#D07070"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="SYN_SENT">
                    <Setter Property="Foreground" Value="#C8A060"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="10,5" BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#4A85F5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ContextMenu">
            <Setter Property="Background"      Value="#0F1020"/>
            <Setter Property="BorderBrush"     Value="#1E2038"/>
            <Setter Property="Foreground"      Value="#DDE0F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="#0F1020" BorderBrush="#1E2038" BorderThickness="1" CornerRadius="8" Padding="4">
                            <Border.Effect><DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.7" Color="#000"/></Border.Effect>
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#DDE0F0"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="8" BorderThickness="1" ClipToBounds="True">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">

            <!-- Accent bar -->
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4A85F5" Offset="0"/>
                        <GradientStop Color="#7C5CE8" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="42" Background="#111222"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#89b4fa" Margin="0,0,10,0" VerticalAlignment="Center">&#x1F310; TCP Connections</TextBlock>
                        <TextBlock x:Name="TxtTitle" FontSize="11" Foreground="#8890B8" FontFamily="Consolas" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtCount" FontSize="11" Foreground="#3A4860" FontFamily="Consolas" Margin="8,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="&#x27F3;" Height="27" Width="30" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="14" Padding="0" Click="Refresh_Click"/>
                        <Button x:Name="BtnMaxTcp" Content="&#x2610;" Width="30" Height="27" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="12" Padding="0" Click="BtnMax_Click"/>
                        <Button Content="&#x2715;" Width="30" Height="27"
                                Style="{StaticResource SRedBtn}" FontSize="11" Padding="0" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Toolbar + State legend bar -->
            <Border DockPanel.Dock="Top" Background="#0A0B14" BorderBrush="#181A28" BorderThickness="0,0,0,1" Padding="10,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Action buttons -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="🛡 Block IP"   Style="{StaticResource SBtn}" Height="24" FontSize="11" Padding="8,0" Margin="0,0,4,0" Click="BlockIp_Click"   ToolTip="Block remote IP in Windows Firewall (inbound + outbound)"/>
                        <Button Content="🛡 Block Port" Style="{StaticResource SBtn}" Height="24" FontSize="11" Padding="8,0" Margin="0,0,0,0" Click="BlockPort_Click" ToolTip="Block TCP port in Windows Firewall (inbound + outbound)"/>
                    </StackPanel>
                    <!-- State legend -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" Fill="#22C55E" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="ESTABLISHED" Foreground="#405060" FontSize="10" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <Ellipse Width="7" Height="7" Fill="#4A85F5" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="LISTEN" Foreground="#405060" FontSize="10" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <Ellipse Width="7" Height="7" Fill="#F59E0B" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="WAIT" Foreground="#405060" FontSize="10" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <Ellipse Width="7" Height="7" Fill="#EF4444" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="CLOSING" Foreground="#405060" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Height="26" Background="#0C0D18"
                    BorderBrush="#181A28" BorderThickness="0,1,0,0">
                <Grid>
                    <TextBlock x:Name="TxtStatus" Text="Ready" Foreground="#353858"
                               FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Margin="12,0"/>
                    <Thumb Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,4,0" Cursor="SizeNWSE" DragDelta="ResizeGrip_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Path Data="M2,12 L12,2 M5,12 L12,5 M9,12 L12,9"
                                      Stroke="#4A85F5" StrokeThickness="1.2" Opacity="0.5"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>
            </Border>

            <!-- TCP Table -->
            <DataGrid x:Name="GridTcp"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Background="#0C0D18" Foreground="#B8C0D8"
                      BorderThickness="0" RowBackground="Transparent"
                      AlternatingRowBackground="#05101428"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#0C0E1A"
                      HeadersVisibility="Column"
                      FontFamily="Consolas" FontSize="12" SelectionMode="Extended"
                      CanUserAddRows="False" CanUserResizeRows="False"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ColumnHeaderStyle="{StaticResource SColHeader}">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="⛔  Close Connection" Click="CloseConn_Click"/>
                        <MenuItem Header="💀  Kill Process"      Click="KillProc_Click"/>
                        <Separator/>
                        <MenuItem Header="Copy Local Address"   Click="GridTcp_CopyLocal_Click"/>
                        <MenuItem Header="Copy Remote Address"  Click="GridTcp_CopyRemote_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="PID"     Binding="{Binding Pid}"         Width="60"  FontSize="11"/>
                    <DataGridTextColumn Header="PROCESS" Binding="{Binding ProcessName}" Width="140" FontSize="11"/>
                    <DataGridTextColumn Header="LOCAL"   Binding="{Binding LocalAddr}"   Width="*"/>
                    <DataGridTextColumn Header="REMOTE"  Binding="{Binding RemoteAddr}"  Width="*"/>
                    <DataGridTemplateColumn Header="STATE" Width="120" SortMemberPath="State">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="10,0,6,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#3A4060"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding State}" Value="ESTABLISHED"><Setter Property="Fill" Value="#22C55E"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="LISTEN">     <Setter Property="Fill" Value="#4A85F5"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="TIME_WAIT">  <Setter Property="Fill" Value="#F59E0B"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="CLOSE_WAIT"> <Setter Property="Fill" Value="#EF4444"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="SYN_SENT">   <Setter Property="Fill" Value="#F59E0B"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="SYN_RCVD">   <Setter Property="Fill" Value="#F59E0B"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="FIN_WAIT1">  <Setter Property="Fill" Value="#EF4444"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="FIN_WAIT2">  <Setter Property="Fill" Value="#EF4444"/></DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding State}" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

        </DockPanel>
    </Border>
</Window>
