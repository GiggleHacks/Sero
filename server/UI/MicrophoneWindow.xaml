<Window x:Class="SeroServer.UI.MicrophoneWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Microphone"
        Width="480" Height="380" MinWidth="400" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border x:Name="RootBorder" CornerRadius="8" BorderThickness="1" ClipToBounds="True">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#EF4444" Offset="0"/>
                        <GradientStop Color="#F97316" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Border DockPanel.Dock="Top" Height="40" Background="#111222"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                            <TextBlock FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#7AAEFF" Offset="0"/>
                                        <GradientStop Color="#B090FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                                <Run Text="Microphone"/>
                            </TextBlock>
                            <TextBlock x:Name="TxtTitle" Text="" FontSize="10" FontFamily="Segoe UI Mono">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#C0CCD8" Offset="0"/>
                                        <GradientStop Color="#6A8099" Offset="0.5"/>
                                        <GradientStop Color="#B0C0D0" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnMax" Content="☐" Width="30" Height="26" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="13" Padding="0" Click="BtnMax_Click"/>
                        <Button Content="✕" Width="28" Height="26" FontSize="10"
                                Style="{StaticResource SRedBtn}" Click="Close_Click" Padding="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border DockPanel.Dock="Bottom" Height="28" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,0">
                                <Grid>
<TextBlock x:Name="TxtStatus" Text="Ready" Foreground="#606880"
                           FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Margin="14,0"/>
                    <Thumb Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,4,0" Cursor="SizeNWSE" DragDelta="ResizeGrip_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Path Data="M2,12 L12,2 M5,12 L12,5 M9,12 L12,9"
                                      Stroke="#4A85F5" StrokeThickness="1.2" Opacity="0.6"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>
            </Border>

            <!-- Controls -->
            <Border DockPanel.Dock="Bottom" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,0" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Device:" Foreground="#606880" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="CmbDevice" Height="28" MinWidth="180"
                                  Style="{StaticResource SCombo}" FontSize="11"/>
                    </StackPanel>
                    <Button Grid.Column="1" x:Name="BtnRecord" Content="Start" Height="28" Padding="14,0"
                            Margin="0,0,6,0" Style="{StaticResource SGreenBtn}" FontSize="11" Click="Record_Click"/>
                    <Button Grid.Column="2" x:Name="BtnStop" Content="Stop" Height="28" Padding="14,0"
                            Margin="0,0,6,0" Style="{StaticResource SRedBtn}" FontSize="11"
                            Click="Stop_Click" IsEnabled="False"/>
                    <Button Grid.Column="3" Content="Save WAV" Height="28" Padding="12,0"
                            Style="{StaticResource SBtn}" FontSize="11" Click="SaveWav_Click"/>
                </Grid>
            </Border>

            <!-- Waveform canvas -->
            <Border Background="#0A0B14" Margin="0">
                <Grid>
                    <!-- Recording indicator -->
                    <Border x:Name="RecordingIndicator" HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="14,10" CornerRadius="10" Padding="8,3" Visibility="Collapsed">
                        <Border.Background>
                            <SolidColorBrush Color="#3A1018"/>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="RecDot" Width="8" Height="8" VerticalAlignment="Center">
                                <Ellipse.Fill><SolidColorBrush Color="#EF4444"/></Ellipse.Fill>
                            </Ellipse>
                            <TextBlock x:Name="TxtRecTime" Text="0:00" Foreground="#f38ba8"
                                       FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <!-- Waveform -->
                    <Canvas x:Name="WaveCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    <!-- Idle placeholder -->
                    <StackPanel x:Name="PnlIdle" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="🎙" FontSize="40" HorizontalAlignment="Center" Opacity="0.2"/>
                        <TextBlock Text="Select device and press REC"
                                   Foreground="#404060" FontSize="12" HorizontalAlignment="Center"
                                   Margin="0,8,0,0" FontFamily="Segoe UI"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DockPanel>
    </Border>
</Window>
