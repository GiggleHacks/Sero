<Window x:Class="SeroServer.UI.RemoteDesktopWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Remote Desktop"
        Width="940" Height="580" MinWidth="440" MinHeight="320"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="CanResize">

    <Window.Resources>

        <!-- ── Input toggle ─────────────────────────────────────────── -->
        <Style x:Key="PillToggle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Pill" CornerRadius="4" Padding="9,3"
                                Background="#0A0C18" BorderBrush="#1E2038" BorderThickness="1" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="Led" Width="6" Height="6" Fill="#252840"
                                         VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <ContentPresenter VerticalAlignment="Center"
                                                  TextElement.FontSize="10"
                                                  TextElement.FontWeight="SemiBold"
                                                  TextElement.Foreground="#505878"
                                                  TextElement.FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Pill" Property="Background"  Value="#07101E"/>
                                <Setter TargetName="Pill" Property="BorderBrush" Value="#3A70D8"/>
                                <Setter TargetName="Led"  Property="Fill"        Value="#4A85F5"/>
                                <Setter TargetName="Led"  Property="Effect">
                                    <Setter.Value><DropShadowEffect Color="#4A85F5" BlurRadius="4" ShadowDepth="0" Opacity="0.8"/></Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Pill" Property="BorderBrush" Value="#2A3460"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Gradient slider ──────────────────────────────────────── -->
        <Style x:Key="SlimSlider" TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" CornerRadius="1.5">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#4A85F5" Offset="0"/>
                                                            <GradientStop Color="#7C5CE8" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="12" Height="12" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="tb" Width="12" Height="12" Fill="#4A85F5">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect Color="#4A85F5" BlurRadius="5" ShadowDepth="0" Opacity="0.5"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="tb" Property="Fill" Value="#6AABFF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="tb" Property="Fill" Value="#7C5CE8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" Background="#1E2038" CornerRadius="1.5"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="8" BorderThickness="1" ClipToBounds="True">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">

            <!-- ── Accent bar ──────────────────────────────────────── -->
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4A85F5" Offset="0"/>
                        <GradientStop Color="#7C5CE8" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- ── Title bar ───────────────────────────────────────── -->
            <Border DockPanel.Dock="Top" Height="40" Background="#111222"
                    MouseLeftButtonDown="TitleBar_Drag">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#89b4fa" Margin="0,0,10,0" VerticalAlignment="Center">&#x1F5A5; Remote Desktop</TextBlock>
                        <TextBlock x:Name="TxtClientId" Text="" FontSize="11" FontFamily="Consolas" Foreground="#8890B8" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonUp="TxtClientId_MouseLeftButtonUp" ToolTip="Click to copy ID"/>
                        <Border x:Name="LiveBadge" Margin="12,0,0,0" CornerRadius="3"
                                Background="#0C2016" BorderBrush="#1A6040" BorderThickness="1"
                                Padding="6,2" Visibility="Collapsed" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="5" Height="5" Fill="#22C55E" VerticalAlignment="Center" Margin="0,0,5,0">
                                    <Ellipse.Effect><DropShadowEffect Color="#22C55E" BlurRadius="4" ShadowDepth="0" Opacity="0.9"/></Ellipse.Effect>
                                </Ellipse>
                                <TextBlock Text="LIVE" Foreground="#22C55E" FontSize="9" FontWeight="Bold" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Margin="0,0,12,0" Padding="8,3" CornerRadius="3" Background="#0A0C18" BorderBrush="#1E2038" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtPing" Text="— ms" Foreground="#404878"
                                           FontSize="10" FontFamily="Segoe UI Mono" MinWidth="38" TextAlignment="Right" Margin="0,0,8,0"/>
                                <TextBlock x:Name="TxtBandwidth" Text="— Mbps" Foreground="#404878"
                                           FontSize="10" FontFamily="Segoe UI Mono" MinWidth="54" TextAlignment="Right" Margin="0,0,8,0"/>
                                <TextBlock x:Name="TxtFps" Text="— fps" Foreground="#404878"
                                           FontSize="10" FontFamily="Segoe UI Mono" MinWidth="44" TextAlignment="Right" Margin="0,0,8,0"/>
                                <TextBlock x:Name="SignalIcon" Text="📶" Foreground="#404878"
                                           FontSize="12" FontFamily="Segoe UI Emoji" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Button x:Name="BtnFullscreen" Content="⛶" Width="28" Height="26" Margin="0,0,4,0"
                                Background="#0F1020" BorderBrush="#1E2038" BorderThickness="1"
                                Foreground="#505878" FontSize="13" Cursor="Hand"
                                Click="BtnFullscreen_Click"/>
                        <Button Content="✕" Width="28" Height="26"
                                Style="{StaticResource SRedBtn}" Cursor="Hand"
                                Click="Close_Click" FontSize="10" Padding="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Toolbar ─────────────────────────────────────────── -->
            <Border DockPanel.Dock="Top" x:Name="CtrlBorder" Background="#111222" Padding="14,8"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,1">
                <DockPanel LastChildFill="False">

                    <!-- Right: START / STOP -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnWebcam" Content="📷" Width="28" Height="26" Margin="0,0,8,0"
                                Style="{StaticResource SBtn}" Click="BtnWebcam_Click"
                                ToolTip="Open Webcam" FontSize="11" Cursor="Hand" Padding="0"/>
                        <Button x:Name="BtnStart" Content="START" Width="76" Height="26"
                                Style="{StaticResource SGreenBtn}" Click="BtnStart_Click"
                                FontSize="10" FontWeight="Bold" FontFamily="Segoe UI" Padding="14,3"/>
                        <Button x:Name="BtnStop" Content="STOP" Width="70" Height="26" Margin="5,0,0,0"
                                Style="{StaticResource SRedBtn}" Click="BtnStop_Click"
                                IsEnabled="False" Opacity="0.35"
                                FontSize="10" FontWeight="Bold" FontFamily="Segoe UI" Padding="14,3"/>
                    </StackPanel>

                    <!-- Left: monitor + quality + resolution -->
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Monitor selector -->
                        <TextBlock Text="MONITOR" Foreground="#404878" FontSize="9" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="CmbMonitor" Width="180" Height="26"
                                  Style="{StaticResource SCombo}"
                                  SelectionChanged="CmbMonitor_Changed"/>

                        <Rectangle Width="1" Height="16" Margin="16,0">
                            <Rectangle.Fill><SolidColorBrush Color="#1E2038"/></Rectangle.Fill>
                        </Rectangle>

                        <!-- Quality -->
                        <TextBlock Text="QUALITY" Foreground="#404878" FontSize="9" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider x:Name="SldQuality" Minimum="60" Maximum="95" Value="90" Width="80"
                                Style="{StaticResource SlimSlider}"/>
                        <Border Margin="6,0,0,0" Padding="5,1" CornerRadius="3" Background="#0A0C18" BorderBrush="#1E2038" BorderThickness="1">
                            <TextBlock x:Name="TxtQuality" Text="90" Foreground="#8090C0"
                                       FontSize="10" FontFamily="Segoe UI Mono" Width="18" TextAlignment="Center"/>
                        </Border>

                        <Rectangle Width="1" Height="16" Margin="16,0">
                            <Rectangle.Fill><SolidColorBrush Color="#1E2038"/></Rectangle.Fill>
                        </Rectangle>

                        <!-- Resolution scale -->
                        <TextBlock Text="SCALE" Foreground="#404878" FontSize="9" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider x:Name="SldScale" Minimum="25" Maximum="100" Value="100" Width="70"
                                Style="{StaticResource SlimSlider}"/>
                        <Border Margin="6,0,0,0" Padding="5,1" CornerRadius="3" Background="#0A0C18" BorderBrush="#1E2038" BorderThickness="1">
                            <TextBlock x:Name="TxtScale" Text="100%" Foreground="#8090C0"
                                       FontSize="10" FontFamily="Segoe UI Mono" Width="30" TextAlignment="Center"/>
                        </Border>
                    </StackPanel>

                </DockPanel>
            </Border>

            <!-- ── Status bar ──────────────────────────────────────── -->
            <Border DockPanel.Dock="Bottom" Height="28" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,0">
                <Grid Margin="14,0">
                    <!-- Left: status -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="6" Height="6" Fill="#252840"
                                 VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock x:Name="TxtStatus" Text="Connecting..."
                                   Foreground="#404878" FontSize="10" FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- Center: input toggles -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <CheckBox x:Name="ChkClicks"    Content="CLICKS"
                                  Style="{StaticResource PillToggle}" Margin="0,0,5,0"/>
                        <CheckBox x:Name="ChkCursor"    Content="CURSOR"
                                  Style="{StaticResource PillToggle}" Margin="0,0,5,0"/>
                        <CheckBox x:Name="ChkKeyboard"  Content="KEYBOARD"
                                  Style="{StaticResource PillToggle}" Margin="0,0,5,0"/>
                        <CheckBox x:Name="ChkClipboard" Content="CLIPBOARD"
                                  Style="{StaticResource PillToggle}"/>
                    </StackPanel>
                    <!-- Right: resolution + resize grip -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtResolution" Text=""
                                   Foreground="#303458" FontSize="9" FontFamily="Segoe UI Mono"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Thumb Width="14" Height="14" VerticalAlignment="Bottom"
                               Cursor="SizeNWSE" DragDelta="ResizeGrip_DragDelta" Opacity="0.5">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Path Data="M2,12 L12,2 M5,12 L12,5 M9,12 L12,9"
                                          Stroke="#4A85F5" StrokeThickness="1.2" Opacity="0.6"/>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Video area ──────────────────────────────────────── -->
            <Grid>
                <Rectangle Fill="#020306"/>
                <Image x:Name="ImgFrame"
                       Stretch="Fill"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                       RenderOptions.EdgeMode="Aliased"
                       Cursor="Arrow"
                       HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                       MouseMove="Img_MouseMove" MouseDown="Img_MouseDown"
                       MouseUp="Img_MouseUp" MouseWheel="Img_MouseWheel"
                       Focusable="True"
                       KeyDown="Img_KeyDown" KeyUp="Img_KeyUp"
                       Loaded="Img_Loaded"/>
                <StackPanel x:Name="PnlNoSession" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock Text="No active session"
                               Foreground="#252848" FontSize="14" FontWeight="SemiBold"
                               FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                    <TextBlock Text="Select a monitor and click START"
                               Foreground="#1E2038" FontSize="11" FontFamily="Segoe UI"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

        </DockPanel>
    </Border>
</Window>
