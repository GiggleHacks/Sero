<Window x:Class="SeroServer.UI.TikTokWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TikTok Bot"
        Width="960" Height="700" MinWidth="760" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="8" BorderThickness="1" ClipToBounds="True" x:Name="RootBorder">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">

            <!-- Accent bar -->
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#f38ba8" Offset="0"/>
                        <GradientStop Color="#cba6f7" Offset="0.5"/>
                        <GradientStop Color="#89b4fa" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="42" Background="#111222"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="♪" FontSize="15" Foreground="#f38ba8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="TikTok Bot" FontSize="13" FontWeight="SemiBold" Foreground="#C0CCDD"
                                   VerticalAlignment="Center" FontFamily="Segoe UI"/>
                        <Border x:Name="BadgeRunning" Margin="10,0,0,0" CornerRadius="3"
                                Background="#0A1E10" BorderBrush="#1A5E28" BorderThickness="1"
                                Padding="6,2" Visibility="Collapsed" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="5" Height="5" Fill="#22C55E" VerticalAlignment="Center" Margin="0,0,5,0">
                                    <Ellipse.Effect><DropShadowEffect Color="#22C55E" BlurRadius="4" ShadowDepth="0" Opacity="0.9"/></Ellipse.Effect>
                                </Ellipse>
                                <TextBlock x:Name="TxtBadge" Text="POSTING" Foreground="#22C55E" FontSize="9" FontWeight="Bold" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnMax" Content="☐" Width="30" Height="28" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="13" Padding="0" Click="BtnMax_Click"/>
                        <Button Content="✕" Width="30" Height="28"
                                Style="{StaticResource SRedBtn}" FontSize="11" Padding="0" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Height="28" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,0">
                <Grid Margin="14,0">
                    <TextBlock x:Name="TxtStatus" Text="Ready" Foreground="#404868"
                               FontSize="11" FontFamily="Consolas" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtProgress" Text="" Foreground="#a6e3a1"
                               FontSize="11" FontFamily="Consolas" VerticalAlignment="Center"
                               HorizontalAlignment="Right" Margin="0,0,20,0"/>
                    <Thumb Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,4,0" Cursor="SizeNWSE" DragDelta="ResizeGrip_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Path Data="M2,12 L12,2 M5,12 L12,5 M9,12 L12,9"
                                      Stroke="#f38ba8" StrokeThickness="1.2" Opacity="0.6"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>
            </Border>

            <!-- Main -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" MinWidth="140"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── Left: client list ─────────────────────────────────── -->
                <Border Grid.Column="0" Background="#0A0B14" BorderBrush="#1A1C2E" BorderThickness="0,0,1,0">
                    <DockPanel LastChildFill="True">

                        <Border DockPanel.Dock="Top" Background="#111222" BorderBrush="#1A1C2E"
                                BorderThickness="0,0,0,1" Padding="10,6">
                            <TextBlock Text="CLIENTS" FontSize="9" FontWeight="Bold"
                                       Foreground="#C0f38ba8" FontFamily="Consolas" VerticalAlignment="Center"/>
                        </Border>

                        <ListBox x:Name="ClientList" Background="Transparent" BorderThickness="0"
                                 Foreground="#C0CCDD" FontFamily="Segoe UI" FontSize="12">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background"      Value="Transparent"/>
                                    <Setter Property="Padding"         Value="10,5"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#111830"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" Foreground="#C0CCDD"
                                                   FontSize="11" FontFamily="Segoe UI"/>
                                        <TextBlock Text="{Binding Status}" Foreground="#505878"
                                                   FontSize="9" FontFamily="Consolas" Margin="0,1,0,2"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="1" Width="4" Background="#0F1020"
                              HorizontalAlignment="Stretch" Cursor="SizeWE"/>

                <!-- ── Right: main panel ─────────────────────────────────── -->
                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="14,12">

                    <!-- ── CDP Auto-Signup ─────────────────────────────── -->
                    <Border Padding="12,10" CornerRadius="6" Margin="0,0,0,8"
                            Background="#0A0F08" BorderThickness="1" BorderBrush="#1A3020">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🤖  AUTO-SIGNUP (Chrome CDP)" FontSize="9" FontWeight="Bold"
                                               Foreground="#C0a6e3a1" FontFamily="Consolas" VerticalAlignment="Center"/>
                                    <TextBlock Text="  — Google session required on client" Foreground="#303850"
                                               FontSize="9" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button x:Name="BtnCdpSignup" Content="🤖 Signup Selected" Height="26" Padding="12,0"
                                        HorizontalAlignment="Right" Style="{StaticResource SGreenBtn}"
                                        FontSize="10" Click="BtnCdpSignup_Click"
                                        ToolTip="Creates TikTok accounts on all selected clients via Chrome hidden CDP session"/>
                            </Grid>
                            <Border Background="#05080A" CornerRadius="4" Height="72">
                                <TextBox x:Name="TxtCdpLog"
                                         Background="Transparent" Foreground="#a6e3a1"
                                         FontFamily="Consolas" FontSize="10"
                                         BorderThickness="0" Padding="8,5"
                                         IsReadOnly="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" AcceptsReturn="True"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── Account inventory ───────────────────────────── -->
                    <Border Padding="12,10" CornerRadius="6" Margin="0,0,0,8"
                            Background="#111222" BorderThickness="1" BorderBrush="#1E2038">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="📋  ACCOUNTS" FontSize="9" FontWeight="Bold"
                                           Foreground="#C0cba6f7" FontFamily="Consolas" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock x:Name="TxtAccountCount" Text="0 accounts"
                                               Foreground="#505878" FontSize="10" FontFamily="Consolas"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button Content="Clear" Height="22" Padding="8,0"
                                            Style="{StaticResource SBtn}" FontSize="9" Click="BtnClearAccounts_Click"/>
                                </StackPanel>
                            </Grid>
                            <DataGrid x:Name="GridAccounts"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      Background="Transparent" Foreground="#DDE0F0"
                                      BorderThickness="0" RowBackground="Transparent"
                                      AlternatingRowBackground="#06101428"
                                      GridLinesVisibility="None" HeadersVisibility="Column"
                                      FontFamily="Consolas" FontSize="11"
                                      CanUserAddRows="False" CanUserResizeRows="False"
                                      ColumnHeaderHeight="26" MaxHeight="160"
                                      ColumnHeaderStyle="{StaticResource SColHeader}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="CLIENT"  Binding="{Binding Label}"       Width="120"/>
                                    <DataGridTextColumn Header="STATUS"  Binding="{Binding Status}"      Width="150"/>
                                    <DataGridTextColumn Header="COOKIE"  Binding="{Binding CookieShort}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- ── Comment broadcast ──────────────────────────── -->
                    <Border Padding="12,10" CornerRadius="6" Margin="0,0,0,8"
                            Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                        <StackPanel>
                            <TextBlock Text="💬  COMMENT BROADCAST" FontSize="9" FontWeight="Bold"
                                       Foreground="#C089b4fa" FontFamily="Consolas" Margin="0,0,0,10"/>

                            <!-- Target -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="URL / ID" Grid.Column="0" Foreground="#606880" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="TxtVideoId" Grid.Column="1"
                                         Style="{StaticResource STxt}" Height="28" FontSize="11"
                                         ToolTip="TikTok video URL, livestream URL, or numeric ID"/>
                                <RadioButton x:Name="RbVideo" Grid.Column="2" Content="Video"
                                             Foreground="#DDE0F0" FontSize="11" VerticalAlignment="Center"
                                             Margin="10,0,8,0" GroupName="TargetType" IsChecked="True"
                                             Checked="RbTarget_Changed"/>
                                <RadioButton x:Name="RbLive"  Grid.Column="3" Content="Live"
                                             Foreground="#DDE0F0" FontSize="11" VerticalAlignment="Center"
                                             GroupName="TargetType" Checked="RbTarget_Changed"/>
                            </Grid>

                            <!-- Comments -->
                            <Grid Margin="0,0,0,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="80"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,4">
                                    <TextBlock Text="COMMENTS  (one per line — rotated across accounts)"
                                               Foreground="#404878" FontSize="9" FontFamily="Segoe UI"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtQueueCount" Text="0"
                                               Foreground="#505878" FontSize="10" FontFamily="Consolas"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <TextBox x:Name="TxtComments" Grid.Row="1"
                                         Style="{StaticResource STxt}" TextWrapping="Wrap"
                                         AcceptsReturn="True" FontSize="12"
                                         TextChanged="TxtComments_Changed"/>
                            </Grid>

                            <!-- Delay + actions -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="54"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="54"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Delay (s):" Foreground="#606880" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox x:Name="TxtDelayMin" Grid.Column="1" Text="5"
                                         Style="{StaticResource STxt}" Height="28" FontSize="11"/>
                                <TextBlock Grid.Column="2" Text="–" Foreground="#606880" FontSize="11"
                                           VerticalAlignment="Center" Margin="6,0"/>
                                <TextBox x:Name="TxtDelayMax" Grid.Column="3" Text="15"
                                         Style="{StaticResource STxt}" Height="28" FontSize="11"/>
                                <TextBlock x:Name="TxtSentCount" Grid.Column="4" Text=""
                                           Foreground="#a6e3a1" FontSize="10" FontFamily="Consolas"
                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <Button x:Name="BtnStart" Grid.Column="5" Content="▶ Post" Height="30"
                                        Padding="14,0" Margin="0,0,6,0"
                                        Style="{StaticResource SGreenBtn}" FontSize="11" FontWeight="SemiBold"
                                        Click="BtnStart_Click"
                                        ToolTip="Post to all accounts that have a cookie"/>
                                <Button x:Name="BtnStop" Grid.Column="6" Content="■ Stop" Height="30"
                                        Padding="12,0" Margin="0,0,6,0"
                                        Style="{StaticResource SRedBtn}" FontSize="11"
                                        IsEnabled="False" Click="BtnStop_Click"/>
                                <Button Grid.Column="7" Content="Once" Height="30" Padding="12,0"
                                        Style="{StaticResource SBtn}" FontSize="11"
                                        Click="BtnPostOnce_Click"
                                        ToolTip="Post one comment from each account, once"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Log ────────────────────────────────────────── -->
                    <Border Padding="12,10" CornerRadius="6"
                            Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="LOG" FontSize="9" FontWeight="Bold"
                                           Foreground="#C089b4fa" FontFamily="Consolas" VerticalAlignment="Center"/>
                                <Button Content="Clear" Height="20" Padding="8,0" HorizontalAlignment="Right"
                                        Style="{StaticResource SBtn}" FontSize="9" Click="BtnClearLog_Click"/>
                            </Grid>
                            <Border Background="#05060E" CornerRadius="4" Height="100">
                                <TextBox x:Name="TxtLog"
                                         Background="Transparent" Foreground="#C8D0E8"
                                         FontFamily="Consolas" FontSize="11"
                                         BorderThickness="0" Padding="8,6"
                                         IsReadOnly="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" AcceptsReturn="True"/>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
                </ScrollViewer>
            </Grid>

        </DockPanel>
    </Border>
</Window>
