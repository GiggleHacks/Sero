<Window x:Class="SeroServer.UI.ServiceManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SeroServer.UI"
        Title="Service Manager"
        Width="1040" Height="600" MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">
    <Border x:Name="RootBorder" CornerRadius="8" BorderThickness="1">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#2A2E50" Offset="0"/><GradientStop Color="#141628" Offset="1"/></LinearGradientBrush></Border.BorderBrush>
        <Border.Effect><DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/></Border.Effect>
        <DockPanel>
            <!-- Top accent line -->
            <Rectangle DockPanel.Dock="Top" Height="2">
                <Rectangle.Fill><LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#4A85F5" Offset="0"/><GradientStop Color="#7C5CE8" Offset="1"/></LinearGradientBrush></Rectangle.Fill>
            </Rectangle>

            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="42" Background="#111222" MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{x:Static local:ServiceEntryVM.SvcIcon}" Width="16" Height="16"
                               Margin="0,0,7,0" VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#4A85F5" Margin="0,0,10,0" VerticalAlignment="Center">Services</TextBlock>
                        <TextBlock x:Name="TxtTitle" FontSize="11" Foreground="#8890B8" FontFamily="Consolas" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtCount" FontSize="11" Foreground="#3A4860" FontFamily="Consolas" Margin="8,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnMax" Content="&#x2610;" Width="30" Height="27" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="12" Padding="0" Click="BtnMax_Click"/>
                        <Button Content="&#x2715;" Width="30" Height="27"
                                Style="{StaticResource SRedBtn}" FontSize="11" Padding="0" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Toolbar: search + action buttons -->
            <Border DockPanel.Dock="Top" Height="38" Background="#0E0F1E" BorderBrush="#181A2C" BorderThickness="0,0,0,1">
                <Grid Margin="10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Search box -->
                    <Border Grid.Column="0" CornerRadius="4" Background="#12132A" BorderBrush="#252850"
                            BorderThickness="1" VerticalAlignment="Center" Height="26" MaxWidth="320" HorizontalAlignment="Left">
                        <Grid>
                            <TextBlock Text="🔍  Search services…" Foreground="#30385A" FontSize="11" VerticalAlignment="Center" Margin="8,0"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TxtSearch}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox x:Name="TxtSearch" Background="Transparent" BorderThickness="0"
                                     Foreground="#CDD0E8" FontSize="11" FontFamily="Segoe UI"
                                     VerticalAlignment="Center" Padding="8,0" CaretBrush="#4A85F5"/>
                        </Grid>
                    </Border>
                    <!-- Refresh only — actions via right-click -->
                    <Button Grid.Column="1" Content="⟳ Refresh" Height="26" Padding="10,0"
                            Style="{StaticResource SBtn}" FontSize="11" Click="BtnRefresh_Click"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Height="26" Background="#0C0D18" BorderBrush="#181A28" BorderThickness="0,1,0,0">
                <Grid>
                    <TextBlock x:Name="TxtStatus" Text="Ready" Foreground="#353858" FontSize="11"
                               FontFamily="Consolas" VerticalAlignment="Center" Margin="12,0"/>
                    <TextBlock x:Name="TxtCountdown" Text="" Foreground="#252848" FontSize="11"
                               FontFamily="Consolas" VerticalAlignment="Center"
                               HorizontalAlignment="Right" Margin="0,0,24,0"/>
                    <Thumb Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,4,0" Cursor="SizeNWSE" DragDelta="ResizeGrip_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Path Data="M2,12 L12,2 M5,12 L12,5 M9,12 L12,9"
                                      Stroke="#4A85F5" StrokeThickness="1.2" Opacity="0.5"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>
            </Border>

            <!-- Services grid -->
            <DataGrid x:Name="GridServices" AutoGenerateColumns="False" IsReadOnly="True"
                      Background="#0C0D18" Foreground="#CDD0E8" BorderThickness="0"
                      RowBackground="Transparent" AlternatingRowBackground="#05101428"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#0C0E1A"
                      HeadersVisibility="Column" FontFamily="Segoe UI" FontSize="12"
                      SelectionMode="Extended" CanUserAddRows="False"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      EnableColumnVirtualization="True"
                      ScrollViewer.CanContentScroll="True"
                      EnableRowVirtualization="True"
                      ColumnHeaderStyle="{StaticResource SColHeader}">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Height" Value="24"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background"      Value="#1C3A70"/>
                                <Setter Property="Foreground"      Value="#FFFFFF"/>
                                <Setter Property="BorderBrush"     Value="#4A85F5"/>
                                <Setter Property="BorderThickness" Value="2,0,0,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#141A30"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#E8F0FF"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="▶ Start"   Click="BtnStart_Click"/>
                        <MenuItem Header="⏹ Stop"    Click="BtnStop_Click"/>
                        <MenuItem Header="↺ Restart" Click="BtnRestart_Click"/>
                        <Separator/>
                        <MenuItem Header="⊘ Disable" Click="BtnDisable_Click"/>
                        <MenuItem Header="✖ Delete"  Click="BtnDelete_Click"/>
                        <Separator/>
                        <MenuItem Header="Copy Name" Click="GridServices_CopyName_Click"/>
                        <Separator/>
                        <MenuItem Header="⟳ Refresh" Click="BtnRefresh_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <!-- Name with ⚙ glyph colored by status + DisplayName -->
                    <DataGridTemplateColumn Header="NAME" Width="220" SortMemberPath="DisplayName" CanUserSort="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">
                                    <Image Source="{x:Static local:ServiceEntryVM.SvcIcon}" Width="14" Height="14"
                                           Margin="0,0,6,0" VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text="{Binding DisplayName}" Foreground="#CDD0E8" FontSize="12"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Description -->
                    <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}" Width="*"/>

                    <!-- Status: colored dot + text -->
                    <DataGridTemplateColumn Header="STATUS" Width="100" SortMemberPath="Status" CanUserSort="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">
                                    <TextBlock Text="{Binding StatusDot}" Foreground="{Binding StatusColor}"
                                               FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding Status}" Foreground="{Binding StatusColor}"
                                               FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Startup Type: colored text -->
                    <DataGridTemplateColumn Header="STARTUP TYPE" Width="110" SortMemberPath="StartType" CanUserSort="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StartType}" Foreground="{Binding StartTypeColor}"
                                           FontSize="11" VerticalAlignment="Center" Margin="6,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Log On As -->
                    <DataGridTextColumn Header="LOG ON AS" Binding="{Binding LogOnAs}" Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</Window>
