<Window x:Class="SeroServer.UI.FunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fun"
        Width="580" Height="640" MinWidth="500" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="FBtn" TargetType="Button">
            <Setter Property="Background"       Value="#141628"/>
            <Setter Property="Foreground"       Value="#C0CCDD"/>
            <Setter Property="BorderBrush"      Value="#2A3058"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="Height"           Value="30"/>
            <Setter Property="Margin"           Value="0,0,5,4"/>
            <Setter Property="Padding"          Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PART_Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_Bg" Property="Background"   Value="#1E2248"/>
                                <Setter TargetName="PART_Bg" Property="BorderBrush"  Value="#4A85F5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PART_Bg" Property="Background"   Value="#0E1228"/>
                            </Trigger>
                            <!-- Inactive: partner was clicked — heavily dimmed -->
                            <Trigger Property="Tag" Value="off">
                                <Setter TargetName="PART_Bg" Property="Background"  Value="#0C0D18"/>
                                <Setter TargetName="PART_Bg" Property="BorderBrush" Value="#1A1C28"/>
                                <Setter Property="Foreground"                        Value="#353858"/>
                                <Setter Property="Opacity"                           Value="0.6"/>
                            </Trigger>
                            <!-- Active state: thick left accent + blue fill — clearly visible on all variants -->
                            <Trigger Property="Tag" Value="on">
                                <Setter TargetName="PART_Bg" Property="BorderBrush"     Value="#4A85F5"/>
                                <Setter TargetName="PART_Bg" Property="BorderThickness" Value="3,1,1,1"/>
                                <Setter TargetName="PART_Bg" Property="Background"      Value="#0A1530"/>
                                <Setter Property="Foreground"                            Value="#FFFFFF"/>
                                <Setter Property="Opacity"                               Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FBtnGreen"  TargetType="Button" BasedOn="{StaticResource FBtn}">
            <Setter Property="BorderBrush" Value="#2A4A28"/>
        </Style>
        <Style x:Key="FBtnRed"   TargetType="Button" BasedOn="{StaticResource FBtn}">
            <Setter Property="BorderBrush" Value="#4A2028"/>
        </Style>
        <Style x:Key="FBtnOrange" TargetType="Button" BasedOn="{StaticResource FBtn}">
            <Setter Property="BorderBrush" Value="#4A3A18"/>
        </Style>
        <Style x:Key="FBtnPurple" TargetType="Button" BasedOn="{StaticResource FBtn}">
            <Setter Property="Foreground" Value="#cba6f7"/>
            <Setter Property="BorderBrush" Value="#3A2858"/>
        </Style>
        <Style x:Key="FSection" TargetType="Border">
            <Setter Property="Background"      Value="#111222"/>
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="Margin"          Value="0,0,0,8"/>
            <Setter Property="BorderBrush"     Value="#1E2038"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#606880"/>
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Margin"       Value="0,0,0,6"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" BorderThickness="1" ClipToBounds="True">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">
            <!-- Gradient accent bar -->
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF6B6B" Offset="0"/>
                        <GradientStop Color="#FFE66D" Offset="0.33"/>
                        <GradientStop Color="#4ECDC4" Offset="0.66"/>
                        <GradientStop Color="#7C5CE8" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="40" Background="#111222"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#f9e2af" Margin="0,0,10,0">🎭 Fun</TextBlock>
                        <TextBlock x:Name="TxtTitle" Text="" FontSize="11" Foreground="#8890B8" FontFamily="Consolas"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnMaxFun" Content="&#x2610;" Width="28" Height="26" FontSize="12"
                            Click="BtnMax_Click" Style="{StaticResource SBtn}" Padding="0" Margin="0,0,2,0"/>
                    <Button Content="&#x2715;" Width="28" Height="26" FontSize="11"
                            Click="Close_Click" Style="{StaticResource SRedBtn}" Padding="0"/>
                    </StackPanel>
                    <!-- legacy placeholder for old close button that now lives in the StackPanel above -->
                    <Button Visibility="Collapsed" Content="✕" Width="0" Height="0" FontSize="10" Click="Close_Click" HorizontalAlignment="Right">
                        <Button.Style><Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="#f38ba8"/>
                            <Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="4,2">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate></Setter.Value></Setter>
                        </Style></Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Height="28" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,0">
                                <Grid>
<TextBlock x:Name="TxtStatus" Text="Ready" Foreground="#606880"
                           FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Margin="14,0"/>
                    <Thumb Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,4,0" Cursor="SizeNWSE" DragDelta="ResizeGrip_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Path Data="M2,12 L12,2 M5,12 L12,5 M9,12 L12,9"
                                      Stroke="#4A85F5" StrokeThickness="1.2" Opacity="0.6"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>
            </Border>

            <!-- Main content: two-column grid -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="12,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">

                        <!-- CD-ROM -->
                        <Border Style="{StaticResource FSection}">
                            <StackPanel>
                                <TextBlock Text="💿  CD-ROM" Style="{StaticResource SectionLabel}"/>
                                <WrapPanel>
                                    <Button Content="⏏ Eject"  Style="{StaticResource FBtn}" Click="CdOpen_Click"/>
                                    <Button Content="↩ Close"  Style="{StaticResource FBtn}" Click="CdClose_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Taskbar -->
                        <Border Style="{StaticResource FSection}">
                            <StackPanel>
                                <TextBlock Text="🗂  Taskbar" Style="{StaticResource SectionLabel}"/>
                                <WrapPanel>
                                    <Button x:Name="BtnTaskbarShow" Content="👁 Show"  Style="{StaticResource FBtnGreen}" Click="TaskbarShow_Click"/>
                                    <Button x:Name="BtnTaskbarHide" Content="🙈 Hide"  Style="{StaticResource FBtnRed}"   Click="TaskbarHide_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Explorer -->
                        <Border Style="{StaticResource FSection}">
                            <StackPanel>
                                <TextBlock Text="🪟  Explorer" Style="{StaticResource SectionLabel}"/>
                                <WrapPanel>
                                    <Button Content="☠ Kill"   Style="{StaticResource FBtnRed}"   Click="ExplorerKill_Click"/>
                                    <Button Content="▶ Start"  Style="{StaticResource FBtnGreen}" Click="ExplorerStart_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Screen -->
                        <Border Style="{StaticResource FSection}">
                            <StackPanel>
                                <TextBlock Text="🖥  Screen" Style="{StaticResource SectionLabel}"/>
                                <WrapPanel>
                                    <Button x:Name="BtnScreenOn"  Content="💡 On"  Style="{StaticResource FBtnGreen}" Click="ScreenOn_Click"/>
                                    <Button x:Name="BtnScreenOff" Content="🌑 Off" Style="{StaticResource FBtnRed}"   Click="ScreenOff_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Clock -->
                        <Border Style="{StaticResource FSection}">
                            <StackPanel>
                                <TextBlock Text="🕐  Clock / Tray" Style="{StaticResource SectionLabel}"/>
                                <WrapPanel>
                                    <Button x:Name="BtnClockShow" Content="👁 Clock Show"  Style="{StaticResource FBtnGreen}" Click="ClockShow_Click"/>
                                    <Button x:Name="BtnClockHide" Content="🙈 Clock Hide"  Style="{StaticResource FBtnRed}"   Click="ClockHide_Click"/>
                                    <Button x:Name="BtnTrayShow"  Content="👁 Tray Show"   Style="{StaticResource FBtnGreen}" Click="TrayShow_Click"/>
                                    <Button x:Name="BtnTrayHide"  Content="🙈 Tray Hide"   Style="{StaticResource FBtnRed}"   Click="TrayHide_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Desktop Icons -->
                        <Border Style="{StaticResource FSection}">
                            <StackPanel>
                                <TextBlock Text="🖼  Desktop Icons" Style="{StaticResource SectionLabel}"/>
                                <WrapPanel>
                                    <Button x:Name="BtnDesktopIconsShow" Content="👁 Show"  Style="{StaticResource FBtnGreen}" Click="DesktopIconsShow_Click"/>
                                    <Button x:Name="BtnDesktopIconsHide" Content="🙈 Hide"  Style="{StaticResource FBtnRed}"   Click="DesktopIconsHide_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Volume -->
                        <Border Style="{StaticResource FSection}">
                            <StackPanel>
                                <TextBlock Text="🔊  Volume" Style="{StaticResource SectionLabel}"/>
                                <WrapPanel>
                                    <Button Content="+ Vol"    Style="{StaticResource FBtnGreen}"  Click="VolUp_Click"/>
                                    <Button Content="- Vol"    Style="{StaticResource FBtnOrange}" Click="VolDown_Click"/>
                                    <Button Content="🔇 Mute"  Style="{StaticResource FBtnRed}"    Click="VolMute_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <StackPanel Grid.Column="2">

                        <!-- Mouse -->
                        <Border Style="{StaticResource FSection}">
                            <StackPanel>
                                <TextBlock Text="🖱  Mouse" Style="{StaticResource SectionLabel}"/>
                                <WrapPanel>
                                    <Button x:Name="BtnMouseNormal" Content="↔ Normal" Style="{StaticResource FBtnGreen}" Click="MouseNormal_Click"/>
                                    <Button x:Name="BtnMouseSwap"   Content="↕ Swap"   Style="{StaticResource FBtnRed}"   Click="MouseSwap_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Screen Rotation -->
                        <Border Style="{StaticResource FSection}">
                            <StackPanel>
                                <TextBlock Text="🔄  Screen Rotation" Style="{StaticResource SectionLabel}"/>
                                <WrapPanel>
                                    <Button x:Name="BtnFlip0"   Content="0°"   Width="44" Style="{StaticResource FBtn}"       Click="Flip0_Click"/>
                                    <Button x:Name="BtnFlip90"  Content="90°"  Width="44" Style="{StaticResource FBtnOrange}" Click="Flip90_Click"/>
                                    <Button x:Name="BtnFlip180" Content="180°" Width="48" Style="{StaticResource FBtnOrange}" Click="Flip180_Click"/>
                                    <Button x:Name="BtnFlip270" Content="270°" Width="48" Style="{StaticResource FBtnOrange}" Click="Flip270_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Crazy Mouse -->
                        <Border Style="{StaticResource FSection}">
                            <StackPanel>
                                <TextBlock Text="🤪  Crazy Mouse" Style="{StaticResource SectionLabel}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="TxtCrazyMouseSec" Text="10" Width="40" Height="28"
                                             Background="#0A0B14" Foreground="#DDE0F0"
                                             BorderBrush="#2A3058" BorderThickness="1"
                                             Padding="4,3" FontFamily="Consolas" FontSize="11"
                                             Margin="0,0,4,0"
                                             VerticalContentAlignment="Center"/>
                                    <TextBlock Text="sec" Foreground="#606880" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <Button Content="🤪 Activate" Style="{StaticResource FBtnOrange}" Click="CrazyMouse_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Text Speak -->
                        <Border Style="{StaticResource FSection}">
                            <StackPanel>
                                <TextBlock Text="🗣  Text to Speech" Style="{StaticResource SectionLabel}"/>
                                <TextBox x:Name="TxtSpeak" Text="Hello World"
                                         Background="#0A0B14" Foreground="#DDE0F0"
                                         BorderBrush="#2A3058" BorderThickness="1"
                                         Padding="6,4" FontFamily="Consolas" FontSize="11"
                                         Margin="0,0,0,6" Height="28" VerticalContentAlignment="Center"/>
                                <Button Content="🗣 Speak" HorizontalAlignment="Left" Style="{StaticResource FBtnPurple}" Click="Speak_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Message Box -->
                        <Border Style="{StaticResource FSection}">
                            <StackPanel>
                                <TextBlock Text="💬  Message Box" Style="{StaticResource SectionLabel}"/>
                                <TextBox x:Name="TxtMsgBox" Text="Surprise!"
                                         Background="#0A0B14" Foreground="#DDE0F0"
                                         BorderBrush="#2A3058" BorderThickness="1"
                                         Padding="6,4" FontFamily="Consolas" FontSize="11"
                                         Margin="0,0,0,6" Height="28" VerticalContentAlignment="Center"/>
                                <Button Content="💬 Show" HorizontalAlignment="Left" Style="{StaticResource FBtnOrange}" Click="MsgBox_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Open URL -->
                        <Border Style="{StaticResource FSection}">
                            <StackPanel>
                                <TextBlock Text="🌐  Open URL (on victim)" Style="{StaticResource SectionLabel}"/>
                                <TextBox x:Name="TxtUrl" Text="https://www.youtube.com/watch?v=dQw4w9WgXcQ"
                                         Background="#0A0B14" Foreground="#DDE0F0"
                                         BorderBrush="#2A3058" BorderThickness="1"
                                         Padding="6,4" FontFamily="Consolas" FontSize="10"
                                         Margin="0,0,0,6" Height="26" VerticalContentAlignment="Center"/>
                                <Button Content="🌐 Open" HorizontalAlignment="Left" Style="{StaticResource FBtnPurple}" Click="OpenUrl_Click"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>
            </ScrollViewer>

        </DockPanel>
    </Border>
</Window>
