<Window x:Class="SeroServer.UI.PerformanceMonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Performance Monitor"
        Width="680" Height="460" MinWidth="520" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" WindowStyle="None" Background="#0C0D18">

    <Border x:Name="RootBorder" CornerRadius="8" BorderThickness="1" ClipToBounds="True">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        

        <DockPanel>
            <!-- Accent -->
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4A85F5" Offset="0"/>
                        <GradientStop Color="#7C5CE8" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="42" Background="#111222"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#4A85F5" Margin="0,0,12,0">Performance Monitor</TextBlock>
                        <TextBlock x:Name="TxtTitle" FontSize="11" Foreground="#8890B8" FontFamily="Consolas"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="&#x2715;" Width="30" Height="27"
                                Style="{StaticResource SRedBtn}" FontSize="11" Padding="0" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Height="26" Background="#0C0D18"
                    BorderBrush="#181A28" BorderThickness="0,1,0,0">
                <Grid>
                    <TextBlock x:Name="TxtStatus" Text="Connecting…" Foreground="#353858"
                               FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Margin="12,0"/>
                    <Thumb Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,4,0" Cursor="SizeNWSE" DragDelta="ResizeGrip_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Path Data="M2,12 L12,2 M5,12 L12,5 M9,12 L12,9"
                                      Stroke="#4A85F5" StrokeThickness="1.2" Opacity="0.5"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>
            </Border>

            <!-- Performance panels -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16,14,16,14" >

                    <!-- CPU -->
                    <Border Background="#0A0B14" CornerRadius="6" Padding="14,12" Margin="0,0,0,10"
                            BorderBrush="#1A1C2E" BorderThickness="1">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="CPU" FontSize="11" FontWeight="SemiBold" Foreground="#606880"/>
                                <TextBlock x:Name="TxtCpu" FontSize="20" FontWeight="Bold" Foreground="#4A85F5"
                                           HorizontalAlignment="Right" FontFamily="Consolas"/>
                            </Grid>
                            <Border Height="18" Background="#0C0E1A" CornerRadius="3">
                                <Border x:Name="BarCpu" HorizontalAlignment="Left" Width="0" Height="18"
                                        CornerRadius="3">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#1A4A9A" Offset="0"/>
                                            <GradientStop Color="#4A85F5" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                            <!-- Sparkline canvas -->
                            <Canvas x:Name="SparkCpu" Height="40" Margin="0,8,0,0" ClipToBounds="True">
                                <Canvas.Background><SolidColorBrush Color="#070810"/></Canvas.Background>
                            </Canvas>
                        </StackPanel>
                    </Border>

                    <!-- RAM -->
                    <Border Background="#0A0B14" CornerRadius="6" Padding="14,12" Margin="0,0,0,10"
                            BorderBrush="#1A1C2E" BorderThickness="1">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="RAM" FontSize="11" FontWeight="SemiBold" Foreground="#606880"/>
                                <TextBlock x:Name="TxtRam" FontSize="20" FontWeight="Bold" Foreground="#7C5CE8"
                                           HorizontalAlignment="Right" FontFamily="Consolas"/>
                            </Grid>
                            <Border Height="18" Background="#0C0E1A" CornerRadius="3">
                                <Border x:Name="BarRam" HorizontalAlignment="Left" Width="0" Height="18"
                                        CornerRadius="3">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#3A1A7A" Offset="0"/>
                                            <GradientStop Color="#7C5CE8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                            <Canvas x:Name="SparkRam" Height="40" Margin="0,8,0,0" ClipToBounds="True">
                                <Canvas.Background><SolidColorBrush Color="#070810"/></Canvas.Background>
                            </Canvas>
                        </StackPanel>
                    </Border>

                    <!-- Network -->
                    <Border Background="#0A0B14" CornerRadius="6" Padding="14,12" Margin="0,0,0,0"
                            BorderBrush="#1A1C2E" BorderThickness="1">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="NETWORK" FontSize="11" FontWeight="SemiBold" Foreground="#606880"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="↑ " Foreground="#22C55E" FontSize="12" FontWeight="SemiBold" FontFamily="Consolas"/>
                                    <TextBlock x:Name="TxtNetSent" FontSize="12" FontWeight="Bold" Foreground="#22C55E" FontFamily="Consolas" Margin="0,0,14,0"/>
                                    <TextBlock Text="↓ " Foreground="#4A85F5" FontSize="12" FontWeight="SemiBold" FontFamily="Consolas"/>
                                    <TextBlock x:Name="TxtNetRecv" FontSize="12" FontWeight="Bold" Foreground="#4A85F5" FontFamily="Consolas"/>
                                </StackPanel>
                            </Grid>
                            <Canvas x:Name="SparkNet" Height="50" ClipToBounds="True">
                                <Canvas.Background><SolidColorBrush Color="#070810"/></Canvas.Background>
                            </Canvas>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
