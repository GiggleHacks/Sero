<Window x:Class="SeroServer.UI.Socks5Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SOCKS5 Proxy"
        Width="560" Height="400" MinWidth="420" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="8" BorderThickness="1" ClipToBounds="True" x:Name="RootBorder">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">

            <!-- Accent bar -->
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4A85F5" Offset="0"/>
                        <GradientStop Color="#22C55E" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="40" Background="#111222"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                            <TextBlock FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#7AAEFF" Offset="0"/>
                                        <GradientStop Color="#B090FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                                <Run Text="SOCKS5 Proxy"/>
                            </TextBlock>
                            <TextBlock x:Name="TxtTitle" Text="" FontSize="10" FontFamily="Segoe UI Mono">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#C0CCD8" Offset="0"/>
                                        <GradientStop Color="#6A8099" Offset="0.5"/>
                                        <GradientStop Color="#B0C0D0" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </StackPanel>
                        <Border x:Name="BadgeActive" Margin="10,0,0,0" CornerRadius="3"
                                Background="#0A1E10" BorderBrush="#1A5E28" BorderThickness="1"
                                Padding="6,2" Visibility="Collapsed" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="5" Height="5" Fill="#22C55E" VerticalAlignment="Center" Margin="0,0,5,0">
                                    <Ellipse.Effect><DropShadowEffect Color="#22C55E" BlurRadius="4" ShadowDepth="0" Opacity="0.9"/></Ellipse.Effect>
                                </Ellipse>
                                <TextBlock Text="ACTIVE" Foreground="#22C55E" FontSize="9" FontWeight="Bold" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnMaximize" Content="☐" Width="30" Height="28" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="13" Padding="0" Click="BtnMaximize_Click"/>
                        <Button Content="✕" Width="30" Height="28"
                                Style="{StaticResource SRedBtn}" FontSize="11" Padding="0" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Height="28" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,0">
                                <Grid>
<TextBlock x:Name="TxtStatus" Text="Configure port and click Start"
                           Foreground="#404868" FontSize="11" FontFamily="Consolas"
                           VerticalAlignment="Center" Margin="14,0"/>
                    <Thumb Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,4,0" Cursor="SizeNWSE" DragDelta="ResizeGrip_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Path Data="M2,12 L12,2 M5,12 L12,5 M9,12 L12,9"
                                      Stroke="#4A85F5" StrokeThickness="1.2" Opacity="0.6"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Margin="20,16">

                <!-- Port config -->
                <Border Padding="14,12" CornerRadius="6"
                        Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="LOCAL SOCKS5 PORT" FontSize="9" FontWeight="Bold"
                                       Foreground="#C04A85F5" FontFamily="Consolas" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="127.0.0.1 :" Foreground="#606880" FontSize="12"
                                           FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox x:Name="TxtPort" Text="1080" Width="80" Height="30"
                                         Style="{StaticResource STxt}" FontSize="13"/>
                            </StackPanel>
                            <TextBlock Text="Configure your browser/tool to use 127.0.0.1:PORT as SOCKS5 proxy"
                                       Foreground="#404868" FontSize="10" FontFamily="Segoe UI" Margin="0,6,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="BtnStart" Content="Start" Height="32" Padding="16,0"
                                Margin="0,0,6,0" Style="{StaticResource SGreenBtn}" FontSize="12" Click="BtnStart_Click"/>
                        <Button Grid.Column="2" x:Name="BtnStop"  Content="Stop"  Height="32" Padding="16,0"
                                Style="{StaticResource SRedBtn}"   FontSize="12" Click="BtnStop_Click" IsEnabled="False"/>
                    </Grid>
                </Border>

                <!-- Traffic log -->
                <Border Padding="14,10" CornerRadius="6"
                        Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="CONNECTIONS" FontSize="9" FontWeight="Bold"
                                       Foreground="#C04A85F5" FontFamily="Consolas" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtConnCount" Text="0 active"
                                       Foreground="#505878" FontSize="11" FontFamily="Consolas"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Background="#05060E" CornerRadius="4" Height="180">
                            <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                                <TextBox x:Name="TxtLog"
                                         Background="Transparent" Foreground="#C8D0E8"
                                         FontFamily="Consolas" FontSize="11"
                                         BorderThickness="0" Padding="8,6"
                                         IsReadOnly="True" TextWrapping="Wrap"
                                         AcceptsReturn="True"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </DockPanel>
    </Border>
</Window>
