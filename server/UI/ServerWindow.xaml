<Window x:Class="SeroServer.UI.ServerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SɆⱤØ RAT"
        Icon="/sero.ico"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="None"
        UseLayoutRounding="True"
        RenderOptions.ClearTypeHint="Enabled"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Flat progress bar used in dashboard OS breakdown -->
        <Style x:Key="FlatBar" TargetType="ProgressBar">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border x:Name="PART_Track" Background="{TemplateBinding Background}" CornerRadius="2" ClipToBounds="True">
                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="2" HorizontalAlignment="Left"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderThickness" Value="4,1,1,1" />
            <Setter Property="BorderBrush"     Value="Transparent" />
            <Setter Property="Foreground"      Value="#DDE0F0" />
            <Style.Triggers>
                <!-- Tagged rows: amber tint + amber left accent — evaluated first so selection overrides it -->
                <DataTrigger Binding="{Binding HasTag}" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#130E01" Offset="0"/>
                                <GradientStop Color="#090700" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="BorderBrush"     Value="#C8991A"/>
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0F1525" />
                </Trigger>
                <!-- Selection triggers are LAST so they always win over the tag amber border -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#1E4598" Offset="0"/>
                                <GradientStop Color="#0E2050" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Foreground"      Value="#FFFFFF" />
                    <Setter Property="BorderBrush"     Value="#6AABFF" />
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected"   Value="True" />
                        <Condition Property="IsMouseOver"  Value="True" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#2654B8" Offset="0"/>
                                <GradientStop Color="#112666" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="BorderBrush"     Value="#88C0FF" />
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="10,6" BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="#C8CEFA" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background"      Value="#0F1020" />
            <Setter Property="BorderBrush"     Value="#1E2038" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground"      Value="#DDE0F0" />
            <Setter Property="Padding"         Value="4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="#0F1020" BorderBrush="#1E2038" BorderThickness="1"
                                CornerRadius="10" Padding="4">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="28" ShadowDepth="8" Opacity="0.75" Color="#000000"/>
                            </Border.Effect>
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#DDE0F0"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <!-- Item row -->
                            <Border x:Name="bd" Background="Transparent" CornerRadius="5" Margin="1,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Fill="#0C0D1E"/>
                                    <Rectangle Grid.Column="0" HorizontalAlignment="Right" Width="1" Fill="#191B30" VerticalAlignment="Stretch"/>
                                    <ContentPresenter Grid.Column="0" ContentSource="Icon"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Margin="0,6,0,6"/>
                                    <ContentPresenter Grid.Column="1" ContentSource="Header"
                                                      Margin="4,7,4,7" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="Arrow" Grid.Column="2" Text="›" FontSize="13"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"
                                               Foreground="#505878" Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                            <!-- Sub-menu popup (only rendered when item has children) -->
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Right" HorizontalOffset="-2" VerticalOffset="-5"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border Background="#111225" BorderBrush="#22253E" BorderThickness="1"
                                        CornerRadius="8" Padding="4" MinWidth="168">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="22" ShadowDepth="6" Opacity="0.75" Color="#000"/>
                                    </Border.Effect>
                                    <ItemsPresenter KeyboardNavigation.TabNavigation="Cycle"
                                                    KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1E2248"/>
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="Arrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.38"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ── Window chrome ──────────────────────────────────────────── -->
    <Border x:Name="RootBorder" Background="#0C0D18" CornerRadius="8" BorderThickness="1"
            BorderBrush="#1C1E30">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="3"  />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*"  />
                <RowDefinition Height="100" />
            </Grid.RowDefinitions>

            <!-- ── Background ─────────────────────────────────────────── -->
            <Grid Grid.RowSpan="5" IsHitTestVisible="False" ClipToBounds="True">

                <Rectangle Fill="#0C0D18"/>

                <!-- Logo watermark centré -->
                <Image x:Name="BgLogoImage"
                       Source="/serofondtransparent.png"
                       Width="460" Height="460"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Margin="0,55,0,0"
                       Opacity="0.52"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="LowQuality"
                       RenderOptions.CachingHint="Cache">
                    <Image.Effect>
                        <BlurEffect x:Name="BgLogoBlur" Radius="2"/>
                    </Image.Effect>
                </Image>

            </Grid>

            <!-- ── Screenshot popup overlay (click-to-enlarge) ──── -->
            <Grid x:Name="ScreenPopupOverlay" Grid.RowSpan="5" Panel.ZIndex="200"
                  Background="#D0060810" Visibility="Collapsed"
                  MouseLeftButtonDown="ScreenPopupOverlay_Close">
                <Border Background="#0C0E1E" CornerRadius="10" BorderThickness="1" BorderBrush="#2A3060"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Padding="16" MinWidth="300" MaxWidth="1100"
                        MouseLeftButtonDown="ScreenPopupOverlay_StopBubble">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock x:Name="ScreenPopupTitle" Foreground="#CCD8FF" FontSize="12"
                                       FontFamily="Consolas" VerticalAlignment="Center"/>
                            <Button HorizontalAlignment="Right" Content="✕" Width="22" Height="22"
                                    Foreground="#606880" Background="Transparent" BorderThickness="0"
                                    FontSize="12" Cursor="Hand"
                                    Click="ScreenPopupOverlay_CloseBtn"/>
                        </Grid>
                        <Image x:Name="ScreenPopupImage" Stretch="Uniform"
                               MaxHeight="680" MaxWidth="1068"/>
                        <TextBlock x:Name="ScreenPopupSub" Foreground="#404878" FontSize="10"
                                   FontFamily="Consolas" Margin="0,8,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Title bar ──────────────────────────────────────── -->
            <Border Grid.Row="0" Background="#C0111222" CornerRadius="10,10,0,0"
                    BorderThickness="0,0,0,1">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#281E2038" Offset="0"/>
                        <GradientStop Color="#1E2038"   Offset="0.5"/>
                        <GradientStop Color="#281E2038" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/icone.png" Width="26" Height="26" Margin="0,0,9,0"
                               RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Clip>
                                <RectangleGeometry RadiusX="5" RadiusY="5" Rect="0,0,26,26" />
                            </Image.Clip>
                        </Image>
                        <TextBlock VerticalAlignment="Center" FontSize="14" FontWeight="Bold">
                            <Run Text="SɆⱤØ">
                                <Run.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#4A85F5" Offset="0"/>
                                        <GradientStop Color="#7C5CE8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Run.Foreground>
                            </Run>
                            <Run Text="RAT">
                                <Run.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#D8DCF0" Offset="0"/>
                                        <GradientStop Color="#8890B8" Offset="0.5"/>
                                        <GradientStop Color="#C4C8E0" Offset="1"/>
                                    </LinearGradientBrush>
                                </Run.Foreground>
                            </Run>
                            <Run x:Name="TxtVersionNumber" Text=" v1.4.2" Foreground="#C8922A" FontSize="10" FontWeight="Normal"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,-2,0">
                        <Button Content="─" Width="32" Height="26" Style="{StaticResource SBtn}"
                                Click="Minimize_Click" Padding="0" FontSize="11" />
                        <Button x:Name="BtnFullscreen" Content="☐" Width="32" Height="26" Style="{StaticResource SBtn}"
                                Click="Fullscreen_Click" Padding="0" Margin="2,0,0,0" FontSize="11" />
                        <Button Content="✕" Width="32" Height="26" Style="{StaticResource SRedBtn}"
                                Click="Close_Click" Padding="0" Margin="2,0,0,0" FontSize="11" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Accent line: full-width repeating aurora ─────────── -->
            <Rectangle x:Name="AuroraBar" Grid.Row="1" Height="3">
                <Rectangle.Fill>
                    <LinearGradientBrush MappingMode="Absolute"
                                         StartPoint="0,0" EndPoint="600,0"
                                         SpreadMethod="Repeat">
                        <LinearGradientBrush.Transform>
                            <TranslateTransform X="0"/>
                        </LinearGradientBrush.Transform>
                        <GradientStop Color="#4A85F5" Offset="0.00"/>
                        <GradientStop Color="#0DCCFF" Offset="0.20"/>
                        <GradientStop Color="#7C5CE8" Offset="0.42"/>
                        <GradientStop Color="#D040FF" Offset="0.58"/>
                        <GradientStop Color="#7C5CE8" Offset="0.76"/>
                        <GradientStop Color="#0DCCFF" Offset="0.90"/>
                        <GradientStop Color="#4A85F5" Offset="1.00"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
                <Rectangle.Triggers>
                    <EventTrigger RoutedEvent="Rectangle.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetName="AuroraBar"
                                    Storyboard.TargetProperty="(Rectangle.Fill).(LinearGradientBrush.Transform).(TranslateTransform.X)"
                                    From="0" To="-600" Duration="0:0:5"
                                    RepeatBehavior="Forever"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Rectangle.Triggers>
            </Rectangle>

            <!-- ── Control bar ────────────────────────────────────── -->
            <Border Grid.Row="2" Background="#C0111222" Padding="16,8"
                    BorderThickness="0,0,0,1" BorderBrush="#181A2C">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="PORT" Foreground="#606880" VerticalAlignment="Center"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,0,8,0" />
                        <TextBox x:Name="TxtPort" Style="{StaticResource STxt}" Width="64" Text="7777" />
                        <Button x:Name="BtnStartStop" Content="START"
                                Style="{StaticResource SGreenBtn}" Click="StartStop_Click"
                                Width="80" Height="30" Margin="8,0,0,0" />
                    </StackPanel>

                    <!-- Status pill with pulsing dot -->
                    <Border Grid.Column="1" Background="#0D0E1A" CornerRadius="6" Padding="16,6"
                            BorderThickness="1" BorderBrush="#1C1E30"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0">
                                <Ellipse x:Name="ServerDot" Width="7" Height="7" Fill="#EF4444"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock x:Name="TxtServerStatus" Text="Stopped"
                                       Foreground="#606880" FontSize="12" />
                            <TextBlock x:Name="TxtClientCount" Text="  ·  0 clients"
                                       Foreground="#606880" FontSize="12" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Button Content="Backup" Style="{StaticResource SBtn}" Height="32" Padding="14,0"
                                Click="ExportBackup_Click" ToolTip="Export cert + auth key (.sero)" />
                        <Button Content="Import" Style="{StaticResource SBtn}" Height="32" Padding="14,0" Margin="6,0,0,0"
                                Click="ImportBackup_Click" ToolTip="Import .sero backup or .pfx cert" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Tab control ────────────────────────────────────── -->
            <TabControl x:Name="MainTabControl" Grid.Row="3" Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource TextBrush}"
                        SelectionChanged="MainTabControl_SelectionChanged">
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <ScrollViewer Grid.Row="0"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          Background="#C0111222"
                                          Focusable="False">
                                <StackPanel Orientation="Horizontal"
                                            IsItemsHost="True"
                                            HorizontalAlignment="Center"/>
                            </ScrollViewer>
                            <Rectangle Grid.Row="1" Height="1">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="#301E2038"   Offset="0.2"/>
                                        <GradientStop Color="#1E2038"     Offset="0.5"/>
                                        <GradientStop Color="#301E2038"   Offset="0.8"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              Grid.Row="2"
                                              ContentSource="SelectedContent"
                                              ContentTemplate="{TemplateBinding SelectedContentTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </ControlTemplate>
                </TabControl.Template>
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Foreground" Value="#606880" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Padding"    Value="14,10" />
                        <Setter Property="FontSize"   Value="12" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Grid x:Name="root" Cursor="Hand">
                                        <Border x:Name="bd" Background="Transparent"
                                                Padding="{TemplateBinding Padding}" />
                                        <ContentPresenter ContentSource="Header"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Margin="{TemplateBinding Padding}" />
                                        <Rectangle x:Name="line" Height="3" VerticalAlignment="Bottom"
                                                   Visibility="Collapsed"
                                                   Fill="{StaticResource AccentBarBrush}" />
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Foreground" Value="#EEF0FF" />
                                            <Setter TargetName="bd"   Property="Background"  Value="#181B30" />
                                            <Setter TargetName="line" Property="Visibility"  Value="Visible" />
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True" />
                                                <Condition Property="IsSelected"  Value="False" />
                                            </MultiTrigger.Conditions>
                                            <Setter Property="Foreground" Value="#A0AACE" />
                                            <Setter TargetName="bd" Property="Background" Value="#10121E" />
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- ── Dashboard ── -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="▦" Foreground="#4A85F5" FontSize="10" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Margin="8" Padding="24,20" CornerRadius="8"
                            Background="#D0111222" BorderThickness="1">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#283040FF" Offset="0"/>
                                <GradientStop Color="#121E2038" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>

                                <!-- Header -->
                                <Grid Margin="0,0,0,16">
                                    <TextBlock Text="OVERVIEW" Style="{StaticResource SLabel}" VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="Updated " Foreground="#2C3450" FontSize="9" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="DashLastUpdated" Text="—" Foreground="#404868" FontSize="9" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Row 1: 4 stat cards -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                                    </Grid.ColumnDefinitions>

                                    <!-- ONLINE -->
                                    <Border Grid.Column="0" CornerRadius="8" Margin="0,0,9,0" ClipToBounds="True" Background="#0A0D1A">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="4"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Rectangle Grid.Column="0" Fill="#22C55E"/>
                                            <StackPanel Grid.Column="1" Margin="14,15,12,15">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                                    <TextBlock Text="&#xE839;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Foreground="#22C55E" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="ONLINE" Foreground="#506070" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock x:Name="DashOnline" Text="0" Foreground="#22C55E" FontSize="34" FontWeight="Bold" Margin="0,5,0,0"/>
                                                <TextBlock Text="connected now" Foreground="#25304A" FontSize="9" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- TOTAL SEEN -->
                                    <Border Grid.Column="1" CornerRadius="8" Margin="0,0,9,0" ClipToBounds="True" Background="#0A0D1A">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="4"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Rectangle Grid.Column="0" Fill="#4A85F5"/>
                                            <StackPanel Grid.Column="1" Margin="14,15,12,15">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                                    <TextBlock Text="&#xE716;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Foreground="#4A85F5" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="TOTAL SEEN" Foreground="#506070" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock x:Name="DashTotal" Text="0" Foreground="#4A85F5" FontSize="34" FontWeight="Bold" Margin="0,5,0,0"/>
                                                <TextBlock Text="unique clients" Foreground="#25304A" FontSize="9" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- NEW 24H -->
                                    <Border Grid.Column="2" CornerRadius="8" Margin="0,0,9,0" ClipToBounds="True" Background="#0A0D1A">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="4"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Rectangle Grid.Column="0" Fill="#F59E0B"/>
                                            <StackPanel Grid.Column="1" Margin="14,15,12,15">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                                    <TextBlock Text="&#xE945;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Foreground="#F59E0B" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="NEW 24H" Foreground="#506070" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock x:Name="DashNew24h" Text="0" Foreground="#F59E0B" FontSize="34" FontWeight="Bold" Margin="0,5,0,0"/>
                                                <TextBlock Text="connections today" Foreground="#25304A" FontSize="9" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- UPTIME -->
                                    <Border Grid.Column="3" CornerRadius="8" ClipToBounds="True" Background="#0A0D1A">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="4"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Rectangle Grid.Column="0" Fill="#7C5CE8"/>
                                            <StackPanel Grid.Column="1" Margin="14,15,12,15">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                                    <TextBlock Text="&#xE121;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Foreground="#7C5CE8" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="UPTIME" Foreground="#506070" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
