<Window x:Class="SeroServer.UI.StartupManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Startup Manager"
        Width="820" Height="500" MinWidth="600" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="8" BorderThickness="1" ClipToBounds="True">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4A85F5" Offset="0"/>
                        <GradientStop Color="#7C5CE8" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Border DockPanel.Dock="Top" Height="40" Background="#111222"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🚀" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Startup Manager" FontSize="12" FontWeight="SemiBold" Foreground="#C0CCDD" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="TxtTitle" FontSize="11" Foreground="#5A6880" VerticalAlignment="Center" FontFamily="Segoe UI Mono"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="⟳ Refresh" Width="70" Height="24" FontSize="10" Click="Refresh_Click">
                            <Button.Style><Style TargetType="Button">
                                <Setter Property="Background" Value="#1A2038"/><Setter Property="Foreground" Value="#89b4fa"/>
                                <Setter Property="BorderBrush" Value="#2A3058"/><Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor" Value="Hand"/><Setter Property="Template">
                                    <Setter.Value><ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="6,3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate></Setter.Value>
                                </Setter>
                            </Style></Button.Style>
                        </Button>
                        <Button Content="✕" Width="28" Height="26" FontSize="10" Click="Close_Click">
                            <Button.Style><Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="#f38ba8"/>
                                <Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="4,2">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate></Setter.Value></Setter>
                            </Style></Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border DockPanel.Dock="Bottom" Height="28" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,0">
                <TextBlock x:Name="TxtStatus" Text="Ready" Foreground="#606880"
                           FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Margin="14,0"/>
            </Border>

            <DataGrid x:Name="GridStartup"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Background="#0C0D18" Foreground="#DDE0F0"
                      BorderThickness="0" RowBackground="Transparent"
                      AlternatingRowBackground="#07101428"
                      GridLinesVisibility="None" HeadersVisibility="Column"
                      FontFamily="Segoe UI" FontSize="13" SelectionMode="Single"
                      CanUserAddRows="False" CanUserResizeRows="False"
                      ColumnHeaderHeight="32">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#111222"/>
                        <Setter Property="Foreground" Value="#606880"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="BorderBrush" Value="#1A1C2E"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.ContextMenu>
                    <ContextMenu Background="#0F1020" BorderBrush="#1E2038" BorderThickness="1">
                        <MenuItem Header="⟳ Refresh"  Click="Refresh_Click"  Foreground="#89b4fa"/>
                        <MenuItem Header="🗑 Delete"   Click="Delete_Click"   Foreground="#f38ba8"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="NAME"     Binding="{Binding Name}"     Width="200"/>
                    <DataGridTextColumn Header="TYPE"     Binding="{Binding Type}"     Width="80"/>
                    <DataGridTextColumn Header="LOCATION" Binding="{Binding Location}" Width="140"/>
                    <DataGridTextColumn Header="PATH"     Binding="{Binding Path}"     Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</Window>
