<Window x:Class="SeroServer.UI.StartupManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Startup Manager"
        Width="860" Height="500" MinWidth="640" MinHeight="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <Style TargetType="DataGridRow">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#CDD0E8"/>
            <Style.Triggers>
                <!-- Unverified rows: red tint (like Autoruns) — must come before IsSelected so selection overrides it -->
                <DataTrigger Binding="{Binding Verified}" Value="False">
                    <Setter Property="Background" Value="#1A0808"/>
                    <Setter Property="Foreground" Value="#E88080"/>
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A1020"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background"      Value="#152040"/>
                    <Setter Property="Foreground"      Value="#FFFFFF"/>
                    <Setter Property="BorderBrush"     Value="#4A85F5"/>
                    <Setter Property="BorderThickness" Value="2,0,0,0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="10,5" BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#4A85F5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ContextMenu">
            <Setter Property="Background"  Value="#0F1020"/>
            <Setter Property="BorderBrush" Value="#1E2038"/>
            <Setter Property="Foreground"  Value="#DDE0F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="#0F1020" BorderBrush="#1E2038" BorderThickness="1" CornerRadius="8" Padding="4">
                            <Border.Effect><DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.7" Color="#000"/></Border.Effect>
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#DDE0F0"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="8" BorderThickness="1" ClipToBounds="True">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">

            <!-- Accent bar -->
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4A85F5" Offset="0"/>
                        <GradientStop Color="#7C5CE8" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="42" Background="#111222"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#a6e3a1" Margin="0,0,10,0" VerticalAlignment="Center">&#x1F680; Startup Manager</TextBlock>
                        <TextBlock x:Name="TxtTitle" FontSize="11" Foreground="#8890B8" FontFamily="Consolas" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtCount" FontSize="11" Foreground="#3A4860" FontFamily="Consolas" Margin="8,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="&#x27F3;" Height="27" Width="30" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="14" Padding="0" Click="Refresh_Click"/>
                        <Button x:Name="BtnMaxStartup" Content="&#x2610;" Width="30" Height="27" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="12" Padding="0" Click="BtnMax_Click"/>
                        <Button Content="&#x2715;" Width="30" Height="27"
                                Style="{StaticResource SRedBtn}" FontSize="11" Padding="0" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>


            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Height="26" Background="#0C0D18"
                    BorderBrush="#181A28" BorderThickness="0,1,0,0">
                <Grid>
                    <TextBlock x:Name="TxtStatus" Text="Ready" Foreground="#353858"
                               FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Margin="12,0"/>
                    <Thumb Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,4,0" Cursor="SizeNWSE" DragDelta="ResizeGrip_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Path Data="M2,12 L12,2 M5,12 L12,5 M9,12 L12,9"
                                      Stroke="#4A85F5" StrokeThickness="1.2" Opacity="0.5"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>
            </Border>

            <!-- Startup list -->
            <DataGrid x:Name="GridStartup"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Background="#0C0D18" Foreground="#CDD0E8"
                      BorderThickness="0" RowBackground="Transparent"
                      AlternatingRowBackground="#05101428"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#0C0E1A"
                      HeadersVisibility="Column"
                      FontFamily="Segoe UI" FontSize="12" SelectionMode="Extended"
                      CanUserAddRows="False" CanUserResizeRows="False"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ColumnHeaderStyle="{StaticResource SColHeader}">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Delete Entry" Click="Delete_Click"/>
                        <Separator/>
                        <MenuItem Header="Copy Name"    Click="GridStartup_CopyName_Click"/>
                        <MenuItem Header="Copy Path"    Click="GridStartup_CopyPath_Click"/>
                        <Separator/>
                        <MenuItem Header="Refresh"      Click="Refresh_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="NAME"      Binding="{Binding Name}"             Width="200" FontSize="12"/>
                    <DataGridTextColumn Header="TYPE"      Binding="{Binding Type}"             Width="70"  FontSize="11"/>
                    <DataGridTextColumn Header="LOCATION"  Binding="{Binding Location}"         Width="115" FontSize="11"/>
                    <DataGridTemplateColumn Header="PUBLISHER" Width="210" SortMemberPath="PublisherDisplay">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding PublisherDisplay}" FontSize="11" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="PATH"      Binding="{Binding Path}"             Width="*"   FontSize="11"/>
                </DataGrid.Columns>
            </DataGrid>

        </DockPanel>
    </Border>
</Window>
