<Window x:Class="SeroServer.UI.ProcessManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Process Manager"
        Width="880" Height="580" MinWidth="640" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="8" BorderThickness="1" ClipToBounds="True" x:Name="RootBorder">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">

            <!-- Accent bar -->
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4A85F5" Offset="0"/>
                        <GradientStop Color="#7C5CE8" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="40" Background="#111222"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                            <TextBlock FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#7AAEFF" Offset="0"/>
                                        <GradientStop Color="#B090FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                                <Run Text="Process Manager"/>
                            </TextBlock>
                            <TextBlock x:Name="TxtTitle" Text="" FontSize="10" FontFamily="Segoe UI Mono">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#C0CCD8" Offset="0"/>
                                        <GradientStop Color="#6A8099" Offset="0.5"/>
                                        <GradientStop Color="#B0C0D0" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock x:Name="TxtCount" FontSize="11" Foreground="#505878"
                                   VerticalAlignment="Center" FontFamily="Consolas" Margin="10,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="⟳ Refresh" Height="28" Padding="12,0" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="11" Click="BtnRefresh_Click"/>
                        <Button x:Name="BtnMaximize" Content="☐" Width="30" Height="28" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="13" Padding="0" Click="BtnMaximize_Click"/>
                        <Button Content="✕" Width="30" Height="28"
                                Style="{StaticResource SRedBtn}" FontSize="11" Padding="0" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Search bar -->
            <Border DockPanel.Dock="Top" Background="#0A0B14" BorderBrush="#1A1C2E" BorderThickness="0,0,0,1" Padding="14,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtSearch" Grid.Column="0" Height="28"
                             Style="{StaticResource STxt}" FontSize="12"
                             TextChanged="TxtSearch_TextChanged"/>
                    <Button Grid.Column="1" Content="Kill" Height="28" Padding="16,0" Margin="8,0,0,0"
                            Style="{StaticResource SRedBtn}" FontSize="11" Click="BtnKill_Click"/>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Height="28" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,0">
                                <Grid>
<TextBlock x:Name="TxtStatus" Text="Ready"
                           Foreground="#404868" FontSize="11" FontFamily="Consolas"
                           VerticalAlignment="Center" Margin="14,0"/>
                    <Thumb Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,4,0" Cursor="SizeNWSE" DragDelta="ResizeGrip_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Path Data="M2,12 L12,2 M5,12 L12,5 M9,12 L12,9"
                                      Stroke="#4A85F5" StrokeThickness="1.2" Opacity="0.6"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>
            </Border>

            <!-- Process list -->
            <DataGrid x:Name="GridProcs"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Background="#0C0D18" Foreground="#DDE0F0"
                      BorderThickness="0" RowBackground="Transparent"
                      AlternatingRowBackground="#06101428"
                      GridLinesVisibility="None" HeadersVisibility="Column"
                      FontFamily="Segoe UI" FontSize="13" SelectionMode="Single"
                      CanUserAddRows="False" CanUserResizeRows="False"
                      ColumnHeaderHeight="32"
                      ColumnHeaderStyle="{StaticResource SColHeader}">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="☠  Kill Process"    Click="BtnKill_Click"/>
                        <MenuItem Header="⟳  Refresh"         Click="BtnRefresh_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="NAME" Width="*" SortMemberPath="Name">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Image Source="{Binding IconImage}" Width="16" Height="16"
                                           VerticalAlignment="Center" Margin="4,0,8,0"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                                           SnapsToDevicePixels="True"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="PID"    Binding="{Binding Pid}"        Width="70"/>
                    <DataGridTextColumn Header="MEMORY" Binding="{Binding MemDisplay}" Width="90"/>
                    <DataGridTextColumn Header="TITLE"  Binding="{Binding Title}"      Width="220"/>
                </DataGrid.Columns>
            </DataGrid>

        </DockPanel>
    </Border>
</Window>
