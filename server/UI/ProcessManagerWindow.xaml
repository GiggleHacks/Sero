<Window x:Class="SeroServer.UI.ProcessManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Process Manager"
        Width="980" Height="600" MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#CDD0E8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0F1525"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#152040"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="BorderBrush" Value="#4A85F5"/>
                    <Setter Property="BorderThickness" Value="2,0,0,0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="10,5" BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#4A85F5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#0F1020"/>
            <Setter Property="BorderBrush" Value="#1E2038"/>
            <Setter Property="Foreground" Value="#DDE0F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="#0F1020" BorderBrush="#1E2038" BorderThickness="1" CornerRadius="8" Padding="4">
                            <Border.Effect><DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.7" Color="#000"/></Border.Effect>
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#DDE0F0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" BorderThickness="1" ClipToBounds="True" x:Name="RootBorder">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">

            <!-- Accent bar -->
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4A85F5" Offset="0"/>
                        <GradientStop Color="#7C5CE8" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="42" Background="#111222"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#4A85F5" Margin="0,0,12,0">
                            Process Manager
                        </TextBlock>
                        <TextBlock x:Name="TxtTitle" FontSize="11" Foreground="#8890B8" FontFamily="Consolas"/>
                        <TextBlock x:Name="TxtCount" FontSize="11" Foreground="#3A4860" FontFamily="Consolas" Margin="8,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,2,0">
                        <Button Content="&#x27F3;" Height="27" Width="30" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="14" Padding="0" Click="BtnRefresh_Click"/>
                        <Button x:Name="BtnMaximize" Content="&#x2610;" Width="30" Height="27" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="12" Padding="0" Click="BtnMaximize_Click"/>
                        <Button Content="&#x2715;" Width="30" Height="27"
                                Style="{StaticResource SRedBtn}" FontSize="11" Padding="0" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Search toolbar -->
            <Border DockPanel.Dock="Top" Background="#0A0B14" BorderBrush="#181A28" BorderThickness="0,0,0,1" Padding="12,6">
                <TextBox x:Name="TxtSearch" Height="28"
                         Style="{StaticResource STxt}" FontSize="12" TextChanged="TxtSearch_TextChanged"/>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Height="26" Background="#0C0D18"
                    BorderBrush="#181A28" BorderThickness="0,1,0,0">
                <Grid>
                    <TextBlock x:Name="TxtStatus" Text="Ready"
                               Foreground="#353858" FontSize="11" FontFamily="Consolas"
                               VerticalAlignment="Center" Margin="12,0"/>
                    <Thumb Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,4,0" Cursor="SizeNWSE" DragDelta="ResizeGrip_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Path Data="M2,12 L12,2 M5,12 L12,5 M9,12 L12,9"
                                      Stroke="#4A85F5" StrokeThickness="1.2" Opacity="0.5"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>
            </Border>

            <!-- Process list -->
            <DataGrid x:Name="GridProcs"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Background="#0C0D18" Foreground="#CDD0E8"
                      BorderThickness="0" RowBackground="Transparent"
                      AlternatingRowBackground="#05101428"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#0C0E1A"
                      HeadersVisibility="Column"
                      FontFamily="Segoe UI" FontSize="12" SelectionMode="Single"
                      CanUserAddRows="False" CanUserResizeRows="False"
                      ColumnHeaderHeight="30"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ColumnHeaderStyle="{StaticResource SColHeader}">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Kill Process"    Click="BtnKill_Click"/>
                        <MenuItem Header="Suspend"         Click="BtnSuspend_Click"/>
                        <MenuItem Header="Resume"          Click="BtnResume_Click"/>
                        <Separator/>
                        <MenuItem Header="Refresh"         Click="BtnRefresh_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <!-- Name + icon -->
                    <DataGridTemplateColumn Header="NAME" Width="*" SortMemberPath="Name" MinWidth="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Image Source="{Binding IconImage}" Width="15" Height="15"
                                           VerticalAlignment="Center" Margin="2,0,7,0"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                                           SnapsToDevicePixels="True"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!-- PID -->
                    <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="65" FontFamily="Consolas" FontSize="11"/>
                    <!-- CPU heat-map column -->
                    <DataGridTemplateColumn Header="CPU" Width="90" SortMemberPath="CpuUsage">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding CpuHeatBrush}" Margin="-10,-5">
                                    <TextBlock Text="{Binding CpuDisplay}"
                                               Foreground="{Binding CpuTextBrush}"
                                               FontFamily="Consolas" FontSize="11"
                                               VerticalAlignment="Center" Margin="10,5"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!-- RAM heat-map column -->
                    <DataGridTemplateColumn Header="MEMORY" Width="110" SortMemberPath="Memory">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding MemHeatBrush}" Margin="-10,-5">
                                    <TextBlock Text="{Binding MemDisplay}"
                                               Foreground="{Binding MemTextBrush}"
                                               FontFamily="Consolas" FontSize="11"
                                               VerticalAlignment="Center" Margin="10,5"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!-- Network connections -->
                    <DataGridTextColumn Header="NET" Binding="{Binding NetDisplay}" Width="70"
                                        FontFamily="Consolas" FontSize="11"/>
                    <!-- Title -->
                    <DataGridTextColumn Header="TITLE" Binding="{Binding Title}" Width="200" FontSize="11"/>
                </DataGrid.Columns>
            </DataGrid>

        </DockPanel>
    </Border>
</Window>
