<Window x:Class="SeroServer.UI.WebcamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Remote Webcam"
        Width="700" Height="520" MinWidth="420" MinHeight="320"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="CanResize">

    <Window.Resources>

        <!-- Gradient slider — same as HVNC / RDP -->
        <Style x:Key="SlimSlider" TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" CornerRadius="1.5">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#4A85F5" Offset="0"/>
                                                            <GradientStop Color="#7C5CE8" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="12" Height="12" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="tb" Width="12" Height="12" Fill="#4A85F5">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect Color="#4A85F5" BlurRadius="5" ShadowDepth="0" Opacity="0.5"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="tb" Property="Fill" Value="#6AABFF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="tb" Property="Fill" Value="#7C5CE8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" Background="#1E2038" CornerRadius="1.5"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Window shell — matches HVNC / RDP style -->
    <Border x:Name="RootBorder" CornerRadius="8" BorderThickness="1" ClipToBounds="True">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">

            <!-- ── Accent bar ────────────────────────────────────────── -->
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4A85F5" Offset="0"/>
                        <GradientStop Color="#7C5CE8" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- ── Title bar ─────────────────────────────────────────── -->
            <Border DockPanel.Dock="Top" Height="40" Background="#111222"
                    MouseLeftButtonDown="TitleBar_Drag">
                <Grid Margin="14,0">
                    <!-- Left: title + client ID + LIVE badge -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#89dceb" Margin="0,0,10,0" VerticalAlignment="Center">📷 Remote Webcam</TextBlock>
                        <TextBlock x:Name="TxtClientId" Text="" FontSize="11" FontFamily="Consolas" Foreground="#8890B8" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonUp="TxtClientId_MouseLeftButtonUp" ToolTip="Click to copy ID"/>
                        <Border x:Name="LiveBadge" Margin="12,0,0,0" CornerRadius="3"
                                Background="#0C2016" BorderBrush="#1A6040" BorderThickness="1"
                                Padding="6,2" Visibility="Collapsed" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="5" Height="5" Fill="#22C55E"
                                         VerticalAlignment="Center" Margin="0,0,5,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#22C55E" BlurRadius="4" ShadowDepth="0" Opacity="0.9"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock Text="LIVE" Foreground="#22C55E"
                                           FontSize="9" FontWeight="Bold" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <!-- Right: RDP button + FPS pill + fullscreen + close -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnRemoteDesktop" ToolTip="Open Remote Desktop" Width="28" Height="26" Margin="0,0,8,0"
                                Background="#0F1020" BorderBrush="#1E2038" BorderThickness="1"
                                Foreground="#606880" FontSize="13" Cursor="Hand" Padding="0"
                                Click="BtnRemoteDesktop_Click" Content="🖥"/>
                        <Border Margin="0,0,12,0" Padding="8,3" CornerRadius="3"
                                Background="#0A0C18" BorderBrush="#1E2038" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtPing" Text="— ms" Foreground="#404878"
                                           FontSize="10" FontFamily="Segoe UI Mono"
                                           MinWidth="38" TextAlignment="Right" Margin="0,0,8,0"/>
                                <TextBlock x:Name="TxtBandwidth" Text="— Mbps" Foreground="#404878"
                                           FontSize="10" FontFamily="Segoe UI Mono"
                                           MinWidth="54" TextAlignment="Right" Margin="0,0,8,0"/>
                                <TextBlock x:Name="TxtFps" Text="— fps" Foreground="#404878"
                                           FontSize="10" FontFamily="Segoe UI Mono"
                                           MinWidth="44" TextAlignment="Right" Margin="0,0,8,0"/>
                                <TextBlock x:Name="SignalIcon" Text="📶" Foreground="#404878"
                                           FontSize="12" FontFamily="Segoe UI Emoji" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Button x:Name="BtnFullscreen" Content="⛶" Width="28" Height="26" Margin="0,0,4,0"
                                Background="#0F1020" BorderBrush="#1E2038" BorderThickness="1"
                                Foreground="#606880" FontSize="13" Cursor="Hand" Padding="0"
                                Click="BtnFullscreen_Click"/>
                        <Button Content="✕" Width="28" Height="26"
                                Style="{StaticResource SRedBtn}" Cursor="Hand"
                                Click="Close_Click" FontSize="10" Padding="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Toolbar ────────────────────────────────────────────── -->
            <Border DockPanel.Dock="Top" Background="#111222" Padding="12,8"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,1">
                <DockPanel LastChildFill="False">

                    <!-- Right: AUTO START toggle + START / STOP -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="ChkAutoStart" Content="AUTO START"
                                  ToolTip="Automatically start streaming when the window opens"
                                  IsChecked="False" VerticalAlignment="Center" Margin="0,0,10,0"
                                  Foreground="#606888" FontSize="10" FontFamily="Segoe UI" FontWeight="SemiBold"
                                  Checked="ChkAutoStart_Changed" Unchecked="ChkAutoStart_Changed"/>
                        <Button x:Name="BtnStart" Content="START" Width="76" Height="26"
                                Style="{StaticResource SGreenBtn}" Click="BtnStart_Click"
                                FontSize="10" FontWeight="Bold" FontFamily="Segoe UI" Padding="14,3"/>
                        <Button x:Name="BtnStop" Content="STOP" Width="70" Height="26" Margin="5,0,0,0"
                                Style="{StaticResource SRedBtn}" Click="BtnStop_Click"
                                IsEnabled="False" Opacity="0.35"
                                FontSize="10" FontWeight="Bold" FontFamily="Segoe UI" Padding="14,3"/>
                    </StackPanel>

                    <!-- Right-2: Quality + FPS sliders -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,14,0">
                        <Rectangle Width="1" Height="16" Margin="0,0,14,0">
                            <Rectangle.Fill><SolidColorBrush Color="#1E2038"/></Rectangle.Fill>
                        </Rectangle>
                        <TextBlock Text="QUALITY" Foreground="#404878" FontSize="9" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider x:Name="SldQuality" Minimum="20" Maximum="95" Value="20" Width="72"
                                Style="{StaticResource SlimSlider}"/>
                        <Border Margin="6,0,0,0" Padding="5,1" CornerRadius="3"
                                Background="#0A0C18" BorderBrush="#1E2038" BorderThickness="1">
                            <TextBlock x:Name="TxtQuality" Text="20" Foreground="#8090C0"
                                       FontSize="10" FontFamily="Segoe UI Mono"
                                       Width="18" TextAlignment="Center"/>
                        </Border>
                        <Rectangle Width="1" Height="16" Margin="12,0">
                            <Rectangle.Fill><SolidColorBrush Color="#1E2038"/></Rectangle.Fill>
                        </Rectangle>
                        <TextBlock Text="FPS" Foreground="#404878" FontSize="9" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider x:Name="SldFps" Minimum="5" Maximum="30" Value="20" Width="58"
                                Style="{StaticResource SlimSlider}"/>
                        <Border Margin="6,0,0,0" Padding="5,1" CornerRadius="3"
                                Background="#0A0C18" BorderBrush="#1E2038" BorderThickness="1">
                            <TextBlock x:Name="TxtFpsVal" Text="20" Foreground="#8090C0"
                                       FontSize="10" FontFamily="Segoe UI Mono"
                                       Width="18" TextAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Left: device selector + resolution -->
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="DEVICE" Foreground="#404878" FontSize="9" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="CmbDevice" Width="160" Height="26"
                                  Style="{StaticResource SCombo}"/>
                        <Rectangle Width="1" Height="16" Margin="12,0">
                            <Rectangle.Fill><SolidColorBrush Color="#1E2038"/></Rectangle.Fill>
                        </Rectangle>
                        <TextBlock Text="RES" Foreground="#404878" FontSize="9" FontWeight="SemiBold"
                                   FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="CmbResolution" Width="72" Height="26"
                                  Style="{StaticResource SCombo}" SelectedIndex="0">
                            <ComboBoxItem Content="Native"/>
                            <ComboBoxItem Content="720p"/>
                            <ComboBoxItem Content="480p"/>
                            <ComboBoxItem Content="360p"/>
                            <ComboBoxItem Content="240p"/>
                        </ComboBox>
                    </StackPanel>

                </DockPanel>
            </Border>

            <!-- ── Status bar ─────────────────────────────────────────── -->
            <Border DockPanel.Dock="Bottom" Height="28" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,0">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="6" Height="6" Fill="#252840"
                                 VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock x:Name="TxtStatus" Text="Waiting for device list..."
                                   Foreground="#404878" FontSize="10" FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <CheckBox x:Name="ChkAutoSave" Content="AUTO-SAVE"
                                  Foreground="#4F8EF7" FontSize="9" FontWeight="SemiBold"
                                  IsEnabled="False" Opacity="0.4" Margin="0,0,8,0" Cursor="Hand"
                                  Checked="ChkAutoSave_Changed" Unchecked="ChkAutoSave_Changed"/>
                        <Thumb Width="14" Height="14" VerticalAlignment="Bottom"
                               Cursor="SizeNWSE" DragDelta="ResizeGrip_DragDelta" Opacity="0.5">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Path Data="M2,12 L12,2 M5,12 L12,5 M9,12 L12,9"
                                          Stroke="#4A85F5" StrokeThickness="1.2" Opacity="0.6"/>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Video canvas ───────────────────────────────────────── -->
            <Grid>
                <Rectangle Fill="#020306"/>
                <Image x:Name="ImgFrame"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                <!-- Placeholder shown before streaming starts -->
                <TextBlock x:Name="TxtPlaceholder"
                           Text="Waiting for device list..."
                           Foreground="#252848" FontSize="13" FontWeight="SemiBold"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsHitTestVisible="False"/>

                <!-- Debug log overlay (hidden by default) -->
                <Border x:Name="LogPanel" VerticalAlignment="Bottom" MaxHeight="160"
                        Background="#CC020306" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TextBlock x:Name="TxtLog" FontFamily="Consolas" FontSize="10"
                                   Foreground="#88AABBCC" Padding="10,6" TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>
            </Grid>

        </DockPanel>
    </Border>
</Window>
