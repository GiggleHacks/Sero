<Window x:Class="SeroServer.UI.FileManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Manager"
        Width="1000" Height="600" MinWidth="720" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="FmBtn" TargetType="Button">
            <Setter Property="Background" Value="#1A2038"/>
            <Setter Property="Foreground" Value="#C0CCDD"/>
            <Setter Property="BorderBrush" Value="#2A3058"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#222A48"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0E1428"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="8" BorderThickness="1" ClipToBounds="True">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">
            <!-- Accent bar -->
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4A85F5" Offset="0"/>
                        <GradientStop Color="#7C5CE8" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="40" Background="#111222"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                            <TextBlock FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#7AAEFF" Offset="0"/>
                                        <GradientStop Color="#B090FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                                <Run Text="File Manager"/>
                            </TextBlock>
                            <TextBlock x:Name="TxtTitle" Text="" FontSize="10" FontFamily="Segoe UI Mono">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#C0CCD8" Offset="0"/>
                                        <GradientStop Color="#6A8099" Offset="0.5"/>
                                        <GradientStop Color="#B0C0D0" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnMax" Content="☐" Width="30" Height="26" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="13" Padding="0" Click="BtnMax_Click"/>
                        <Button Content="✕" Width="28" Height="26" FontSize="10"
                                Style="{StaticResource SRedBtn}" Click="Close_Click" Padding="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Navigation bar -->
            <Border DockPanel.Dock="Top" Height="38" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,0,0,1">
                <Grid Margin="8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="◀ Back" Height="26" Margin="0,0,4,0"
                            Style="{StaticResource FmBtn}" Click="Back_Click"/>
                    <Button Grid.Column="1" Content="⟳ Refresh" Height="26" Padding="8,0" Margin="0,0,4,0"
                            Style="{StaticResource FmBtn}" FontSize="11" Click="Refresh_Click"/>
                    <!-- GoTo dropdown -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,8,0">
                        <Button Height="26" Margin="0,0,2,0" Style="{StaticResource FmBtn}" Click="GoToDesktop_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🖥" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="Desktop" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Height="26" Margin="0,0,2,0" Style="{StaticResource FmBtn}" Click="GoToUser_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👤" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="User" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Height="26" Margin="0,0,2,0" Style="{StaticResource FmBtn}" Click="GoToTemp_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="Temp" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Height="26" Margin="0,0,2,0" Style="{StaticResource FmBtn}" Click="GoToAppData_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="AppData" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Height="26" Style="{StaticResource FmBtn}" Click="GoToStartup_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🚀" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="Startup" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <TextBox x:Name="TxtPath" Grid.Column="3" Height="26"
                             Background="#0A0B14" Foreground="#C0CCDD" BorderBrush="#2A3058"
                             BorderThickness="1" Padding="6,3" FontFamily="Consolas" FontSize="11"
                             VerticalContentAlignment="Center" KeyDown="TxtPath_KeyDown"/>
                    <Button Grid.Column="4" Content="Go" Height="26" Width="36" Margin="4,0,0,0"
                            Style="{StaticResource FmBtn}" Click="GoPath_Click"/>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Height="28" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,0">
                                <Grid>
<TextBlock x:Name="TxtStatus" Text="Ready" Foreground="#606880"
                           FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Margin="14,0"/>
                    <Thumb Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,4,0" Cursor="SizeNWSE" DragDelta="ResizeGrip_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Path Data="M2,12 L12,2 M5,12 L12,5 M9,12 L12,9"
                                      Stroke="#4A85F5" StrokeThickness="1.2" Opacity="0.6"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>
            </Border>

            <!-- File list + Preview pane -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="320"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="260" MinWidth="160"/>
                </Grid.ColumnDefinitions>

            <DataGrid x:Name="GridFiles" Grid.Column="0"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Background="#0C0D18" Foreground="#DDE0F0"
                      BorderThickness="0" RowBackground="Transparent"
                      AlternatingRowBackground="#07101428"
                      GridLinesVisibility="None" HeadersVisibility="Column"
                      FontFamily="Consolas" FontSize="13"
                      SelectionMode="Extended" SelectionUnit="FullRow"
                      CanUserAddRows="False" CanUserResizeRows="False"
                      ColumnHeaderHeight="28"
                      MouseDoubleClick="GridFiles_DoubleClick"
                      SelectionChanged="GridFiles_SelectionChanged">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#111222"/>
                        <Setter Property="Foreground" Value="#606880"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="BorderBrush" Value="#1A1C2E"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.ContextMenu>
                    <ContextMenu Background="#0F1020" BorderBrush="#1E2038" BorderThickness="1"
                                 Foreground="#DDE0F0">
                        <MenuItem Header="⟳  Refresh"            Click="Refresh_Click">     <MenuItem.Icon><TextBlock Text="⟳" Foreground="#a6e3a1" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <Separator Background="#1E2038"/>
                        <MenuItem Header="▶  Execute Normal"     Click="Exec_Normal_Click">  <MenuItem.Icon><TextBlock Text="▶" Foreground="#a6e3a1" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="⬛ Execute Hidden"     Click="Exec_Hidden_Click">  <MenuItem.Icon><TextBlock Text="⬛" Foreground="#89b4fa" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="🛡 Execute As Admin"   Click="Exec_Admin_Click">   <MenuItem.Icon><TextBlock Text="🛡" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <Separator Background="#1E2038"/>
                        <MenuItem Header="⬇  Download"           Click="Download_Click">     <MenuItem.Icon><TextBlock Text="⬇" Foreground="#89b4fa" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="⬆  Upload here"        Click="Upload_Click">       <MenuItem.Icon><TextBlock Text="⬆" Foreground="#a6e3a1" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="📁 New Folder"         Click="NewFolder_Click">    <MenuItem.Icon><TextBlock Text="📁" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <Separator Background="#1E2038"/>
                        <MenuItem Header="✏  Rename"             Click="Rename_Click">       <MenuItem.Icon><TextBlock Text="✏" Foreground="#f9e2af" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="🗑 Delete"             Click="Delete_Click">       <MenuItem.Icon><TextBlock Text="🗑" Foreground="#f38ba8" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <Separator Background="#1E2038"/>
                        <MenuItem Header="# Hash (SHA-256)"      Click="Hash_Click">         <MenuItem.Icon><TextBlock Text="#" Foreground="#cba6f7" FontSize="11" FontFamily="Consolas"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="👁 Show / Hide"        Click="ShowHide_Click">     <MenuItem.Icon><TextBlock Text="👁" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="🖼 Set as Wallpaper"   Click="Wallpaper_Click">    <MenuItem.Icon><TextBlock Text="🖼" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="🎵 Play Music"         Click="PlayMusic_Click">    <MenuItem.Icon><TextBlock Text="🎵" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="📦 7-Zip (compress)"  Click="Zip_Click">          <MenuItem.Icon><TextBlock Text="📦" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="🌐 Download from URL" Click="DownloadUrl_Click">  <MenuItem.Icon><TextBlock Text="🌐" FontSize="11"/></MenuItem.Icon></MenuItem>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Name" Width="*" SortMemberPath="Name" CanUserSort="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Image Source="{Binding IconImage}" Width="16" Height="16"
                                           VerticalAlignment="Center" Margin="2,0,6,0"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                                           SnapsToDevicePixels="True"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Type"     Binding="{Binding TypeDisplay}" Width="70"  CanUserSort="True" SortMemberPath="TypeDisplay"/>
                    <DataGridTextColumn Header="Size"     Binding="{Binding SizeDisplay}" Width="80"  CanUserSort="True" SortMemberPath="SizeRaw"/>
                    <DataGridTextColumn Header="Modified" Binding="{Binding Modified}"    Width="130" CanUserSort="True" SortMemberPath="Modified"/>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Column="1" Width="4" Background="#0F1020"
                          HorizontalAlignment="Stretch" Cursor="SizeWE"/>

            <!-- Preview pane -->
            <Border Grid.Column="2" Background="#07080F" BorderBrush="#1A1C2E" BorderThickness="1,0,0,0">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" Height="30" Background="#0F1020"
                            BorderBrush="#1A1C2E" BorderThickness="0,0,0,1" Padding="10,0">
                        <Grid>
                            <TextBlock x:Name="TxtPreviewName" Text="No file selected"
                                       Foreground="#404868" FontSize="10" FontFamily="Consolas"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="BtnPreview" Content="Preview" Height="20" Padding="8,0"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Style="{StaticResource SBtn}" FontSize="9"
                                    Click="BtnPreview_Click" IsEnabled="False"/>
                        </Grid>
                    </Border>
                    <Grid>
                        <ScrollViewer x:Name="ImgScroll" Visibility="Collapsed"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <Image x:Name="PreviewImage" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </ScrollViewer>
                        <MediaElement x:Name="PreviewVideo" Visibility="Collapsed"
                                      LoadedBehavior="Manual" Stretch="Uniform"
                                      MouseLeftButtonUp="PreviewVideo_Click"/>
                        <ScrollViewer x:Name="TextScroll" Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="PreviewText"
                                     Background="Transparent" Foreground="#C8D0E8"
                                     FontFamily="Consolas" FontSize="10"
                                     BorderThickness="0" Padding="8"
                                     IsReadOnly="True" TextWrapping="Wrap"/>
                        </ScrollViewer>
                        <StackPanel x:Name="PreviewEmpty" VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="📄" FontSize="40" Opacity="0.12"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtPreviewInfo" Text="Select a file"
                                       Foreground="#2A3050" FontSize="10" FontFamily="Consolas"
                                       HorizontalAlignment="Center" Margin="0,8,0,0" TextWrapping="Wrap"
                                       MaxWidth="200"/>
                        </StackPanel>
                    </Grid>
                </DockPanel>
            </Border>

            </Grid>
        </DockPanel>
    </Border>
</Window>
