<Window x:Class="SeroServer.UI.FileManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Manager"
        Width="1000" Height="600" MinWidth="720" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="FmBtn" TargetType="Button">
            <Setter Property="Background" Value="#1A2038"/>
            <Setter Property="Foreground" Value="#C0CCDD"/>
            <Setter Property="BorderBrush" Value="#2A3058"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#222A48"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0E1428"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="8" BorderThickness="1" ClipToBounds="True">
        <Border.Background><SolidColorBrush Color="#0C0D18"/></Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#2A2E50" Offset="0"/>
                <GradientStop Color="#141628" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="36" ShadowDepth="0" Opacity="0.80"/>
        </Border.Effect>

        <DockPanel LastChildFill="True">
            <!-- Accent bar -->
            <Rectangle DockPanel.Dock="Top" Height="2" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4A85F5" Offset="0"/>
                        <GradientStop Color="#7C5CE8" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="40" Background="#111222"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#4A85F5" Margin="0,0,10,0">&#x1F4C2; File Manager</TextBlock>
                        <TextBlock x:Name="TxtTitle" FontSize="11" Foreground="#8890B8" FontFamily="Consolas"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnMax" Content="&#x25A1;" Width="30" Height="26" Margin="0,0,4,0"
                                Style="{StaticResource SBtn}" FontSize="13" Padding="0" Click="BtnMax_Click"/>
                        <Button Content="&#x2715;" Width="28" Height="26" FontSize="10"
                                Style="{StaticResource SRedBtn}" Click="Close_Click" Padding="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Navigation bar (simplified) -->
            <Border DockPanel.Dock="Top" Height="36" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,0,0,1">
                <Grid Margin="8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="&#x25C0; Back" Height="26" Padding="10,0" Margin="0,0,4,0"
                            Style="{StaticResource FmBtn}" Click="Back_Click"/>
                    <Button Grid.Column="1" Content="&#x1F504;" Height="26" Width="28" Margin="0,0,6,0"
                            Style="{StaticResource FmBtn}" FontSize="13" Click="Refresh_Click"
                            ToolTip="Refresh current folder"/>
                    <TextBox x:Name="TxtPath" Grid.Column="2" Height="26"
                             Background="#0A0B14" Foreground="#C0CCDD" BorderBrush="#2A3058"
                             BorderThickness="1" Padding="6,3" FontFamily="Consolas" FontSize="11"
                             VerticalContentAlignment="Center" KeyDown="TxtPath_KeyDown"/>
                    <Button Grid.Column="3" Content="Go" Height="26" Width="36" Margin="4,0,0,0"
                            Style="{StaticResource FmBtn}" Click="GoPath_Click"/>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Height="26" Background="#111222"
                    BorderBrush="#1A1C2E" BorderThickness="0,1,0,0">
                <Grid>
                    <TextBlock x:Name="TxtStatus" Text="Ready" Foreground="#606880"
                               FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Margin="14,0"/>
                    <Thumb Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,4,0" Cursor="SizeNWSE" DragDelta="ResizeGrip_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Path Data="M2,12 L12,2 M5,12 L12,5 M9,12 L12,9"
                                      Stroke="#4A85F5" StrokeThickness="1.2" Opacity="0.6"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>
            </Border>

            <!-- Main: Left sidebar + File list + Preview -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>                         <!-- sidebar fixed, no splitter -->
                    <ColumnDefinition Width="1"/>                           <!-- thin separator, not draggable -->
                    <ColumnDefinition Width="*" MinWidth="280"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="220" MinWidth="180" MaxWidth="420"/>
                </Grid.ColumnDefinitions>

                <!-- Left sidebar -->
                <Border Grid.Column="0" Background="#0A0B14" BorderBrush="#1A1C2E" BorderThickness="0,0,1,0">
                    <DockPanel LastChildFill="True">

                        <!-- Quick Access header -->
                        <Border DockPanel.Dock="Top" Padding="10,6" Background="#111222"
                                BorderBrush="#1A1C2E" BorderThickness="0,0,0,1">
                            <TextBlock Text="QUICK ACCESS" FontSize="9" FontWeight="Bold"
                                       Foreground="#404868" FontFamily="Consolas"/>
                        </Border>

                        <!-- Quick access buttons -->
                        <StackPanel DockPanel.Dock="Top" Margin="0,4,0,0">
                            <Button Height="28" Margin="6,1" Style="{StaticResource FmBtn}" HorizontalContentAlignment="Left"
                                    Click="GoToDesktop_Click" Padding="8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F5A5;" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Desktop" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Height="28" Margin="6,1" Style="{StaticResource FmBtn}" HorizontalContentAlignment="Left"
                                    Click="GoToUser_Click" Padding="8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F464;" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="User" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Height="28" Margin="6,1" Style="{StaticResource FmBtn}" HorizontalContentAlignment="Left"
                                    Click="GoToTemp_Click" Padding="8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4C1;" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Temp" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Height="28" Margin="6,1" Style="{StaticResource FmBtn}" HorizontalContentAlignment="Left"
                                    Click="GoToAppData_Click" Padding="8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4BE;" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="AppData" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Height="28" Margin="6,1" Style="{StaticResource FmBtn}" HorizontalContentAlignment="Left"
                                    Click="GoToStartup_Click" Padding="8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F680;" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Startup" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Height="28" Margin="6,1" Style="{StaticResource FmBtn}" HorizontalContentAlignment="Left"
                                    Click="GoToWindows_Click" Padding="8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1FA9F;" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Windows" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Height="28" Margin="6,1" Style="{StaticResource FmBtn}" HorizontalContentAlignment="Left"
                                    Click="GoToSystem32_Click" Padding="8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x2699;" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="System32" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Drives header -->
                        <Border DockPanel.Dock="Top" Padding="10,6" Background="#111222"
                                BorderBrush="#1A1C2E" BorderThickness="0,1,0,1" Margin="0,8,0,0">
                            <TextBlock Text="DRIVES" FontSize="9" FontWeight="Bold"
                                       Foreground="#404868" FontFamily="Consolas"/>
                        </Border>

                        <!-- Drives list -->
                        <ListBox x:Name="DrivesList" Background="Transparent" BorderThickness="0"
                                 Foreground="#C0CCDD" FontFamily="Consolas" FontSize="12"
                                 Margin="0,4,0,0"
                                 SelectionChanged="DrivesList_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="8,5"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#111830"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#162040"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding Icon}" Width="16" Height="16"
                                               Margin="0,0,7,0" VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="{Binding Path}" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                    </DockPanel>
                </Border>

                <Rectangle Grid.Column="1" Fill="#1A1C2E" HorizontalAlignment="Stretch"/><!-- fixed separator -->

                <!-- Center: file list + status + preview -->
                <DockPanel Grid.Column="2" LastChildFill="True">

                <!-- Transfer/status strip at bottom of file list -->
                <Border DockPanel.Dock="Bottom" Height="24" Background="#0F1020"
                        BorderBrush="#1A1C2E" BorderThickness="0,1,0,0" Padding="12,0">
                    <Grid>
                        <TextBlock x:Name="TxtFileCount" Text="" Foreground="#505878"
                                   FontSize="10" FontFamily="Consolas" VerticalAlignment="Center"/>
                        <StackPanel x:Name="TransferStrip" Orientation="Horizontal" Visibility="Collapsed"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#x1F504; " Foreground="#89b4fa" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtTransferName" Text="" Foreground="#C0CCDD"
                                       FontSize="10" FontFamily="Consolas" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtTransferStatus" Text="" Foreground="#404868"
                                       FontSize="10" FontFamily="Consolas" VerticalAlignment="Center" Margin="6,0,0,0"/>
                            <TextBlock x:Name="TxtTransferPct" Text="" Foreground="#606880"
                                       FontSize="10" FontFamily="Consolas" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- File list -->
                <DataGrid x:Name="GridFiles"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Background="#0C0D18" Foreground="#DDE0F0"
                      BorderThickness="0" RowBackground="Transparent"
                      AlternatingRowBackground="#07101428"
                      GridLinesVisibility="None" HeadersVisibility="Column"
                      FontFamily="Consolas" FontSize="13"
                      SelectionMode="Extended" SelectionUnit="FullRow"
                      CanUserAddRows="False" CanUserResizeRows="False"
                      CanUserResizeColumns="True" CanUserReorderColumns="False"
                      ColumnHeaderHeight="28"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      EnableColumnVirtualization="True"
                      ScrollViewer.CanContentScroll="True"
                      MouseDoubleClick="GridFiles_DoubleClick"
                      SelectionChanged="GridFiles_SelectionChanged">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#111222"/>
                        <Setter Property="Foreground" Value="#606880"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="BorderBrush" Value="#1A1C2E"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.ContextMenu>
                    <ContextMenu Background="#0F1020" BorderBrush="#1E2038" BorderThickness="1"
                                 Foreground="#DDE0F0">
                        <MenuItem Header="&#x1F504; Refresh"            Click="Refresh_Click">     <MenuItem.Icon><TextBlock Text="&#x1F504;" Foreground="#a6e3a1" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <Separator Background="#1E2038"/>
                        <MenuItem Header="&#x25B6; Execute Normal"     Click="Exec_Normal_Click">  <MenuItem.Icon><TextBlock Text="&#x25B6;" Foreground="#a6e3a1" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="&#x25B6; Execute Hidden"     Click="Exec_Hidden_Click">  <MenuItem.Icon><TextBlock Text="&#x25B6;" Foreground="#89b4fa" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="&#x1F6E1; Execute As Admin"   Click="Exec_Admin_Click">   <MenuItem.Icon><TextBlock Text="&#x1F6E1;" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <Separator Background="#1E2038"/>
                        <MenuItem Header="&#x2B07; Download"           Click="Download_Click">     <MenuItem.Icon><TextBlock Text="&#x2B07;" Foreground="#89b4fa" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="&#x2B06; Upload here"        Click="Upload_Click">       <MenuItem.Icon><TextBlock Text="&#x2B06;" Foreground="#a6e3a1" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="&#x1F4C1; New Folder"         Click="NewFolder_Click">    <MenuItem.Icon><TextBlock Text="&#x1F4C1;" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <Separator Background="#1E2038"/>
                        <MenuItem Header="&#x270F; Rename"             Click="Rename_Click">       <MenuItem.Icon><TextBlock Text="&#x270F;" Foreground="#f9e2af" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="&#x1F5D1; Delete"             Click="Delete_Click">       <MenuItem.Icon><TextBlock Text="&#x1F5D1;" Foreground="#f38ba8" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <Separator Background="#1E2038"/>
                        <MenuItem Header="# Hash (SHA-256)"      Click="Hash_Click">         <MenuItem.Icon><TextBlock Text="#" Foreground="#cba6f7" FontSize="11" FontFamily="Consolas"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="&#x1F441; Show / Hide"        Click="ShowHide_Click">     <MenuItem.Icon><TextBlock Text="&#x1F441;" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="&#x2699; Set Attributes"     Click="SetAttr_Click">      <MenuItem.Icon><TextBlock Text="&#x2699;" Foreground="#f9e2af" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="&#x1F5BC; Set as Wallpaper"   Click="Wallpaper_Click">    <MenuItem.Icon><TextBlock Text="&#x1F5BC;" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="&#x1F3B5; Play Music"         Click="PlayMusic_Click">    <MenuItem.Icon><TextBlock Text="&#x1F3B5;" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="&#x1F5DC; 7-Zip (compress)"  Click="Zip_Click">          <MenuItem.Icon><TextBlock Text="&#x1F5DC;" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="&#x1F310; Download from URL" Click="DownloadUrl_Click">  <MenuItem.Icon><TextBlock Text="&#x1F310;" FontSize="11"/></MenuItem.Icon></MenuItem>
                        <Separator Background="#1E2038"/>
                        <MenuItem Header="Copy Name"     Click="GridFiles_CopyName_Click">     <MenuItem.Icon><TextBlock Text="&#x1F4CB;" FontSize="11" Foreground="#89b4fa"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="Copy Full Path" Click="GridFiles_CopyPath_Click">     <MenuItem.Icon><TextBlock Text="&#x1F4CB;" FontSize="11" Foreground="#89b4fa"/></MenuItem.Icon></MenuItem>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Name" Width="*" SortMemberPath="Name" CanUserSort="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Image Source="{Binding IconImage}" Width="16" Height="16"
                                           VerticalAlignment="Center" Margin="2,0,6,0"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                                           SnapsToDevicePixels="True"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Type"       Binding="{Binding TypeDisplay}"  Width="70"  CanUserSort="True" SortMemberPath="TypeDisplay" CanUserResize="True"/>
                    <DataGridTextColumn Header="Size"       Binding="{Binding SizeDisplay}"  Width="80"  CanUserSort="True" SortMemberPath="SizeRaw"    CanUserResize="True"/>
                    <DataGridTextColumn Header="Modified"   Binding="{Binding Modified}"     Width="130" CanUserSort="True" SortMemberPath="Modified"   CanUserResize="True"/>
                    <DataGridTextColumn Header="Created"    Binding="{Binding Created}"      Width="130" CanUserSort="True" SortMemberPath="Created"    CanUserResize="True"/>
                    <DataGridTextColumn Header="Attr"       Binding="{Binding AttribDisplay}" Width="50"  CanUserSort="False" CanUserResize="True"/>
                </DataGrid.Columns>
            </DataGrid>

                </DockPanel>

                <GridSplitter Grid.Column="3" Width="4" Background="#0F1020"
                              HorizontalAlignment="Stretch" Cursor="SizeWE"/>

                <!-- Preview pane (right) -->
                <Border Grid.Column="4" Background="#07080F" BorderBrush="#1A1C2E" BorderThickness="1,0,0,0">
                    <Grid>
                        <Image x:Name="PreviewImage" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Visibility="Collapsed"
                               HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        <MediaElement x:Name="PreviewVideo" Visibility="Collapsed"
                                      LoadedBehavior="Manual" UnloadedBehavior="Manual"
                                      Stretch="Uniform"
                                      MouseLeftButtonUp="PreviewVideo_Click"/>
                        <ScrollViewer x:Name="TextScroll" Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="PreviewText"
                                     Background="Transparent" Foreground="#C8D0E8"
                                     FontFamily="Consolas" FontSize="10"
                                     BorderThickness="0" Padding="8"
                                     IsReadOnly="True" TextWrapping="Wrap"/>
                        </ScrollViewer>
                        <StackPanel x:Name="PreviewEmpty" VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="&#x1F4C4;" FontSize="36" Opacity="0.10" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtPreviewInfo" Text="Select a file"
                                       Foreground="#2A3050" FontSize="10" FontFamily="Consolas"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"
                                       TextWrapping="Wrap" MaxWidth="200"/>
                        </StackPanel>
                        <!-- Filename overlay -->
                        <Border VerticalAlignment="Bottom" Background="#0D0F1A" Padding="8,4">
                            <TextBlock x:Name="TxtPreviewName" Text=""
                                       Foreground="#505878" FontSize="9" FontFamily="Consolas"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                        <!-- Preview button (invisible anchor for auto-trigger) -->
                        <Button x:Name="BtnPreview" Visibility="Collapsed"
                                Click="BtnPreview_Click" IsEnabled="False"/>
                    </Grid>
                </Border>

            </Grid>
        </DockPanel>
    </Border>
</Window>
