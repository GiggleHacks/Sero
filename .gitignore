# ── Third-party tools (place locally, not committed) ──────────────────────────
tools/
# xmrig binary: download separately and place in xmrig-release/xmrig.exe
xmrig-release/
# xmrig source (large self-contained repo)
xmrig-master/
pe-union-master/

# ── Closed-source components (NOT included in this repo) ──────────────────────
# loader.cpp (C++ native loader) is closed-source — not distributed.
# Crypter.cs: a no-op stub is committed so the project compiles without the crypter.
# Replace server/Builder/Crypter.cs with the real implementation locally, then run:
#   git update-index --assume-unchanged server/Builder/Crypter.cs
server/Stubs/loader.cpp
server/Builder/Crypter.cs.bak
loader/
crypter/
*.loader
*.crypter

# ── Miner embedded binary (generated at build time) ───────────────────────────
miner-stub/xmrig.bin
miner-stub/*.bak

# ── Certificates and runtime server data ──────────────────────────────────────
*.pfx
*.sero
*.cer
*.pem
*.p12
*.key
server_config.json
clients.json
server.log

# ── Plugin cache (compiled C++ DLL plugins, rebuilt on demand) ────────────────
plugin_cache/

